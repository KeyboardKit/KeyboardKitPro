{"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started-Article","interfaceLanguage":"swift"},"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit is a Swift SDK that lets you create fully customizable keyboard extensions in a few lines of code, using SwiftUI. It extends Apple’s limited keyboard APIs and provides you with a lot more functionality."}]},{"inlineContent":[{"type":"text","text":"Keyboard extensions can use KeyboardKit to create custom keyboards, while the main app can use it to show keyboard status, provide keyboard-specific settings screens, link to System Settings, etc."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This guide goes through the steps of adding ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit","type":"reference","isActive":true},{"text":" or ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true,"type":"reference"},{"text":" to your project and setting up the main app and keyboard.","type":"text"}]},{"type":"heading","text":"Step 1. Add KeyboardKit to your project","anchor":"Step-1-Add-KeyboardKit-to-your-project","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to add KeyboardKit to your app or package is with the Swift Package Manager. You can either install "},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit"}],"overridingTitle":"KeyboardKit","type":"reference"},{"type":"text","text":" to use the open-source library, or "},{"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"isActive":true,"overridingTitle":"KeyboardKit Pro","type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" to use the more capable, commercially licensed product:","type":"text"}]},{"type":"codeListing","code":["https:\/\/github.com\/KeyboardKit\/KeyboardKit.git      \/\/ or...","https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git"],"syntax":null},{"type":"paragraph","inlineContent":[{"text":"After adding the package to your project, you must link it correctly to be able to use it. KeyboardKit must be added to both the main app target and its keyboard extension, while KeyboardKit Pro must ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"only","type":"text"}]},{"text":" be added to the main app target.","type":"text"}]},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"text":"You only have to add KeyboardKit to the main app target if you want to use the library in it, for instance to show keyboard settings.","type":"text"}]}],"name":"Tip","type":"aside"},{"anchor":"Step-2-Define-app-specific-information","type":"heading","level":2,"text":"Step 2. Define app-specific information"},{"type":"paragraph","inlineContent":[{"text":"The easiest way to set up KeyboardKit is with a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"text":", which can define ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"text":", a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true,"type":"reference"},{"text":", etc.","type":"text"}]},{"type":"codeListing","code":["import KeyboardKit (or KeyboardKitPro)","","extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        KeyboardApp(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                    \/\/ You may also use a license file","            bundleId: \"com.keyboardkit.demo\",","            appGroupId: \"group.com.keyboardkit.demo\",       \/\/ This will set up settings syncing","            locales: .keyboardKitSupported,                 \/\/ This list is capped to your license ","            autocomplete: .init(","                nextWordPredictionRequest: .claude(apiKey: \"your-key-here\")","            ),","            deepLinks: .init(","                app: \"kkdemo:\/\/\",                           \/\/ This can be used to open your app","                dictation: \"kkdemo:\/\/dictation\"             \/\/ This is the default url for the app url","            )","        )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define this in a file that you add to both the app and its keyboard extension, to easily refer to it from both. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article"},{"type":"text","text":" for more info."}]},{"text":"Step 3. Set up the keyboard extension","anchor":"Step-3-Set-up-the-keyboard-extension","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To set up a keyboard to use KeyboardKit, first inherit "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" instead of "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UIInputViewController","isActive":true},{"type":"text","text":":"}]},{"code":["import KeyboardKit (or KeyboardKitPro)","","class KeyboardController: KeyboardInputViewController {}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This gives you access to lifecycle functions like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","isActive":true,"type":"reference"},{"type":"text","text":", observable "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"type":"text","text":", keyboard "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"type":"text","text":", etc."}]},{"inlineContent":[{"type":"text","text":"To set up the keyboard for your app, just override "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()","isActive":true},{"text":" and call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:)"},{"text":" (or ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupPro(for:errorDisplay:completion:)"},{"type":"text","text":" if you use "},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"isActive":true},{"text":") with your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":" value:"}],"type":"paragraph"},{"tabs":[{"title":"KeyboardKit","content":[{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","    }","}"]}]},{"content":[{"syntax":"swift","type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo) { result in","            \/\/ This is called when the license registration completes","        }","    }","}"]}],"title":"KeyboardKit Pro 👑"}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will make keyboard "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Settings","type":"reference"},{"text":" sync data between the app and its keyboard extension if you define a valid ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true},{"type":"text","text":", set up your KeyboardKit Pro license if you define a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","type":"reference","isActive":true},{"type":"text","text":", set up dictation, deep links, etc."}]},{"type":"paragraph","inlineContent":[{"text":"This is all you have to do if you want to use the standard ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true},{"text":" with a standard configuration. Upgrade to KeyboardKit Pro to unlock more locales and features, like autocomplete and an emoji keyboard.","type":"text"}]},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro has an "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard","type":"reference","isActive":true},{"type":"text","text":" that uses high-resolution emojis on iPad. This consumes memory as you scroll through categories, which can become a problem if your keyboard uses memory intense resources, since extensions are memory capped at ~70 MB. If you notice memory-related crashes, consider applying an "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/KeyboardStyle\/optimized(for:)","type":"reference","isActive":true},{"type":"text","text":" emoji style (see below)."}]}],"type":"aside"},{"anchor":"Step-4-Customize-the-keyboard-extension-optional","level":2,"text":"Step 4. Customize the keyboard extension (optional)","type":"heading"},{"inlineContent":[{"type":"text","text":"You can customize the keyboard and its behavior by customizing its "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardController\/services","isActive":true},{"text":", adjusting it’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardController\/state"},{"type":"text","text":" and their settings, customizing the standard "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"text":" or use a completely custom view, etc.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Just override "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","isActive":true},{"text":" and call ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","type":"reference","isActive":true},{"text":" to replace or customize ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        super.viewWillSetupKeyboardView()","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                services: controller.services","            )","        }","    }","}","","\/\/ Use a custom view if you need to observe some state, like","\/\/ the many context classes that KeyboardKit injects.","struct CustomKeyboardView: View {","","    \/\/ These are not used here, but perhaps you need them.","    var services: Keyboard.Services","","    \/\/ Keyboard state can be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: controller.state,","                services: controller.services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ Each view provides additional parameters than $0.view             ","                collapsedView: { $0.view },","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ This ignores the params and uses a custom view","            )","        }","    }","}"]},{"type":"aside","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true,"type":"reference"},{"type":"text","text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"code":"[weak self]","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":", or the self reference will cause a memory leak!"}]}],"name":"Warning"},{"text":"Step 5. Set up the main app (optional)","level":2,"anchor":"Step-5-Set-up-the-main-app-optional","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to manage the enabled and Full Access status of a keyboard, provide keyboard settings, link to System Settings, etc. It’s a great place for app settings, since it has more space."}]},{"inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","isActive":true},{"text":" root view, which uses a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"type":"text","text":" to set up everything it needs:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"This will make keyboard "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Settings"},{"type":"text","text":" sync data between the app and its keyboard extension if you define a valid "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","type":"reference","isActive":true},{"type":"text","text":", set up your KeyboardKit Pro license if you define a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","type":"reference","isActive":true},{"text":", set up dictation, deep links, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can use the KeyboardKit Pro ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen"},{"type":"text","text":" to easily set up a start screen for the app, or link to the individual "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","isActive":true,"type":"reference"},{"type":"text","text":", and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen","type":"reference","isActive":true},{"type":"text","text":" screens from any screen. You can also use a status "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","type":"reference","isActive":true},{"type":"text","text":" to show keyboard status."}],"type":"paragraph"},{"anchor":"Step-6-Customize-state--services-optional","type":"heading","level":2,"text":"Step 6. Customize state & services (optional)"},{"inlineContent":[{"type":"text","text":"The main "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"type":"text","text":" provides you with keyboard "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","type":"reference","isActive":true},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":", to let you build great keyboards."}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:","type":"text"}],"type":"paragraph"},{"code":["struct CustomKeyboardView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        VStack { ","            Button(\"Show Numeric Keyboard\") {","                keyboardContext.keyboardType = .numeric ","            }","            KeyboardView(","                state: controller.state,","                services: controller.services,","                buttonContent: { $0.view },","                buttonView: { $0.view },","                collapsedView: { $0.view },","                emojiKeyboard: { $0.view },","                toolbar: { _ in CustomToolbar() }","            )","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can replace any services with custom implementations. For instance, here we replace the standard "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","        services.actionHandler = CustomActionHandler(controller: self)","    }","}","","class CustomActionHandler: StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"]},{"inlineContent":[{"type":"text","text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible."}],"type":"paragraph"},{"anchor":"Thats-it","text":"That’s it!","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should now have a fully functional keyboard extension and companion app, which you can customize even further to fit your needs. For more information, see the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","isActive":true,"type":"reference"},{"text":" article, as well as the other articles in this documentation.","type":"text"}]},{"type":"thematicBreak"},{"text":"Advanced","level":2,"type":"heading","anchor":"Advanced"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This section contains information for more advanced configurations."}]},{"type":"heading","anchor":"Set-up-KeyboardKit-as-a-package-dependency","level":3,"text":"Set up KeyboardKit as a package dependency"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"inlineContent":[{"text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"]}]},{"title":"KeyboardKit Pro 👑","content":[{"inlineContent":[{"type":"text","text":"To set up KeyboardKit Pro as a package dependency, just add it to package dependencies and link it to any target that needs it."}],"type":"paragraph"},{"syntax":"swift","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"type":"codeListing"},{"style":"important","name":"Important","type":"aside","content":[{"inlineContent":[{"text":"The KeyboardKit Pro binary may require some special handling to be used as a dependency. You don’t have to link to KeyboardKit Pro from any target that adds ","type":"text"},{"inlineContent":[{"type":"text","text":"your"}],"type":"emphasis"},{"type":"text","text":" package, but the target "},{"inlineContent":[{"text":"must","type":"text"}],"type":"emphasis"},{"type":"text","text":" update "},{"inlineContent":[{"text":"runpath search paths","type":"text"}],"type":"strong"},{"type":"text","text":" under "},{"inlineContent":[{"type":"text","text":"Build Settings"}],"type":"strong"},{"text":". For an app, set it to ","type":"text"},{"inlineContent":[{"type":"text","text":"@executable_path\/Frameworks"}],"type":"strong"},{"text":". For a keyboard, set it to ","type":"text"},{"inlineContent":[{"text":"@executable_path\/..\/..\/Frameworks","type":"text"}],"type":"strong"},{"text":". Failing to set the search paths will cause a runtime crash when you try to use KeyboardKit Pro.","type":"text"}],"type":"paragraph"}]}]}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]}],"sections":[],"metadata":{"role":"article","images":[{"type":"card","identifier":"Page.png"}],"roleHeading":"Article","title":"Getting Started","modules":[{"name":"KeyboardKitPro"}]},"abstract":[{"type":"text","text":"This article describes how to get started with KeyboardKit."}],"references":{"https://github.com/KeyboardKit/KeyboardKitPro":{"title":"KeyboardKit Pro","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","titleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"url":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"link"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardStatus/Section":{"title":"KeyboardStatus.Section","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"Section","kind":"identifier"}],"abstract":[{"type":"text","text":"This section can be used to show keyboard status for"},{"type":"text","text":" "},{"type":"text","text":"a certain keyboard bundle ID."}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"Section","kind":"identifier"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","url":"\/documentation\/keyboardkitpro\/keyboardstatus\/section"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Emoji/KeyboardStyle/optimized(for:)":{"kind":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/KeyboardStyle\/optimized(for:)","type":"topic","url":"\/documentation\/keyboardkitpro\/emoji\/keyboardstyle\/optimized(for:)","title":"optimized(for:)","role":"symbol","abstract":[{"type":"text","text":"Get a memory optimized style for a certain context."}],"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"optimized"},{"text":"(","kind":"text"},{"te