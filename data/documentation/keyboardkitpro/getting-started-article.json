view },","                toolbar: { _ in CustomToolbar() }","            )","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"KeyboardInputViewController\/setupKeyboardView(_:)-qfea","type":"codeVoice"},{"type":"text","text":" view builder provides you with an unowned controller reference, since referring to self may cause memory leaks. However, since it’s a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference"},{"type":"text","text":" you still need self to refer to your specific controller. If so, you MUST use "},{"code":"[weak self]","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"[unowned self]"},{"text":", otherwise the self reference will cause a memory leak.","type":"text"}]}],"name":"Warning"},{"text":"How to set up KeyboardKit for the main app target","anchor":"How-to-set-up-KeyboardKit-for-the-main-app-target","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to manage the enabled and Full Access status of a keyboard, provide keyboard settings, link to System Settings, etc. It’s a great place for app settings, since it has more space."}]},{"type":"paragraph","inlineContent":[{"text":"The easiest way to set up an app is to use a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView"},{"type":"text","text":" root view, which uses a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" to set up everything it needs:"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","            ContentView()","                .task { setupKeyboardKitPro() }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will make the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","isActive":true},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/store","type":"reference"},{"type":"text","text":" sync data between the app and its keyboard if an "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true},{"type":"text","text":" is defined, register a KeyboardKit Pro license if a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true},{"text":" is defined, and set up dictation, deep links, etc.","type":"text"}]},{"text":"Setting up KeyboardKit Pro before 8.9","level":4,"anchor":"Setting-up-KeyboardKit-Pro-before-89","type":"heading"},{"inlineContent":[{"text":"If you have not yet started using the new ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"text":" approach, you must manually register your KeyboardKit Pro license key:","type":"text"}],"type":"paragraph"},{"code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            ContentView()","                .task { setupKeyboardKitPro() }","        }","    }","}","","extension MyApp {","","    func setupKeyboardKitPro() async throws {","        do {","            let license = try await License.register(...)","            \/\/ KeyboardKit Pro is now activated.","        } catch {","            print(error)","            \/\/ Handle the license error in any way you want.","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"KeyboardKit 9 will exclusively use the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"type":"text","text":" approach, since it is easier and sets up all you need with a single line of code."}],"type":"paragraph"},{"type":"heading","level":2,"text":"How to set up KeyboardKit as a package dependency","anchor":"How-to-set-up-KeyboardKit-as-a-package-dependency"},{"inlineContent":[{"type":"text","text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it."}],"type":"paragraph"},{"text":"👑 KeyboardKit Pro","type":"heading","level":3,"anchor":"%F0%9F%91%91-KeyboardKit-Pro"},{"inlineContent":[{"text":"Since KeyboardKit Pro is a binary target, it requires some special handling to be used as a transient package dependency:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You don’t have to link to KeyboardKit Pro from any target.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"You ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" update "},{"inlineContent":[{"type":"text","text":"runpath search paths"}],"type":"strong"},{"text":" under ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Build Settings"}]},{"type":"text","text":"."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"For the main app, set it to ","type":"text"},{"inlineContent":[{"type":"text","text":"@executable_path\/Frameworks"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"i