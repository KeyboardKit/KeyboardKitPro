{"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"seeAlsoSections":[{"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-KeyboardView"],"generated":true,"title":"Essentials","anchor":"Essentials"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started-Article"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide goes through the steps of adding "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" to your project and setting up the main app and keyboard."}]},{"type":"heading","text":"Step 1. Add KeyboardKit to your project","anchor":"Step-1-Add-KeyboardKit-to-your-project","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to add KeyboardKit to your app or package is with the Swift Package Manager. You can either use "},{"overridingTitle":"KeyboardKit","type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit"},{"type":"text","text":" or the more capable, commercially licensed "},{"overridingTitle":"KeyboardKit Pro","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/KeyboardKit\/KeyboardKit.git      \/\/ or...","https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit must be linked to the main app target "},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" its keyboard extension, while KeyboardKit Pro must "},{"type":"emphasis","inlineContent":[{"text":"only","type":"text"}]},{"type":"text","text":" be added to the app."}]},{"type":"heading","text":"Step 2. Define app-specific information","anchor":"Step-2-Define-app-specific-information","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to set up KeyboardKit is with a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":", which can define "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId"},{"type":"text","text":", a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey"},{"type":"text","text":", etc."}]},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit (or KeyboardKitPro)","","extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        .init(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                \/\/ Required by KeyboardKit Pro!","            appGroupId: \"group.com.keyboardkit.demo\",   \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up custom autocomplete  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"kkdemo:\/\/\", ...)     \/\/ Defines how to open the app","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define this in a file that you add to both the app and its keyboard extension, to be able to use it in both targets. See "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","isActive":true},{"type":"text","text":" for more info."}]},{"type":"heading","text":"Step 3. Set up the keyboard extension","anchor":"Step-3-Set-up-the-keyboard-extension","level":2},{"type":"paragraph","inlineContent":[{"text":"To set up a keyboard to use KeyboardKit, first inherit ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"text":" instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UIInputViewController"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit (or KeyboardKitPro)","","class KeyboardController: KeyboardInputViewController {}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This unlocks additional functions and capabilities, like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"type":"text","text":", and adds "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":" and observable "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" to the controller."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Next, override "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()","isActive":true,"type":"reference"},{"type":"text","text":" and call "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:completion:)","isActive":true,"type":"reference"},{"type":"text","text":" to set up the keyboard extension for your app:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        ","        setup(for: .keyboardKitDemo) { result in","            \/\/ If the result is `.success`, the setup succeeded.","            \/\/ This is where you can setup custom services, etc.","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting up the controller makes "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings"},{"type":"text","text":" automatically sync data between the app and its keyboard if the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":" defines an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId"},{"type":"text","text":", set up KeyboardKit Pro if it defines a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey"},{"type":"text","text":", sets up dictation, registers deep links, etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To replace or customize the default "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" that will otherwise be used as the standard keyboard view, just override "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"type":"text","text":" and call "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)"},{"type":"text","text":" with the view that you want to use:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                state: controller.state","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var state: Keyboard.State","    var services: Keyboard.Services","","    \/\/ State can also be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: state,","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 has additional parameter data             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ Ignores the params and returns a view","            )","        }","    }","}"]},{"style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true},{"type":"text","text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"type":"codeVoice","code":"[weak self]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":", or the self reference will cause a memory leak!"}]}],"name":"Warning"},{"type":"heading","text":"Step 4. Set up the main app (optional)","anchor":"Step-4-Set-up-the-main-app-optional","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to display the enabled and Full Access status of your keyboard, link to System Settings, etc. It’s a great place for app and keyboard settings, since it has more space than in the keyboard extension."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","isActive":true},{"type":"text","text":" root view, which uses a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" to set up everything it needs:"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the KeyboardKit Pro "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true},{"type":"text","text":" to easily set up a start screen for the app, or link to the individual "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","isActive":true},{"type":"text","text":", and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen","isActive":true},{"type":"text","text":" screens from any screen. You can also use a status "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","isActive":true},{"type":"text","text":" to show keyboard status."}]},{"type":"heading","text":"Step 5. Customize state & services (optional)","anchor":"Step-5-Customize-state--services-optional","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The main "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"text":" provides you with keyboard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","type":"reference","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","type":"reference","isActive":true},{"text":", to let you build great keyboards.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        ...","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can replace any services with custom implementations. For instance, here we replace the standard "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":" with a custom action handler that prints a message when a "},{"type":"codeVoice","code":".space"},{"type":"text","text":" action is triggered:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo) { [weak self] _ in","            guard let self else { return }","            self.services.actionHandler = CustomActionHandler(controller: self)    ","        }","    }","}","","class CustomActionHandler: StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(action) ","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible."}]},{"type":"heading","text":"Bonus - Set up KeyboardKit as a package dependency","anchor":"Bonus-Set-up-KeyboardKit-as-a-package-dependency","level":2},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}],"type":"paragraph"},{"code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"syntax":"swift","type":"codeListing"}],"title":"KeyboardKit"},{"content":[{"inlineContent":[{"text":"To set up KeyboardKit Pro as a package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}],"type":"paragraph"},{"code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You don’t have to link to KeyboardKit Pro from any target that adds "},{"type":"emphasis","inlineContent":[{"type":"text","text":"your"}]},{"type":"text","text":" package, but the target "},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"type":"text","text":" update its "},{"type":"strong","inlineContent":[{"text":"runpath search paths","type":"text"}]},{"type":"text","text":" under "},{"type":"strong","inlineContent":[{"text":"Build Settings","type":"text"}]},{"type":"text","text":". Use "},{"type":"strong","inlineContent":[{"text":"@executable_path\/Frameworks","type":"text"}]},{"type":"text","text":" for the main app and "},{"type":"strong","inlineContent":[{"text":"@executable_path\/..\/..\/Frameworks","type":"text"}]},{"type":"text","text":" for the keyboard. Failing to set the search paths will cause a runtime crash when you try to use KeyboardKit Pro."}]}],"style":"important","type":"aside","name":"Important"}],"title":"KeyboardKit Pro 👑"}]},{"type":"heading","text":"That’s it!","anchor":"Thats-it","level":2},{"type":"paragraph","inlineContent":[{"text":"You should now have a fully functional keyboard extension and companion app, which you can customize even further to fit your needs. For more information, see the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","isActive":true},{"text":" article, as well as the other articles in this documentation.","type":"text"}]},{"type":"thematicBreak"}]}],"metadata":{"modules":[{"name":"KeyboardKitPro"}],"role":"article","images":[{"type":"card","identifier":"Page.png"}],"title":"Getting Started","roleHeading":"Article"},"kind":"article","abstract":[{"text":"This guide describes how to get started with KeyboardKit.","type":"text"}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardInputViewController/viewWillSetupKeyboardView()":{"url":"\/documentation\/keyboardkitpro\/keyboardinputviewcontroller\/viewwillsetupkeyboardview()","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","role":"symbol","kind":"symbol","title":"viewWillSetupKeyboardView()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"viewWillSetupKeyboardView","