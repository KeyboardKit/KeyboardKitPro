":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":", etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Override "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()","type":"reference"},{"text":" and call ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:)"},{"text":" (or ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupPro(for:errorDisplay:completion:)"},{"text":" if you use ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"overridingTitle":"KeyboardKit Pro"},{"type":"text","text":") to set up the keyboard extension for your app:"}],"type":"paragraph"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","    }","}"],"syntax":"swift"}]},{"title":"KeyboardKit Pro 👑","content":[{"syntax":"swift","type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setupPro(for: .keyboardKitDemo) { result in","            \/\/ This is called when the license registration completes","        }","    }","}"]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will make the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/store"},{"type":"text","text":" automatically sync data between the app and its keyboard if the app defines an "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"type":"text","text":", set up your KeyboardKit Pro license if it defines a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","type":"reference","isActive":true},{"type":"text","text":", set up dictation, deep links, etc."}]},{"type":"paragraph","inlineContent":[{"text":"This also makes the keyboard use a standard ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" that is configured for your app. Override "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","type":"reference"},{"type":"text","text":" and call "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true},{"type":"text","text":" to replace or customize the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true},{"type":"text","text":":"}]},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                state: controller.state","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var state: Keyboard.State","    var services: Keyboard.Services","","    \/\/ State can also be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: state,","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 has additional parameter data             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ Ignores the params and returns a view","            )","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"name":"Warning","style":"warning","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","type":"reference","isActive":true},{"type":"text","text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"type":"codeVoice","code":"[weak self]"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":", or the self reference will cause a memory leak!"}],"type":"paragraph"}]},{"anchor":"Step-4-Set-up-the-main-app-optional","type":"heading","text":"Step 4. Set up the main app (optional)","level":2},{"inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to display the enabled and Full Access status of your keyboard, link to System Settings, etc. It’s a great place for app and keyboard settings, since it has more space than in the keyboard extension."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","type":"reference","isActive":true},{"type":"text","text":" root view, which uses a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" to set up everything it needs:"}]},{"code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"You can use the KeyboardKit Pro ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true,"type":"reference"},{"type":"text","text":" to easily set up a start screen for the app, or link to the individual "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true,"type":"reference"},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","isActive":true},{"type":"text","text":", and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen","isActive":true},{"type":"text","text":" screens from any screen. You can also use a status "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","type":"reference"},{"type":"text","text":" to show keyboard status."}]},{"text":"Step 5. Customize state & services (optional)","level":2,"anchor":"Step-5-Customize-state--services-optional","type":"heading"},{"inlineContent":[{"type":"text","text":"The main "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"type":"text","text":" provides you with keyboard "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":", to let you build great keyboards.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        ...","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services."}]},{"type":"paragraph","inlineContent":[{"text":"You can replace any services with custom implementations. For instance, here we replace the standard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"tabs":[{"title":"KeyboardKit","content":[{"syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","        services.actionHandler = CustomActionHandler(controller: self)","    }","}"],"type":"codeListing"}]},{"title":"KeyboardKit Pro 👑","content":[{"syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setupPro(for: .keyboardKitDemo) { _ in ","            services.actionHandler = CustomActionHandler(controller: self)","        }","    }","}"],"type":"codeListing"}]}],"type":"tabNavigator"},{"type":"codeListing","syntax":"swift","code":["class CustomActionHandler: StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible."}]},{"type":"heading","anchor":"Bonus-Set-up-KeyboardKit-as-a-package-dependency","level":2,"text":"Bonus - Set up KeyboardKit as a package dependency"},{"tabs":[{"title":"KeyboardKit","content":[{"type":"paragraph","inlineContent":[{"text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}]},{"type":"codeListing","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"syntax":"swift"}]},{"content":[{"type":"paragraph",