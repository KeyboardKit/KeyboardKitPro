{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]}],"metadata":{"role":"article","modules":[{"name":"KeyboardKitPro"}],"title":"Getting Started","images":[{"type":"card","identifier":"Page.png"}],"roleHeading":"Article"},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"This guide goes through the steps of adding "},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"type":"text","text":" to your project and setting up the main app and keyboard."}],"type":"paragraph"},{"level":2,"text":"Step 1. Add KeyboardKit to your project","type":"heading","anchor":"Step-1-Add-KeyboardKit-to-your-project"},{"inlineContent":[{"text":"The easiest way to add KeyboardKit to your app or package is with the Swift Package Manager. You can either use ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit","overridingTitle":"KeyboardKit","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit","type":"text"}]},{"text":" or the more capable, commercially licensed ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","type":"reference","isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}]},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["https:\/\/github.com\/KeyboardKit\/KeyboardKit.git      \/\/ or...","https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git"]},{"inlineContent":[{"text":"KeyboardKit must be linked to the main app target ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"text":" its keyboard extension, while KeyboardKit Pro must ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"text":" be added to the app.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Step 2. Define app-specific information","type":"heading","anchor":"Step-2-Define-app-specific-information"},{"inlineContent":[{"type":"text","text":"The easiest way to set up KeyboardKit is with a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" that can define a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true},{"type":"text","text":", a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true},{"type":"text","text":", etc."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit (or KeyboardKitPro)","","extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        .init(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                \/\/ Required by KeyboardKit Pro!","            appGroupId: \"group.com.keyboardkit.demo\",   \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up custom autocomplete  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"kkdemo:\/\/\", ...)     \/\/ Defines how to open the app","        )","    }","}"]},{"inlineContent":[{"type":"text","text":"Define this in a file that you add to both the app and its keyboard extension, to be able to use it in both targets. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article"},{"type":"text","text":" for more info."}],"type":"paragraph"},{"level":2,"text":"Step 3. Set up the keyboard extension","type":"heading","anchor":"Step-3-Set-up-the-keyboard-extension"},{"inlineContent":[{"text":"To set up a keyboard to use KeyboardKit, first inherit ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"text":" instead of ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UIInputViewController","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit (or KeyboardKitPro)","","class KeyboardController: KeyboardInputViewController {}"]},{"inlineContent":[{"type":"text","text":"This unlocks additional functions and capabilities, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"type":"text","text":", and adds "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":" and observable "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" to the controller."}],"type":"paragraph"},{"inlineContent":[{"text":"Next, override ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()","type":"reference"},{"text":" and call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:completion:)","type":"reference"},{"text":" to set up the keyboard extension for your app:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        ","        \/\/ Set up the keyboard with the app we created above","        setup(for: .keyboardKitDemo) { result in","            \/\/ If the result is `.success`, the setup succeeded.","            \/\/ This is where you can setup custom services, etc.","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"Setting up the controller makes "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","isActive":true},{"type":"text","text":" automatically sync data between the app and its keyboard if the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" defines an "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true},{"type":"text","text":", set up KeyboardKit Pro if it defines a "},{"type":"codeVoice","code":"licenseKey"},{"type":"text","text":", sets up dictation, registers deep links, etc."}],"type":"paragraph"},{"inlineContent":[{"text":"To replace or customize the default ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference"},{"text":" that will otherwise be used as the standard keyboard view, just override ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","type":"reference"},{"text":" and call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","type":"reference"},{"text":" with the view that you want to use:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                state: controller.state","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var state: Keyboard.State","    var services: Keyboard.Services","","    \/\/ State can also be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: state,","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 has additional parameter data             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ Ignores the params and returns a view","            )","        }","    }","}"]},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)"},{"text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use ","type":"text"},{"code":"[weak self]","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"[unowned self]","type":"codeVoice"},{"text":", or the self reference will cause a memory leak!","type":"text"}]}]},{"level":2,"text":"Step 4. Set up the main app (optional)","type":"heading","anchor":"Step-4-Set-up-the-main-app-optional"},{"inlineContent":[{"text":"You can use KeyboardKit in your main app, to display the enabled and Full Access status of your keyboard, link to System Settings, etc. It’s a great place for app and keyboard settings, since it has more space than in the keyboard extension.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView"},{"type":"text","text":" root view, which uses a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":" to set up everything it needs:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","","            \/\/ Here we use the keyboard app we created above","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"]},{"inlineContent":[{"text":"You can use the KeyboardKit Pro ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true},{"text":" to easily set up a start screen for the app, or link to the individual ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","isActive":true},{"text":", and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen","isActive":true},{"text":" screens from any screen. You can also use a status ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","isActive":true},{"text":" to show keyboard status.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Step 5. Customize state & services (optional)","type":"heading","anchor":"Step-5-Customize-state--services-optional"},{"inlineContent":[{"type":"text","text":"The main "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true,"type":"reference"},{"text":" provides you with keyboard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":", to let you build great keyboards.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct CustomView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        ...","    }","}"]},{"inlineContent":[{"text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can replace any services with custom implementations. For instance, here we replace the standard ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":" with a custom action handler that prints a message when a ","type":"text"},{"code":".space","type":"codeVoice"},{"text":" action is triggered:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo) { [weak self] _ in","            guard let self else { return }","            self.services.actionHandler = CustomActionHandler(controller: self)    ","        }","    }","}","","class CustomActionHandler: StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(action) ","    }","}"]},{"inlineContent":[{"type":"text","text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible."}],"type":"paragraph"},{"level":2,"text":"Bonus - Set up KeyboardKit as a package dependency","type":"heading","anchor":"Bonus-Set-up-KeyboardKit-as-a-package-dependency"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it."}]},{"type":"codeListing","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"syntax":"swift"}]},{"title":"KeyboardKit Pro 👑","content":[{"inlineContent":[{"type":"text","text":"To set up KeyboardKit Pro as a package dependency, just add it to package dependencies and link it to any target that needs it."}],"type":"paragraph"},{"code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"type":"codeListing","syntax":"swift"},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"You don’t have to link to KeyboardKit Pro from any target that adds ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"your"}]},{"text":" package, but the target ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"must","type":"text"}]},{"text":" update its ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"runpath search paths"}]},{"text":" under ","type":"text"},{"type":"strong","inlineContent":[{"text":"Build Settings","type":"text"}]},{"text":". Use ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"@executable_path\/Frameworks"}]},{"text":" for the main app and ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"@executable_path\/..\/..\/Frameworks"}]},{"text":" for the keyboard. Failing to set the search paths will cause a runtime crash when you try to use KeyboardKit Pro.","type":"text"}]}]}]}]},{"level":2,"text":"That’s it!","type":"heading","anchor":"Thats-it"},{"inlineContent":[{"text":"You should now have a fully functional keyboard extension and companion app, which you can customize even further to fit your needs. For more information, see the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","isActive":true,"type":"reference"},{"text":" article, as well as the other articles in this documentation.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"}],"kind":"content"}],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started-Article","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Essentials","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-KeyboardView"],"anchor":"Essentials","generated":true}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"abstract":[{"text":"This guide describes how to get started with KeyboardKit.","type":"text"}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardStatus/Section":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Section"}],"url":"\/documentation\/keyboardkitpro\/keyboardstatus\/section","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Section"}],"role":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","abstract":[{"type":"text","text":"This section 