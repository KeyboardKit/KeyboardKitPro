ineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" its keyboard extension, while KeyboardKit Pro must only be added to the app."}]},{"anchor":"Step-2-Define-app-specific-information","type":"heading","text":"Step 2. Define app-specific information","level":2},{"inlineContent":[{"text":"The easiest way to set up KeyboardKit is with a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"text":", which can define ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"type":"text","text":", a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey"},{"text":", etc.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import KeyboardKit (or KeyboardKitPro)","","extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        .init(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                \/\/ Sets up KeyboardKit Pro!","            appGroupId: \"group.com.keyboardkit.demo\",   \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up custom autocomplete  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"kkdemo:\/\/\", ...)     \/\/ Defines how to open the app","        )","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Define this in a file that you add to both the app and its keyboard extension, to easily refer to it from both. See "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","isActive":true,"type":"reference"},{"type":"text","text":" for more info."}],"type":"paragraph"},{"text":"Step 3. Set up the keyboard extension","level":2,"anchor":"Step-3-Set-up-the-keyboard-extension","type":"heading"},{"inlineContent":[{"type":"text","text":"To set up a keyboard to use KeyboardKit, first inherit "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"type":"text","text":" instead of "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UIInputViewController","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import KeyboardKit (or KeyboardKitPro)","","class KeyboardController: KeyboardInputViewController {}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"This gives you access to lifecycle functions like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()","isActive":true},{"type":"text","text":", observable "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":", keyboard "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":", etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Override "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()"},{"text":" and call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:)","type":"reference"},{"type":"text","text":" (or "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupPro(for:errorDisplay:completion:)","isActive":true},{"type":"text","text":" if you use "},{"isActive":true,"overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"type":"text","text":") to set up the keyboard extension for your app:"}],"type":"paragraph"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","    }","}"],"syntax":"swift"}]},{"title":"KeyboardKit Pro 👑","content":[{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setupPro(for: .keyboardKitDemo) { result in","            \/\/ This is called when the license registration completes","        }","    }","}"]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will make the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/store"},{"text":" automatically sync data between the app and its keyboard if the app defines an ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true},{"type":"text","text":", set up your KeyboardKit Pro license if it defines a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","type":"reference"},{"text":", set up dictation, deep links, etc.","type":"text"}]},{"inlineContent":[{"text":"This also makes the keyboard use a standard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"type":"text","text":" that is configured for your app. Override "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"type":"text","text":" and call "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true,"type":"reference"},{"text":" to replace or customize the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                state: controller.state","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var state: Keyboard.State","    var services: Keyboard.Services","","    \/\/ State can also be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: state,","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 has additional parameter data             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ Ignores the params and returns a view","            )","        }","    }","}"],"syntax":"swift"},{"name":"Warning","style":"warning","type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true},{"type":"text","text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"type":"codeVoice","code":"[weak self]"},{"text":" or ","type":"text"},{"code":"[unowned self]","type":"codeVoice"},{"type":"text","text":", or the self reference will cause a memory leak!"}],"type":"paragraph"}]},{"text":"Step 4. Set up the main app (optional)","level":2,"anchor":"Step-4-Set-up-the-main-app-optional","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to display the enabled and Full Access status of your keyboard, link to System Settings, etc. It’s a great place for app and keyboard settings, since it has more space than in the keyboard extension."}]},{"inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView"},{"text":" root view, which uses a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","type":"reference"},{"text":" to set up everything it needs:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"You can use the KeyboardKit Pro "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true,"type":"reference"},{"type":"text","text":" to easily set up a start screen for the app, or link to the individual "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen"},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","isActive":true},{"text":", and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen","isActive":true},{"text":" screens from any screen. You can also use a status ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","isActive":true,"type":"reference"},{"type":"text","text":" to show keyboard status."}],"type":"paragraph"},{"anchor":"Step-5-Customize-state--services-optional","text":"Step 5. Customize state & services (optional)","level":2,"type":"heading"},{"inlineContent":[{"text":"The main ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"type":"text","text":" provides you with keyboard "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":", to let you build great keyboards."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:"}]},{"code":["struct CustomView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        ...","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can replace any services with custom implementations. For instance, here we replace the standard "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference"},{"text":":","type":"text"}]},{"tabs":[{"title":"KeyboardKit","content":[{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo)","        services.actionHandler = CustomActionHandler(controller: self)","    }","}"],"syntax":"swift","type":"codeListing"}]},{"title":"KeyboardKit Pro 👑","content":[{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setupPro(for: .keyboardKitDemo) { _ in ","            services.actionHandler = CustomActionHandler(controller: self)","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"type":"tabNavigator"},{"type":"codeListing","syntax":"swift","code":["class CustomActionHandler: StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"]},{"inlineContent":[{"text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Bonus-Set-up-KeyboardKit-as-a-package-dependency","text":"Bonus - Set up KeyboardKit as a package dependency"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"type":"paragraph","inlineContent":[{"text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"To set up KeyboardKit Pro as a package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}]},{"code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"Keyboar