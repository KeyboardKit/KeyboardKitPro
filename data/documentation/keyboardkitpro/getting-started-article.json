{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started-Article","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Essentials","generated":true,"anchor":"Essentials","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-KeyboardView"]}],"metadata":{"modules":[{"name":"KeyboardKitPro"}],"images":[{"type":"card","identifier":"Page.png"}],"roleHeading":"Article","role":"article","title":"Getting Started"},"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"This guide goes through the steps of adding ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit"},{"text":" or ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" to your project and setting up the main app and keyboard.","type":"text"}]},{"level":2,"text":"Step 1. Add KeyboardKit to your project","type":"heading","anchor":"Step-1-Add-KeyboardKit-to-your-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to add KeyboardKit to your app or package is with the Swift Package Manager. You can either use "},{"overridingTitle":"KeyboardKit","isActive":true,"type":"reference","overridingTitleInlineContent":[{"text":"KeyboardKit","type":"text"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit"},{"type":"text","text":" or the more capable, commercially licensed "},{"overridingTitle":"KeyboardKit Pro","isActive":true,"type":"reference","overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":":"}]},{"code":["https:\/\/github.com\/KeyboardKit\/KeyboardKit.git      \/\/ or...","https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit must be linked to the main app target "},{"type":"emphasis","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" its keyboard extension, while KeyboardKit Pro must "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":" be added to the app."}]},{"level":2,"text":"Step 2. Define app-specific information","type":"heading","anchor":"Step-2-Define-app-specific-information"},{"type":"paragraph","inlineContent":[{"text":"The easiest way to set up KeyboardKit is with a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"text":" that can define a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"text":", a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true,"type":"reference"},{"text":", etc.","type":"text"}]},{"code":["import KeyboardKit (or KeyboardKitPro)","","extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        .init(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                \/\/ Required by KeyboardKit Pro!","            appGroupId: \"group.com.keyboardkit.demo\",   \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up custom autocomplete  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"kkdemo:\/\/\", ...)     \/\/ Defines how to open the app","        )","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Define this in a file that you add to both the app and its keyboard extension, to be able to use it in both targets. See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article"},{"type":"text","text":" for more info."}]},{"level":2,"text":"Step 3. Set up the keyboard extension","type":"heading","anchor":"Step-3-Set-up-the-keyboard-extension"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To set up a keyboard to use KeyboardKit, first inherit "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"type":"text","text":" instead of "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UIInputViewController","type":"reference","isActive":true},{"type":"text","text":":"}]},{"code":["import KeyboardKit (or KeyboardKitPro)","","class KeyboardController: KeyboardInputViewController {}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This unlocks additional functions and capabilities, like ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"text":", and adds ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":" and observable ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"text":" to the controller.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Next, override ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewDidLoad()","isActive":true,"type":"reference"},{"text":" and call ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setup(for:completion:)","isActive":true,"type":"reference"},{"text":" to set up the keyboard extension for your app:","type":"text"}]},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        ","        \/\/ Set up the keyboard with the app we created above","        setup(for: .keyboardKitDemo) { result in","            \/\/ If the result is `.success`, the setup succeeded.","            \/\/ This is where you can setup custom services, etc.","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Setting up the controller makes "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","isActive":true,"type":"reference"},{"type":"text","text":" automatically sync data between the app and its keyboard if the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"type":"text","text":" defines an "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"type":"text","text":", set up KeyboardKit Pro if it defines a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true,"type":"reference"},{"type":"text","text":", sets up dictation, registers deep links, etc."}]},{"type":"paragraph","inlineContent":[{"text":"To replace or customize the default ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"text":" that will otherwise be used as the standard keyboard view, just override ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboardView()"},{"text":" and call ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)"},{"text":" with the view that you want to use:","type":"text"}]},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView( ","                state: controller.state","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var state: Keyboard.State","    var services: Keyboard.Services","","    \/\/ State can also be accessed from the enviroment.","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext.keyboardType == .email {","            \/\/ Insert your GPT-powered email client here :)","        } else {","            KeyboardView(","                state: state,","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 has additional parameter data             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ Ignores the params and returns a view","            )","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"name":"Warning","style":"warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true},{"type":"text","text":" provides you with an unowned controller, to help you avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"type":"codeVoice","code":"[weak self]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":", or the self reference will cause a memory leak!"}]}]},{"level":2,"text":"Step 4. Set up the main app (optional)","type":"heading","anchor":"Step-4-Set-up-the-main-app-optional"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use KeyboardKit in your main app, to display the enabled and Full Access status of your keyboard, link to System Settings, etc. It’s a great place for app and keyboard settings, since it has more space than in the keyboard extension."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to set up an app is to use a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","isActive":true},{"type":"text","text":" root view, which uses a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" to set up everything it needs:"}]},{"code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","","            \/\/ Here we use the keyboard app we created above","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the KeyboardKit Pro "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen"},{"type":"text","text":" to easily set up a start screen for the app, or link to the individual "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen"},{"type":"text","text":", and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/ThemeScreen"},{"type":"text","text":" screens from any screen. You can also use a status "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section"},{"type":"text","text":" to show keyboard status."}]},{"level":2,"text":"Step 5. Customize state & services (optional)","type":"heading","anchor":"Step-5-Customize-state--services-optional"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The main "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" provides you with keyboard "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"type":"text","text":", to let you build great keyboards."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects observable state into the view hierarchy as environment objects, which lets you access various state types like this:","type":"text"}]},{"code":["struct CustomView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: some View {","        ...","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can replace any services with custom implementations. For instance, here we replace the standard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"text":" with a custom action handler that prints a message when a ","type":"text"},{"type":"codeVoice","code":".space"},{"text":" action is triggered:","type":"text"}]},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .keyboardKitDemo) { [weak self] _ in","            guard let self else { return }","            self.services.actionHandler = CustomActionHandler(controller: self)    ","        }","    }","}","","class CustomActionHandler: KeyboardAction.StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(action) ","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible."}]},{"level":2,"text":"Bonus - Set up KeyboardKit as a package dependency","type":"heading","anchor":"Bonus-Set-up-KeyboardKit-as-a-package-dependency"},{"type":"tabNavigator","tabs":[{"title":"KeyboardKit","content":[{"inlineContent":[{"text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"]}]},{"title":"KeyboardKit Pro 👑","content":[{"type":"paragraph","inlineContent":[{"text":"To set up KeyboardKit Pro as a package dependency, just add it to package dependencies and link it to any target that needs it.","type":"text"}]},{"type":"codeListing","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro.git\",","        .upToNextMajor(from: \"9.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"],"syntax":"swift"},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"text":"You don’t have to link to KeyboardKit Pro from any target that adds ","type":"text"},{"inlineContent":[{"text":"your","type":"text"}],"type":"emphasis"},{"text":" package, but the target ","type":"text"},{"inlineContent":[{"type":"text","text":"must"}],"type":"emphasis"},{"text":" update its ","type":"text"},{"inlineContent":[{"type":"text","text":"runpath search paths"}],"type":"strong"},{"text":" under ","type":"text"},{"inlineContent":[{"text":"Build Settings","type":"text"}],"type":"strong"},{"text":". Use ","type":"text"},{"inlineContent":[{"text":"@executable_path\/Frameworks","type":"text"}],"type":"strong"},{"text":" for the main app and ","type":"text"},{"inlineContent":[{"text":"@executable_path\/..\/..\/Frameworks","type":"text"}],"type":"strong"},{"text":" for the keyboard. Failing to set the search paths will cause a runtime crash when you try to use KeyboardKit Pro.","type":"text"}],"type":"paragraph"}]}]}]},{"level":2,"text":"That’s it!","type":"heading","anchor":"Thats-it"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should now have a fully functional keyboard extension and companion app, which you can customize even further to fit your needs. For more information, see the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","type":"reference","isActive":true},{"type":"text","text":" article, as well as the other articles in this documentation."}]},{"type":"thematicBreak"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/getting-started-article"]}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"abstract":[{"text":"This guide describes how to get started with KeyboardKit.","type":"text"}],"kind":"article","sections":[],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardAction":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"KeyboardAction","kind":"identifier"}],"role":"symbol","abstract":[{"text":"This enum defines keyboard-specific actions, and is also","type":"text"},{"text":" ","type":"text"},{"text":"a namespace for keyboard action-related types.",