g","level":2,"text":"Services","anchor":"Services"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/FeedbackService","isActive":true,"type":"reference"},{"text":" can be used to trigger audio & haptic feedback as users interacts with the keyboard. The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":" protocol also implements this protocol, and will trigger feedback as actions are triggered.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback\/StandardFeedbackService","isActive":true,"type":"reference"},{"text":"  instance into ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":". You can replace it at any time, to customize how the keyboard triggers feedback.","type":"text"}]},{"type":"heading","level":2,"text":"Settings","anchor":"Settings"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/FeedbackSettings","isActive":true,"type":"reference"},{"type":"text","text":" with auto-persisted feedback-related settings. The context "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/FeedbackContext\/settings-swift.property","isActive":true,"type":"reference"},{"type":"text","text":" is used by default."}]},{"type":"thematicBreak"},{"type":"heading","level":2,"text":"How to…","anchor":"How-to"},{"type":"heading","level":3,"text":"…trigger keyboard feedback","anchor":"trigger-keyboard-feedback"},{"type":"paragraph","inlineCont