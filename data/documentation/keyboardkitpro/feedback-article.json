ce","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext"},{"text":" class that can be used to configure feedback for various gestures and actions. It also has auto-persisted ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","isActive":true},{"type":"text","text":" that can be used to customize the feedback behavior and toggle it on and off."}]},{"inlineContent":[{"text":"KeyboardKit automatically creates an instance of this class and injects it into ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":". You can use this instance to configure feedback."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Services","text":"Services"},{"inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","isActive":true},{"type":"text","text":" can be used to trigger audio & haptic feedback as users interacts with the keyboard. The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":" protocol also implements this protocol."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit injects a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/StandardFeedbackService"},{"text":"  instance into ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","type":"reference"},{"type":"text","te