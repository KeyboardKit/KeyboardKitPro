oller\/state"},{"type":"text","text":". You can use this instance to configure feedback."}]},{"type":"heading","text":"Services","level":2,"anchor":"Services"},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","isActive":true,"type":"reference"},{"text":" can be used to trigger audio & haptic feedback as users interacts with the keyboard. The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":" protocol also implements this protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit injects a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/StandardFeedbackService","isActive":true},{"type":"text","text":"  instance into "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"type":"text","text":". You can replace it at any time, to customize it to affect how the keyboard triggers feedback."}]},{"type":"heading","text":"Settings","level":2,"anchor":"Settings"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackSettings","isActive":true,"type":"reference"},{"text":" type with feedback-related settings. The context ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","isActive":true,"type":"reference"},{"text":" is used by default.","type":"text"}]},{"type":"thematicBreak"},{"type":"heading","text":"How to…","level":2,"anchor":"How-to"},{"type":"heading","text":"…trigger keyboard feedback","level":3,"anchor":"trigger-keyboard-feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can trigger "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio"},{"type":"text","text":" & "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic"},{"type":"text","text":" feedback with a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService"},{"type":"text","text":" or a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":". The standard action handler uses a nested feedback service by default."}]},{"type":"paragraph","inlineContent":[{"text":"To trigger feedback, just use ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerAudioFeedback(_:)","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerHapticFeedback(_:)","isActive":true,"type":"reference"},{"text":". The standard action handler has more ways to customize which feedback to trigger for specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"text":" gestures.","type":"text"}]},{"type":"heading","text":"…customize keyboard feedback","level":3,"anchor":"customize-keyboard-feedback"},{"type":"paragraph","inlineContent":[{"text":"You can configure the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/docu