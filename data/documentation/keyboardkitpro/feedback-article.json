t"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/HapticEngine","isActive":true,"type":"reference"},{"text":", etc.","type":"text"}]},{"type":"heading","level":2,"anchor":"Audio--Haptic-Feedback","text":"Audio & Haptic Feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true},{"type":"text","text":" enum defines audio feedback types, like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/input","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/system","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/delete","isActive":true},{"type":"text","text":", etc. The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback","isActive":true},{"type":"text","text":" namespace also has other audio-related types like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/AudioConfiguration","isActive":true},{"type":"text","text":", which can be used to define complex audio feedback behavior."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic","isActive":true,"type":"reference"},{"text":" enum defines haptic feedback types, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/success","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/warning","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/error","isActive":true,"type":"reference"},{"text":" etc. The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback","isActive":true,"type":"reference"},{"text":" namespace also has other haptic-related types like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/HapticConfiguration","isActive":true,"type":"reference"},{"text":", which can be used to define complex haptic feedback behavior.","type":"text"}]},{"type":"heading","level":2,"anchor":"Context","text":"Context"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has an observable ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext"},{"text":" class that can be used to configure feedback for various gestures and actions. It also has auto-persisted ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property"},{"text":" that can be used to customize the feedback behavior and toggle it on and off.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of this class and injects it into "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true},{"type":"text","text":". You can use this instance to configure feedback."}]},{"anchor":"Services","type":"heading","text":"Services","level":2},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService"},{"text":" can be used to trigger audio & haptic feedback as users interacts with the keyboard. The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":" protocol also implements this protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/StandardFeedbackService","type":"reference"},{"text":"  instance into ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","type":"reference"},{"text":". You can replace it at any time, to customize it to affect how the keyboard triggers feedback.","type":"text"}]},{"anchor":"Settings","type":"heading","text":"Settings","level":2},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackSettings","type":"reference"},{"text":" type with feedback-related settings. The context ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","type":"reference"},{"text":" is used by default.","type":"text"}]},{"type":"thematicBreak"},{"anchor":"How-to","type":"heading","text":"How to…","level":2},{"anchor":"trigger-keyboard-feedback","type":"heading","text":"…trigger keyboard feedback","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can trigger "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true},{"type":"text","text":" & "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic","isActive":true},{"type":"text","text":" feedback with a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","isActive":true},{"type":"text","text":" or a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":". The standard action handler uses a nested feedback service by default."}]},{"type":"paragraph","inlineContent":[{"text":"To trigger feedback, just use ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerAudioFeedback(_:)","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerHapticFeedback(_:)","isActive":true,"type":"reference"},{"text":". The standard action handler has more ways to customize which feedback to trigger for specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"text":" gestures.","type":"text"}]},{"type":"heading","anchor":"customize-keyboard-feedback","level":3,"text":"…customize keyboard feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can configure the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State\/feedbackContext"},{"type":"text","text":"  in the main "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" to configure the feedback behavior. For instance, this would customize the audio feedback for input keys, then disable haptic feedback:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.audioConfiguration.input = .custom(id: 1329)","        context.settings.isHapticFeedbackEnabled = false","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use use the context to register custom feedback for any gesture on any action."}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.registerCustomFeedback(.audio(.rocketFuse, for: .press, on: .rocket))","        context.registerCustomFeedback(.audio(.rocketLaunch, for: .release, on: .rocket))","        context.registerCustomFeedback(.haptic(.selection, for: .repeat, on: .rocket))","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Since the configuration is observable, any changes will automatically cause the keyboard to update, e.g. if you have feedback toggles.","type":"text"}]},{"type":"heading","anchor":"define-custom-audio-feedback","level":3,"text":"…define custom audio feedback"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true,"type":"reference"},{"text":" feedback type uses ","type":"text"},{"inlineContent":[{"type":"text","text":"AudioServices"}],"type":"strong"},{"text":", which means that you can use any system audio (see ","type":"text"},{"identifier":"https:\/\/iphonedev.wiki\/index.php\/AudioServices","isActive":true,"type":"reference"},{"text":" for info) as feedback:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension Feedback.Audio {","","    static let sentMessage = .custom(id: 1004)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/customUrl(_:)","isActive":true},{"type":"text","text":" feedback type to define a custom audio feedback that loads a sound effect from an audio file:"}]},{"type":"codeListing","syntax":"swift","code":["extension Feedback.Audio {","","    static let sentMessage = .customUrl(","        Bundle.main.url(forResource: \"sent\", withExtension: \"mp3\")","    )","}"]},{"type":"paragraph","inlineContent":[{"text":"You can also implement a custom action handler to trigger feedback in a different ways. See the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","type":"reference"},{"text":" article for more information.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/feedback-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/feedback-article"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback-Article","interfaceLanguage":"swift"},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardFeedback/AudioEngine":{"abstract":[{"text":"This engine can be used to trigger audio feedback.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identif