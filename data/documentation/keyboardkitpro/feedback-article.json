o\/documentation\/KeyboardKitPro\/KeyboardFeedback\/AudioEngine"},{"type":"text","text":" & "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/HapticEngine"},{"type":"text","text":", etc."}]},{"type":"heading","text":"Audio & Haptic Feedback","level":2,"anchor":"Audio--Haptic-Feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true},{"type":"text","text":" enum defines audio feedback types, like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/input","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/system","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/delete","isActive":true},{"type":"text","text":", etc. The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback","isActive":true},{"type":"text","text":" namespace also has other audio-related types like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/AudioConfiguration"},{"type":"text","text":", which can be used to define complex audio feedback behavior."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic","isActive":true},{"type":"text","text":" enum defines haptic feedback types, like "},{"type":"reference","identifier":