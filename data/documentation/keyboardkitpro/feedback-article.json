/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/AudioEngine","isActive":true},{"type":"text","text":" & "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/HapticEngine","isActive":true},{"type":"text","text":", etc."}],"type":"paragraph"},{"text":"Audio & Haptic Feedback","anchor":"Audio--Haptic-Feedback","type":"heading","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true,"type":"reference"},{"text":" enum defines audio feedback types, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/input","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/system","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio\/delete","isActive":true,"type":"reference"},{"text":", etc. The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback","isActive":true,"type":"reference"},{"text":" namespace also has other audio-related types like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/AudioConfiguration","isActive":true,"type":"reference"},{"text":", which can be used to define complex audio feedback behavior.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic","type":"reference"},{"type":"text","text":" enum defines haptic feedback types, like "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/success","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/warning","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic\/error","type":"reference"},{"type":"text","text":" etc. The "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback","type":"reference"},{"type":"text","text":" namespace also has other haptic-related types like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/HapticConfiguration"},{"type":"text","text":", which can be used to define complex haptic feedback behavior."}],"type":"paragraph"},{"text":"Context","anchor":"Context","type":"heading","level":2},{"inlineContent":[{"text":"KeyboardKit has an observable ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext","type":"reference"},{"text":" class that can be used to configure feedback for various gestures and actions. It also has auto-persisted ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","type":"reference"},{"text":" that can be used to customize the feedback behavior and toggle it on and off.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of this class and injects it into "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":". You can use this instance to configure feedback."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Services","anchor":"Services"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In KeyboardKit, a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","isActive":true},{"type":"text","text":" can be used to trigger audio & haptic feedback as users interacts with the keyboard. The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":" protocol also implements this protocol."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/StandardFeedbackService"},{"text":"  instance into ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":". You can replace it at any time, to customize it to affect how the keyboard triggers feedback.","type":"text"}]},{"level":2,"type":"heading","text":"Settings","anchor":"Settings"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackSettings","type":"reference"},{"text":" type with feedback-related settings. The context ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","type":"reference"},{"text":" is used by default.","type":"text"}]},{"type":"thematicBreak"},{"level":2,"type":"heading","text":"How to…","anchor":"How-to"},{"level":3,"type":"heading","text":"…trigger keyboard feedback","anchor":"trigger-keyboard-feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can trigger "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","isActive":true},{"type":"text","text":" & "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic","isActive":true},{"type":"text","text":" feedback with a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","isActive":true},{"type":"text","text":" or a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":". The standard action handler uses a nested feedback service by default."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To trigger feedback, just use "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerAudioFeedback(_:)","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerHapticFeedback(_:)","isActive":true,"type":"reference"},{"type":"text","text":". The standard action handler has more ways to customize which feedback to trigger for specific "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"type":"text","text":" gestures."}]},{"level":3,"text":"…customize keyboard feedback","type":"heading","anchor":"customize-keyboard-feedback"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can configure the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State\/feedbackContext","type":"reference","isActive":true},{"type":"text","text":"  in the main "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","type":"reference","isActive":true},{"type":"text","text":" to configure the feedback behavior. For instance, this would customize the audio feedback for input keys, then disable haptic feedback:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.audioConfiguration.input = .custom(id: 1329)","        context.settings.isHapticFeedbackEnabled = false","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use use the context to register custom feedback for any gesture on any action."}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.registerCustomFeedback(.audio(.rocketFuse, for: .press, on: .rocket))","        context.registerCustomFeedback(.audio(.rocketLaunch, for: .release, on: .rocket))","        context.registerCustomFeedback(.haptic(.selection, for: .repeat, on: .rocket))","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Since the configuration is observable, any changes will automatically cause the keyboard to update, e.g. if you have feedback toggles.","type":"text"}]},{"level":3,"text":"…define custom audio feedback","type":"heading","anchor":"define-custom-audio-feedback"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","