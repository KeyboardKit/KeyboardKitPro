ence","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackSettings","isActive":true},{"type":"text","text":" type with feedback-related settings. The context "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackContext\/settings-swift.property","type":"reference"},{"type":"text","text":" is used by default."}]},{"type":"thematicBreak"},{"text":"How to…","level":2,"anchor":"How-to","type":"heading"},{"text":"…trigger keyboard feedback","type":"heading","level":3,"anchor":"trigger-keyboard-feedback"},{"inlineContent":[{"type":"text","text":"You can trigger "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Audio","type":"reference","isActive":true},{"type":"text","text":" & "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedback\/Haptic"},{"type":"text","text":" feedback with a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService","type":"reference","isActive":true},{"text":" or a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"text":". The standard action handler uses a nested feedback service by default.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To trigger feedback, just use "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerAudioFeedback(_:)","type":"reference"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardFeedbackService\/triggerHapticFeedback(_:)"},{"type":"text","text":". The standard action handler has 