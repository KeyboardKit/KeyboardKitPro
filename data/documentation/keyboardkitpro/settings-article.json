doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"],"title":"Features","generated":true}],"kind":"article","variants":[{"paths":["\/documentation\/keyboardkitpro\/settings-article"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/keyboardkitpro\/settings-article"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Great keyboard apps use the main app to show the current state of the keyboard, if the keyboard is enabled in System Settings, if Full Access is enabled, etc."}]},{"inlineContent":[{"type":"text","text":"Apps and keyboards can also navigate to System Settings to enable the keyboard extension, enable full access etc. Reading settings from the system is however strictly limited by iOS, due to privacy reasons."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit provides tools to make this easier, such as "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/URL"},{"type":"text","text":" extensions and custom navigation links."}]},{"anchor":"Keyboard-settings","level":2,"type":"heading","text":"Keyboard settings"},{"inlineContent":[{"text":"KeyboardKit has an observable ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings"},{"text":" class that defines common keyboard settings, as well as ways to define which ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/store"},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/storeKeyPrefix","isActive":true},{"text":" to use when persisting settings within the library.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Other namespaces have their own settings types, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AutocompleteSettings","type":"reference","isActive":true},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/DictationSettings"},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/FeedbackSettings","isActive":true},{"type":"text","text":", etc. These types will automatically persist changes and can sync changes between the app and keyboard (see further down)."}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"text":" has a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/settings"},{"text":" property for shared settings and will automatically sync its ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","type":"reference"},{"type":"text","text":" with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/settings"},{"type":"text","text":" when the keyboard is launched, and when any settings changes are made."}],"type":"paragraph"},{"anchor":"How-to-sync-settings-between-the-app-and-the-keyboard","text":"How to sync settings between the app and the keyboard","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/registerKeyboardSettingsStore(_:keyPrefix:)","isActive":true},{"type":"text","text":" function to register a custom settings store, for instance to sync user settings between the main app and the keyboard using an App Group:"}]},{"code":["KeyboardSettings.registerKeyboardSettingsStore(.init(suiteName: \"group.com.myapp\"))"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can access this shared store with the static "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/store","isActive":true},{"type":"text","text":" property, or use the computed user defaults "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/UserDefaults\/keyboardSettings","isActive":true},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"text":"Apps will always write data to an App Group, in a way that is instantly available to the keyboard. The keyboard must however have Full Access for changes to be immediately synced to the app. When Full Access is disabled, your keyboard will sync changes less reliably.","type":"text"}]},{"style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Since "},{"type":"codeVoice","code":"@AppStorage"},{"type":"text","text":" properties will use the store instance that is available when they are first called, you must register a custom store as soon as possible, before setting up KeyboardKit or reading these values."}],"type":"paragraph"}],"name":"Important"},{"text":"How to open System Settings","type":"heading","level":2,"anchor":"How-to-open-System-Settings"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit defines a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/URL\/keyboardSettings","type":"reference","isActive":true},{"type":"text","text":" URL that can be used to open your app’s keyboard settings in System Settings. You can use a standard SwiftUI link to open this URL from your app or your keyboard:"}]},{"syntax":"swift","type":"codeListing","code":["if let url = URL.keyboardSettings {","    Link(\"Open System Settings\", destination: url)","}"]},{"inlineContent":[{"type":"text","text":"You can also use the convenient "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/SettingsLink","type":"reference","isActive":true},{"type":"text","text":" link to link to System Settings. It will default use the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/URL\/keyboardSettings","isActive":true,"type":"reference"},{"text":" URL with an English text, but you can customize both the text and the entire content view:","type":"text"}],"type":"paragraph"},{"columns":[{"size":1,"content":[]},{"size":2,"content":[{"inlineContent":[{"identifier":"keyboardstatuslabel","type":"image"}],"type":"paragraph"}]},{"content":[],"size":1}],"type":"row","numberOfColumns":4},{"inlineContent":[{"type":"text","text":"To trigger a URL from the keyboard, you can trigger a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/url(_:id:)","isActive":true},{"text":" action to make the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":" open the URL.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If your app randomly navigates to the System Settings root instead of your app, try adding an empty settings bundle to your app."}]}]},{"anchor":"How-to-access-System-Settings","text":"How to access System Settings","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A common feature request is to be able to access various settings from System Settings, for instance autocapitalization & autocorrect preferences that the user has configured."}]},{"inlineContent":[{"text":"This is not possible, at least not with the public APIs. This is most probably due to privacy concerns, and unfortunately means that your app must provide its own keyboard settings.","type":"text"}],"type":"paragraph"},{"text":"Views","type":"heading","level":2,"anchor":"Views"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","isActive":true,"type":"reference"},{"type":"text","text":" namespace has settings-specific views, that can be used to link to System Settings:"}],"type":"paragraph"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A keyboard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/SettingsLink","isActive":true,"type":"reference"},{"text":" can be used to link to System Settings, or any other custom URL:","type":"text"}]},{"columns":[{"size":1,"content":[]},{"size":2,"content":[{"inlineContent":[{"type":"image","identifier":"keyboardstatuslabel"}],"type":"paragraph"}]},{"content":[],"size":1}],"numberOfColumns":4,"type":"row"},{"inlineContent":[{"text":"This view can use any content view, and is used by the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Status-Article"},{"type":"text","text":" views to link users to System Settings while displaying keyboard statuses."}]