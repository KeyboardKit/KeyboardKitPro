{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-KeyboardView"},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"content":[{"anchor":"Keyboard-View","level":2,"text":"Keyboard View","type":"heading"},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" that mimics the native iOS keyboard. It can be used for alphabetic, numeric & symbolic keyboards, as well as completely custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLayout"},{"type":"text","text":"s, and can be used on all Apple platforms:"}],"type":"paragraph"},{"numberOfColumns":3,"type":"row","columns":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"keyboardview-english"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"keyboardview-swedish"}]}],"size":1},{"content":[{"inlineContent":[{"type":"image","identifier":"keyboardview-theme"}],"type":"paragraph"}],"size":1}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference"},{"text":" will automatically conform to the current configurations and settings in the various context and settings classes, like ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","type":"reference"},{"text":", apply gestures and callouts to its keys, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","isActive":true},{"type":"text","text":" makes "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"type":"text","text":" automatically support all the locales in your license, by using localized "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLayout","type":"reference","isActive":true},{"type":"text","text":"s that adapt to the current "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/locale","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/keyboardLayoutType","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Injected-Values-vs-View-Modifiers","level":2,"text":"Injected Values vs. View Modifiers","type":"heading"},{"inlineContent":[{"text":"Since the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"text":" has all the information it needs, it will set up most things for you. While you can customize each view, it will automatically apply gestures, styles, callouts, etc. based on the provided ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services","type":"reference","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can however apply some view modifiers, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardDockEdge(_:)","isActive":true,"type":"reference"},{"text":" to override the default values that  ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"text":" will otherwise apply. This support will be further extended throughout the KeyboardKit 9 lifecycle.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For instance, you will find that you can style many parts of the keyboard with both view modifiers and a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true,"type":"reference"},{"text":", while some styles don’t yet have a corresponding view modifier.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In general, use "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services","type":"reference","isActive":true},{"type":"text","text":", "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State","type":"reference","isActive":true},{"type":"text","text":", and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings","type":"reference","isActive":true},{"type":"text","text":" to customize the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"text":" and use view modifiers for styles and to override context and settings properties that have corresponding view modifiers.","type":"text"}],"type":"paragraph"},{"anchor":"How-to","type":"heading","level":2,"text":"How to"},{"level":3,"text":"…customize the keyboard","anchor":"customize-the-keyboard","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"text":" can be customized to great extent. You can pass in custom services & state, and replace any button or sub-view:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["KeyboardView(","    controller: controller,             \/\/ You can pass in a controller OR specific states and services","    buttonContent: { $0.view },         \/\/ You can customize the content view of any button","    buttonView: { $0.view },            \/\/ You can customize the entire view of any button","    collapsedView: { $0.view },         \/\/ You can customize the collapsed keyboard view","    emojiKeyboard: { $0.view },         \/\/ You can customize the emoji keyboard, if any","    toolbar: { params in params.view }  \/\/ You can customize the toolbar above the keyboard",")"]},{"type":"paragraph","inlineContent":[{"text":"Just return ","type":"text"},{"code":"{ $0.view }","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"{ params in params.view }"},{"text":" to use the standard view, or return a custom view for any part of the keyboard, using the contextual parameters that each view builder provides.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The standard emoji keyboard and collapsed view are unlocked by "},{"type":"reference","overridingTitle":"KeyboardKit Pro","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":". You can however inject any custom views you like."}]},{"type":"heading","anchor":"customize-the-keyboard-behavior","level":3,"text":"…customize the keyboard behavior"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to customize the behavior of the keyboard is to inherit "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true},{"type":"text","text":", then customize the behavior of any "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture","isActive":true},{"type":"text","text":" on any "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true},{"type":"text","text":" by overriding the various service functions."}]},{"type":"paragraph","inlineContent":[{"text":"See the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","isActive":true,"type":"reference"},{"text":" article for more information.","type":"text"}]},{"type":"heading","anchor":"customize-the-keyboard-callouts","level":3,"text":"…customize the keyboard callouts"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The easiest way to customize the secondary callout actions that are used for a specific key is to inherit "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardCallout\/StandardCalloutService"},{"type":"text","text":", then customize which actions to return any keys by overriding the various service functions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","isActive":true},{"type":"text","text":" article for more information."}]},{"type":"heading","anchor":"customize-the-keyboard-layout","level":3,"text":"…customize the keyboard layout"},{"type":"paragraph","inlineContent":[{"text":"The easiest way to add, replace and remove keys is to inherit ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLayout\/StandardLayoutService","type":"reference"},{"text":" and customize the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLayout","type":"reference"},{"text":" by overriding the various service functions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Layout-Article","isActive":true},{"type":"text","text":" article for more information."}]},{"type":"heading","anchor":"customize-the-keyboard-design","level":3,"text":"…customize the keyboard design"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The standard way to style the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"type":"text","text":" is to inherit "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","isActive":true,"type":"reference"},{"type":"text","text":" and customize styles by overriding the various service functions. You can change background and foreground colors, fonts, etc. for any part of the keyboard."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"From KeyboardKit 9.5, there are new "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardViewStyle(_:)","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardButtonStyle(builder:)","isActive":true},{"type":"text","text":" view modifiers, that can be used to customize the styling as well. These will replace the style service in KeyboardKit 10, if they prove successful."}]},{"type":"paragraph","inlineContent":[{"text":"See the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Styling-Article","type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article","type":"reference"},{"text":" articles for more information.","type":"text"}]},{"type":"heading","anchor":"customize-the-keyboard-size","level":3,"text":"…customize the keyboard size"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" will by default take up as much space as it needs, and resize the keyboard extension frame accordingly. It will:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Collapse when "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/isKeyboardCollapsed","isActive":true},{"type":"text","text":" is set, e.g. when connecting an external keyboard."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Collapse when an external keyboard is connected, if "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/isKeyboardAutoCollapseEnabled","isActive":true},{"type":"text","text":" is set."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Dock to any horizontal edge of the screen when ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardSettings\/keyboardDockEdge","isActive":true,"type":"reference"},{"text":" is set.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"tex