{"primaryContentSections":[{"content":[{"type":"heading","text":"Keyboard View","anchor":"Keyboard-View","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" that mimics the native iOS keyboard. It can be used for alphabetic, numeric & symbolic keyboards, as well as completely custom "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLayout"},{"type":"text","text":"s:"}],"type":"paragraph"},{"numberOfColumns":3,"type":"row","columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"keyboardview-english"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"keyboardview-swedish","type":"image"}]}]},{"size":1,"content":[{"inlineContent":[{"type":"image","identifier":"keyboardview-theme"}],"type":"paragraph"}]}]},{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"text":" will automatically observe and adapt to the current configurations and settings in the various context classes, and can render all localized keyboards that are unlocked by ","type":"text"},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","text":"How to","anchor":"How-to","level":2},{"type":"heading","text":"…customize the keyboard","anchor":"customize-the-keyboard","level":3},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"text":" will set up most things for you, like applying gestures, styles, callouts, etc. based on the ","typ