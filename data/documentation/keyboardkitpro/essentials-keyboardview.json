kit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference"},{"text":" will automatically observe and adapt to the current configurations and settings in the various context classes, and can render all localized keyboards that are unlocked by ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"text":".","type":"text"}]},{"text":"How to","anchor":"How-to","level":2,"type":"heading"},{"text":"…customize the keyboard","anchor":"customize-the-keyboard","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"text":" will set up most things for you, like applying gestures, styles, callouts, etc. based on the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State"},{"text":". You can customize any view in the keyboard, apply view modifiers to override the values that  ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"text":" will otherwise use, etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, you can customize any button content or button view by using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" init arguments, or use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboard