{"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"text":"KeyboardKit has ways to check various keyboard statuses, e.g. if a keyboard is enabled in System Settings, if Full Access is enabled, if a keyboard is actively being used, etc. This can be used to help users set up their keyboard.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"👑 ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"type":"text","text":" unlocks more keyboard status-related views & utilities. Information about Pro features can be found further down."}],"type":"paragraph"},{"text":"Namespace","anchor":"Namespace","level":2,"type":"heading"},{"inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus","isActive":true},{"text":" namespace that contains status-related types and views, like the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Label","type":"reference","isActive":true},{"text":" that can be used to visualize a certain status value, as well as the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","type":"reference"},{"type":"text","text":" which is unlocked by KeyboardKit Pro."}],"type":"paragraph"},{"text":"Context","level":2,"anchor":"Context","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The observable ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatusContext","isActive":true},{"text":" can be used to observe the state of any keyboard:","type":"text"}]},{"code":["struct MyView: View {","","    @StateObject","    var status = KeyboardStatusCon