{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"KeyboardKit has ways to check various keyboard statuses, e.g. if a keyboard is enabled in System Settings, if Full Access is enabled, if a keyboard is actively being used, etc. This can be used to help users set up their keyboard.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"👑 "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks more keyboard status-related views & utilities. Information about Pro features can be found further down."}],"type":"paragraph"},{"text":"Namespace","anchor":"Namespace","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus","isActive":true,"type":"reference"},{"type":"text","text":" namespace that contains status-related types and views, like the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Label","isActive":true,"type":"reference"},{"type":"text","text":" that can be used to visualize a certain status value, as well as the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","isActive":true,"type":"reference"},{"type":"text","text":" which is unlocked by KeyboardKit Pro."}],"type":"paragraph"},{"text":"Context","anchor":"Context","type":"heading","level":2},{"inlineContent":[{"text":"The observable ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatusContext","isActive":true},{"text":" can be used to observe the state of any keyboard:","type":"text"}],"type":"paragraph"},{"code":["struct MyView: View {","","    @StateObject","    var status = KeyboardStatusContext(bundleId: \"com.myapp.keyboard\")","","    var body: some View {","        VStack {","            Text(\"Enabled: \\(status.isKeyboardEnabled.description)\")","            Text(\"Active: \\(status.isKeyboardActive.description)\")","            Text(\"Full Access: \\(status.isFullAccessEnabled.description)\")","        }","    }","} "],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The context is observable, so any status changes will immediately cause the view to refresh. It supports bundle ID wildcards, which lets you inspect multiple keyboards with a single instance:","type":"text"}],"type":"paragraph"},{"code":["@StateObject","var status = KeyboardStatusContext(bundleId: \"com.myapp.*\")"],"type":"codeListing","syntax":null},{"text":"Views","anchor":"Views","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus"},{"type":"text","text":" namespace has status-specific views, that can be used to display various keyboard status-related values:"}],"type":"paragraph"},{"tabs":[{"title":"Label","content":[{"columns":[{"size":1,"content":[{"inlineContent":[{"type":"image","identifier":"keyboardstatuslabel"}],"type":"paragraph"}]},{"size":1,"content":[{"inlineContent":[{"text":"A keyboard status ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Label","type":"reference"},{"text":" can display various keyboard statuses, e.g. if a keyboard has been enabled, if Full Access is enabled, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The view supports custom texts, icons, etc. and can be styled with the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardStatusLabelStyle(_:)","type":"reference","isActive":true},{"text":" view modifier.","type":"text"}],"type":"paragraph"}]}],"numberOfColumns":2,"type":"row"}]}],"type":"tabNavigator"},{"type":"thematicBreak"},{"text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro","type":"heading","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}]},{"text":" unlocks additional keyboard status views and utilities, like a keyboard status section that can be added to the home or settings screen in an app that has a custom keyboard.","type":"text"}],"type":"paragraph"},{"tabs":[{"content":[{"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"keyboardstatussection"}]}]},{"size":1,"content":[{"inlineContent":[{"text":"A keyboard status ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section","isActive":true},{"text":" can display all relevant status labels for a keyboard extension, with a link to System Settings if needed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The view is used by the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true},{"type":"text","text":" component, and can be added as a standalone section, in e.g. an app’s settings screen."}],"type":"paragraph"},{"inlineContent":[{"text":"The view can be styled with the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardStatusSectionStyle(_:)","isActive":true,"type":"reference"},{"text":" view modifier.","type":"text"}],"type":"paragraph"}]}],"type":"row","numberOfColumns":2}],"title":"Section"}],"type":"tabNavigator"}]}],"hierarchy":{"pa