{"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"KeyboardKit has ways to check various keyboard statuses, e.g. if a keyboard is enabled in System Settings, if Full Access is enabled, if a keyboard is actively being used, etc. This can be used to help users set up their keyboard."}],"type":"paragraph"},{"inlineContent":[{"text":"👑 ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"text":" unlocks more keyboard status-related views & utilities. Information about Pro features can be found further down.","type":"text"}],"type":"paragraph"},{"anchor":"Namespace","text":"Namespace","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus"},{"type":"text","text":" namespace that contains status-related types and views, like the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Label"},{"type":"text","text":" that can be used to visualize a certain status value, as well as the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section"},{"type":"text","text":" which is unlocked by KeyboardKit Pro."}],"type":"paragraph"},{"anchor":"Context","text":"Context","level":2,"type":"heading"},{"inlineContent":[{"text":"The observable ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatusContext","isActive":true,"type":"reference"},{"text":" can be used to observe the state of any keyboard:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct MyView: View {","","    @StateObject","    var status = KeyboardStatusContext(bundleId: \"com.myapp.keyboard\")","","    var body: some View {","        VStack {","            Text(\"Enabled: \\(status.isKeyboardEnabled.description)\")","            Text(\"Active: \\(status.isKeyboardActive.description)\")","            Text(\"Full Access: \\(status.isFullAccessEnabled.description)\")","        }","    }","} "],"type":"codeListing"},{"inlineContent":[{"text":"The context is observable, so any status changes will immediately cause the view to refresh. It supports bundle ID wildcards, which lets you inspect multiple keyboards with a single instance:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["@StateObject","var status = KeyboardStatusContext(bundleId: \"com.myapp.*\")"],"type":"codeListing"},{"anchor":"Views","text":"Views","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus","isActive":true},{"type":"text","text":" namespace has status-specific views, that can be used to display various keyboard status-related values:"}],"type":"paragraph"},{"tabs":[{"content":[{"type":"row","numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"keyboardstatuslabel","type":"image"}]}]},{"size":1,"content":[{"inlineContent":[{"type":"text","text":"A keyboard status "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Label","isActive":true},{"type":"text","text":" can display various keyboard statuses, e.g. if a keyboard has been enabled, if Full Access is enabled, etc."}],"type":"paragraph"},{"inlineContent":[{"text":"The view supports custom texts, icons, etc. and can be styled with the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardStatusLabelStyle(_:)","type":"reference"},{"text":" view modifier.","type":"text"}],"type":"paragraph"}]}]}],"title":"Label"}],"type":"tabNavigator"},{"type":"thematicBreak"},{"level":2,"anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro","type":"heading"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"isActive":true,"overridingTitle":"KeyboardKit Pro"},{"type":"text","text":" unlocks additional keyboard status views and utilities, like a keyboard status section that can be added to the home or settings screen in an app that has a custom keyboard."}],"type":"paragraph"},{"tabs":[{"content":[{"numberOfColumns":2,"type":"row","columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"keyboardstatussection","type":"image"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A keyboard status "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStatus\/Section"},{"type":"text","text":" can display all relevant status labels for a keyboard extension, with a link to System Settings if needed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The view is used by the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true},{"type":"text","text":" component, and can be added as a standalone section, in e.g. an app’s settings screen."}]},{"type":"paragraph","inlineContent":[{"text":"The view can be styled with the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardStatusSectionStyle(_:)","isActive":true},{"text":" vi