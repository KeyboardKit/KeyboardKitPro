\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"type":"reference","overridingTitle":"KeyboardKit Pro","isActive":true},{"type":"text","text":" unlocks ways to read "},{"type":"strong","inlineContent":[{"type":"text","text":"all"}]},{"type":"text","text":" text from a text field, using the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy\/fullDocumentContext(config:)"},{"type":"text","text":" proxy extensions that will read the full document content instead of just returning the text closest to the input cursor."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"By reading the full text, you can pass in more information to your AI model or ChatGPT-powered functionality, and make your AI-based features a lot more capable."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Read more in the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article","isActive":true},{"type":"text","text":" article."}]},{"anchor":"Text-Input-Support","level":3,"type":"heading","text":"Text Input Support"},{"inlineContent":[{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"isActive":true},{"type":"text","text":" unlocks ways to let you type within a keyboard extension, by routing text input from the main app to text fields within the keyboard extension."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro has a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","isActive":true},{"type":"text","text":" that handles text routing automatically, by registering and unregistering itself as the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy","type":"reference"},{"text":" when it gets and loses focus. There is also a multi-line ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"This lets you provide AI-based features that require user input in your keyboard, such as generating custom images with DALL·E, asking questions to an AI like ChatGPT, etc.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Read more in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article"},{"type":"text","text":" article."}]}]}],"metadata":{"title":"AI Support","role":"article","roleHeading":"Article","modules":[{"name":"KeyboardKitPro"}],"images":[{"identifier":"Page.png","type":"card"}],"color":{"standardColorIdentifier":"blue"}},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Text-Input-Article":{"type":"topic","kind":"article","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","url":"\/documentation\/keyboardkitpro\/text-input-article","title":"Text Input","role":"article","images":[{"identifier":"Page.png","type":"card"}],"abstract":[{"type":"text","text":"This article describes the KeyboardKit text input engine, which lets you type within the keyboard extension."}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Localization-Article":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Localization-Articl