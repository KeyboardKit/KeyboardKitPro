{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"This configuration can be used to set up how to read"},{"text":" ","type":"text"},{"type":"text","text":"the full document context of a "},{"code":"UITextDocumentProxy","type":"codeVoice"},{"text":" .","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FullDocumentConfiguration","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"reference"},{"type":"text","text":" sets how long to wait with any"},{"text":" ","type":"text"},{"text":"subsequent operations when the text cursor has moved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It’s needed, since the proxy needs a pause before it"},{"type":"text","text":" "},{"text":"can access more text. A too short delay will cause a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"read operation to just return empty text, which will"},{"type":"text","text":" "},{"text":"cause the operation to abort, while using a too long","type":"text"},{"type":"text","text":" "},{"type":"text","text":"delay will cause the operation to take longer. Tweak"},{"text":" ","type":"text"},{"type":"text","text":"the this parameter to find an optimal value."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"0.04"},{"type":"text","text":" sleep interval is tested to work"},{"text":" ","type":"text"},{