{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FullDocumentConfiguration"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval"},{"text":" sets how long to wait with any","type":"text"},{"type":"text","text":" "},{"text":"subsequent operations when the text cursor has moved.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It’s needed, since the proxy needs a pause before it"},{"text":" ","type":"text"},{"type":"text","text":"can access more text. A too short delay will cause a"},{"text":" ","type":"text"},{"type":"text","text":"read operation to just return empty text, which will"},{"type":"text","text":" "},{"type":"text","text":"cause the operation to abort, while using a too long"},{"text":" ","type":"text"},{"text":"delay will cause the operation to take longer. Tweak","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the this parameter to find an optimal value."}]},{"type":"paragraph","inlineContent":[{"text":"The standard ","type":"text"},{"code":"0.04","type":"codeVoice"},{"type":"text","text":" sleep interval is tested to work"},{"text":" ","type":"text"},{"text":"on older devices, like iPhone 7, while newer devices","type":"text"},{"type":"text","text":" "},{"text":"can use a much shorter interval like ","type":"text"},{"code":"0.02","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","isActive":true,"type":"reference"},{"text":" determines how many times","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"text":"beginning or the end of the proxy. This is needed to","type":"text"},{"type":"text","text":" "},{"text":"handle texts that have many line breaks, since these","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"line breaks can otherwise cause the operation to end."}]},{"inlineContent":[{"text":"The standard ","type":"text"},{"type":"codeVoice","code":"10"},{"type":"text","text":" attempts will make a proxy attempt"},{"type":"text","text":" "},{"type":"text","text":"to move the cursor that many times, but it will fail"},{"type":"text","text":" "},{"type":"text","text":"if there are more paragraphs. Using more attempts is"},{"type":"text","text":" "},{"text":"however taking longer to complete.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration"]}],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration","interfaceLanguage":"swift"},"metadata":{"title":"Proxy.FullDocumentConfiguration","modules":[{"name":"KeyboardKitPro"}],"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FullDocumentConfiguration"}],"role":"symbol","symbolKind":"struct","navigatorTitle":[{"text":"FullDocumentConfiguration","kind":"identifier"}],"extendedModule":"KeyboardKitPro","externalID":"s:14KeyboardKitPro5ProxyV25FullDocumentConfigurationV"},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"]]},"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/c