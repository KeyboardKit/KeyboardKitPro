{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"]]},"variants":[{"paths":["\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration"},"abstract":[{"type":"text","text":"This configuration can be used to set up how to read"},{"type":"text","text":" "},{"type":"text","text":"the full document context of a "},{"type":"codeVoice","code":"UITextDocumentProxy"},{"type":"text","text":" ."}],"sections":[],"metadata":{"title":"Proxy.FullDocumentConfiguration","symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FullDocumentConfiguration"}],"externalID":"s:14KeyboardKitPro5ProxyV25FullDocumentConfigurationV","navigatorTitle":[{"kind":"identifier","text":"FullDocumentConfiguration"}],"extendedModule":"KeyboardKitPro","modules":[{"name":"KeyboardKitPro"}],"role":"symbol","roleHeading":"Structure"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/init(sleepInterval:endOfProxyAttempts:)"],"generated":true,"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval"],"generated":true,"anchor":"Instance-Properties"},{"title":"Type Properties","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/standard"],"generated":true,"anchor":"Type-Properties"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FullDocumentConfiguration"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"reference","isActive":true},{"type":"text","text":" sets how long to wait with any"},{"type":"text","text":" "},{"type":"text","text":"subsequent operations when the text cursor has moved."},{"type":"text","text":" "},{"type":"text","text":"It’s needed, since the proxy needs a pause before it"},{"type":"text","text":" "},{"type":"text","text":"can access more text. A too short delay will cause a"},{"type":"text","text":" "},{"type":"text","text":"read operation to just return empty text, which will"},{"type":"text","text":" "},{"type":"text","text":"cause the operation to abort, while using a too long"},{"type":"text","text":" "},{"type":"text","text":"delay will cause the operation to take longer. Tweak"},{"type":"text","text":" "},{"type":"text","text":"the this parameter to find an optimal value."}],"type":"paragraph"},{"inlineContent":[{"text":"The standard ","type":"text"},{"type":"codeVoice","code":"0.04"},{"text":" sleep interval is tested to work","type":"text"},{"text":" ","type":"text"},{"text":"on older devices, like iPhone 7, while newer devices","type":"text"},{"text":" ","type":"text"},{"text":"can use a much shorter interval like ","type":"text"},{"type":"codeVoice","code":"0.02"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","isActive":true},{"type":"text","text":" determines how many times"},{"type":"text","text":" "},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"type":"text","text":"beginning or the end of the proxy. This is needed to"},{"type":"text","text":" "},{"type":"text","text":"handle texts that have many line breaks, since these"},{"type":"text","text":" "},{"type":"text","text":"line breaks can otherwise cause the operation to end."}],"type":"paragraph"},{"inlineContent":[{"text":"The standard ","type":"text"},{"type":"codeVoice","code":"10"},{"text":" attempts will make a proxy attempt","type":"text"},{"text":" ","type":"text"},{"text":"to move the cursor that many times, but it will fail","type":"text"},{"text":" ","type":"text"},{"text":"if there are more paragraphs. Using more attempts is","type":"text"},{"text":" ","type":"text"},{"text":"however taking longer to complete.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy/FullDocumentConfiguration/standard":{"title":"standard","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"standard","kind":"identifier"},{"text":": `Self`","kind":"text"}],"abstract":[{"type":"text","text":"A standard full document reader configuration."}],"type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/standard","url":"\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration\/standard","role":"symbol","kind":"symbol"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy":{"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Proxy","kind":"identifier"}],"navigatorTitle":[{"text":"Proxy","kind":"identifier"}],"