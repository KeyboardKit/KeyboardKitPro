{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/init(sleepInterval:endOfProxyAttempts:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval"]},{"title":"Type Properties","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/standard"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FullDocumentConfiguration"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"reference"},{"type":"text","text":" determines how long to wait after"},{"type":"text","text":" "},{"text":"the cursor has been moved, before attempting to proceed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with the operation. This is needed, since a proxy needs"},{"type":"text","text":" "},{"type":"text","text":"time to get ready before it can start reading more text."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using a too short delay can result in a proxy not being","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ready, which causes the operation to abort, while using"},{"type":"text","text":" "},{"type":"text","text":"a longer delay will take longer to complete. This means"},{"text":" ","type":"text"},{"type":"text","text":"that we need to tweak the operation for optimal results."}]},{"inlineContent":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"0.04"},{"text":" sleep interval is tested to work on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"older devices, like iPhone 7 and iPad Air. Newer device"},{"type":"text","text":" "},{"type":"text","text":"types can use a much shorter sleep interval like "},{"type":"codeVoice","code":"0.02"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and still return correct results."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","isActive":true,"type":"reference"},{"type":"text","text":" determines how many times to"},{"text":" ","type":"text"},{"text":"attempt to move the text input cursor when reaching the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"beginning or the end of the proxy. This is needed since"},{"type":"text","text":" "},{"type":"text","text":"line breaks may cause the proxy return empty text, even"},{"type":"text","text":" "},{"type":"text","text":"though there is more text to get."}]},{"inlineContent":[{"text":"The standard ","type":"text"},{"type":"codeVoice","code":"10"},{"type":"text","text":" attempts will make a proxy attempt to"},{"type":"text","text":" "},{"type":"text","text":"move the text input cursor as many times, but will fail"},{"text":" ","type":"text"},{"text":"if there are more paragraphs. Using more attempts takes","type":"text"},{"type":"text","text":" "},{"text":"longer to complete.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"role":"symbol","roleHeading":"Structure","externalID":"s:14KeyboardKitPro5ProxyV25FullDocumentConfigurationV","modules":[{"name":"KeyboardKitPro"}],"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FullDocumentConfiguration"}],"navigatorTitle":[{"kind":"identifier","text":"FullDocumentConfiguration"}],"extendedModule":"KeyboardKitPro","title":"Proxy.FullDocumentConfiguration"},"kind":"symbol","abstract":[{"type":"text","text":"This configuration can be used to configure how to read"},{"text":" ","type":"text"},{"text":"full document context of a ","type":"text"},{"type":"codeVoice","code":"UITextDocumentProxy"},{"type":"text","text":" ."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration"]}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy/FullDocumentConfiguration/sleepInterval":{"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"sleepInterval","kind":"identifier"},{"kind":"text","text":": "},{"text":"TimeInterval","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval"}],"url":"\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration\/sleepinterval","abstract":[{"type":"text","text":"How long to sleep after moving the cursor."}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"topic","kind":"symbol","title":"sleepInterval"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy","kind":"symbol","title":"Proxy","type":"topic","n