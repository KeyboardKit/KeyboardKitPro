pe Properties","anchor":"Type-Properties","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FullDocumentConfiguration","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"reference","isActive":true},{"text":" sets how long to wait with any","type":"text"},{"text":" ","type":"text"},{"text":"subsequent operations when the text cursor has moved.","type":"text"},{"text":" ","type":"text"},{"text":"It’s needed, since the proxy needs a pause before it","type":"text"},{"text":" ","type":"text"},{"text":"can access more text. A too short delay will cause a","type":"text"},{"text":" ","type":"text"},{"text":"read operation to just return empty text, which will","type":"text"},{"text":" ","type":"text"},{"text":"cause the operation to abort, while using a too long","type":"text"},{"text":" ","type":"text"},{"text":"delay will cause the operation to take longer. Tweak","type":"text"},{"text":" ","type":"text"},{"text":"the this parameter to find an optimal value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The standard "},{"code":"0.04","type":"codeVoice"},{"type":"text","text":" sleep interval is tested to work"},{"type":"text","text":" "},{"type":"text","text":"on older devices, like iPhone 7, while newer devices"},{"type":"text","text":" "},{"type":"text","text":"can use a much shorter interval like "},{"code":"0.02","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts"},{"type":"text","text":" determines how many times"},{"type":"text","text":" "},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"type":"text","text":"beginning or the end of the proxy. This is needed to"},{"type":"text","text":" "},{"type":"text","text":"handle texts that have many line breaks, since these"},{"type":"text","text":" "},{"type":"text","text":"line breaks can otherwise cause the operation to end."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"10"},{"type":"text","text":" attempts will make a proxy attempt"},{"type":"text","text":" "},{"type":"text","text":"to move the cursor that many times, but it will fail"},{"type":"text","text":" "},{"type":"text","text":"if there are more paragraphs. Using more attempts is"},{"type":"text","text":" "},{"type":"text","text":"however taking longer to complete."}],"type":"paragraph"}]}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy":{"abstract":[{"text":"This namespace contains proxy-related types.","type":"text"}],"url":"\/documentation\/keyboardkitpro\/proxy","title":"Proxy","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Proxy","kind":"identifier"}],"navigatorTitle":[{"text":"Proxy","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy","kind":"symbol","role":"symbol"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy/FullDocumentConfiguration/sleepInterval":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","abstract":[{"text":"How long to sleep after moving the cursor.","type":"text"}],"role":"symbol","title":"sleepInterval","url":"\/documentation\/keyboardkitpro\/prox