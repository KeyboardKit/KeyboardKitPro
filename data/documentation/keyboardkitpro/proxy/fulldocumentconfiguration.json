/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","type":"reference","isActive":true},{"type":"text","text":" sets how long to wait with any"},{"text":" ","type":"text"},{"text":"subsequent operations when the text cursor has moved.","type":"text"},{"type":"text","text":" "},{"text":"It’s needed, since the proxy needs a pause before it","type":"text"},{"text":" ","type":"text"},{"text":"can access more text. A too short delay will cause a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"read operation to just return empty text, which will"},{"type":"text","text":" "},{"text":"cause the operation to abort, while using a too long","type":"text"},{"type":"text","text":" "},{"type":"text","text":"delay will cause the operation to take longer. Tweak"},{"type":"text","text":" "},{"type":"text","text":"the this parameter to find an optimal value."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The standard "},{"code":"0.04","type":"codeVoice"},{"type":"text","text":" sleep interval is tested to work"},{"text":" ","type":"text"},{"type":"text","text":"on older devices, like iPhone 7, while newer devices"},{"type":"text","text":" "},{"type":"text","text":"can use a much shorter interval like "},{"type":"codeVoice","code":"0.02"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","isActive":true,"type":"reference"},{"type":"text","text":" determines how many times"},{"text":" ","type":"text"},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"text":"beginning or the end of the proxy. This is needed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handle texts that have many line breaks, since these"},{"text":" ","type":"text"},{"type":"text","text":"line breaks can otherwise cause the operation to end."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"10"},{"type":"text","text":" attempts will make a proxy attempt"},{"type":"text","text":" "},{"text":"to move the cursor that many times, but it will fail","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if there are more paragraphs. Using more attempts is"},{"type":"text","text":" "},{"type":"text","text":"however taking longer to complete."}]}]}],"variants":[{"paths":["\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"]]},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy/FullDocumentConfiguration/endOfProxyAttempts":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","url":"\/documentation\/keyboardkitpro\/proxy\/fulldocumentconfiguration\/endofproxyattempts","type":"topic","title":"endOfProxyAttempts","kind":"symbol","abstract":[{"text":"The number of times to look for more content.","type":"text"}],"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"endOfProxyAttempts","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Proxy/FullDocumentConfiguration/init(sleepInterval:endOfProxyAttempts:)":{"title":"init(sleepInterval:endOfProxyAttempts:)","url":"\/documentation