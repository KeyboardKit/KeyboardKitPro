{"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/init(sleepInterval:endOfProxyAttempts:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval"]},{"title":"Type Properties","anchor":"Type-Properties","generated":true,"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/standard"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FullDocumentConfiguration","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/sleepInterval","isActive":true,"type":"reference"},{"text":" sets how long to wait with any","type":"text"},{"text":" ","type":"text"},{"text":"subsequent operations when the text cursor has moved.","type":"text"},{"text":" ","type":"text"},{"text":"It’s needed, since the proxy needs a pause before it","type":"text"},{"text":" ","type":"text"},{"text":"can access more text. A too short delay will cause a","type":"text"},{"text":" ","type":"text"},{"text":"read operation to just return empty text, which will","type":"text"},{"text":" ","type":"text"},{"text":"cause the operation to abort, while using a too long","type":"text"},{"text":" ","type":"text"},{"text":"delay will cause the operation to take longer. Tweak","type":"text"},{"text":" ","type":"text"},{"text":"the this parameter to find an optimal value.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The standard ","type":"text"},{"code":"0.04","type":"codeVoice"},{"text":" sleep interval is tested to work","type":"text"},{"text":" ","type":"text"},{"text":"on older devices, like iPhone 7, while newer devices","type":"text"},{"text":" ","type":"text"},{"text":"can use a much shorter interval like ","type":"text"},{"code":"0.02","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy\/FullDocumentConfiguration\/endOfProxyAttempts","isActive":true},{"type":"text","text":" determines how many times"},{"type":"text","text":" "},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"type":"text","text":"beginning or the end of the proxy. This is needed to"},{"type":"text","text":" "},{"type":"text","text":"handle texts that have many line breaks, since these"},{"type":"text","text":" "},{"type":"text","text":"line breaks can otherwise cause the operation to end."}]},{"type":"paragraph","inlineContent":[{"text":"The standard ","type":"text"},{"code":"10","type":"codeVoice"},{"text":" attempts will make a proxy attempt","type":"text"},{"text":" ","type":"text"},{"text":"to move the cursor that many times, but it will fail","type":"text"},{"text":" ","type":"text"},{"text":"if there are more paragraphs. Using more attempts is","type":"text"},{"text":" ","type":"text"},{"text":"however taking longer to complete.","type":"text"}]}]}],"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FullDocumentConfiguration"}],"navigatorTitle":[{"kind":"identifier","text":"FullDocumentConf