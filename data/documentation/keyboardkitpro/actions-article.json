yboardKitPro\/KeyboardAction"},{"text":" enum that defines a bunch of keyboard-related actions. It’s also a namespace for action-related types and views, like a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler"},{"text":" that provides you with a standard way to handle actions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Here are just some of the many actions that the enum defines. See the full ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"text":" documentation for a full list of actions:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/backspace","isActive":true},{"type":"text","text":" - triggers a backspace deletion."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/character(_:)","type":"reference","isActive":true},{"text":" - inserts a character.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/dismissKeyboard"},{"type":"text","text":" - dismisses the keyboard."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/diacritic(_:)"},{"type":"text","text":" - inserts a diacritic."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/emoji(_:)-swift.enum.case","isActive":true,"type":"reference"},{"text":" - inserts an emoji.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/keyboardType(_:)","isActive":true,"type":"reference"},{"text":" - changes the keyboard type.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextKeyboard"},{"type":"text","text":" - triggers the system keyboard switcher."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextLocale","type":"reference","isActive":true},{"type":"text","text":" - triggers the locale switcher."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Many actions have a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardAction","isActive":true,"type":"reference"},{"text":", and a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","isActive":true,"type":"reference"},{"text":" while others require manual handling by creating a custom ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"text":"Action Handlers","anchor":"Action-Handlers","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"text":" can handle actions, apply ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion","type":"reference","isActive":true},{"text":" values, trigger audio & haptic feedback, etc. It’s in the center of how actions are handled, and can be customized to fit your needs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, to customize what happens when a user double-taps space, you can override "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","isActive":true},{"type":"text","text":" and check if the action is "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/space","isActive":true},{"type":"text","text":" and the gesture is "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture\/doubleTap","isActive":true},{"type":"text","text":". If so, do your custom thing, else call super."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler"},{"type":"text","text":" and injects it into "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":". You can replace it at any time, as described further down."}]},{"text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" injects more capabilities into the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler"},{"text":", to make it handle locale-specific input methods like Vietnamese TELEX, VIQR, and VNI, and handle other locale and pro-specific replacements.","type":"text"}]},{"type":"thematicBreak"},{"text":"How to…","anchor":"How-to","type":"heading","level":2},{"text":"…trigger keyboard actions","anchor":"trigger-keyboard-actions","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit automatically triggers ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","type":"reference","isActive":true},{"text":"s when users interact with the keyboard or when certain events happen. Actions are by default handled with the main ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler","type":"reference","isActive":true},{"text":", which you can replace to customize how actions are handled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can trigger actions programmatically with ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(action:)","isActive":true,"type":"reference"},{"text":", or trigger ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","isActive":true,"type":"reference"},{"text":" to simulate a certain action gesture:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func doStuff(with handler: KeyboardActionHandler) {","    handler.handle(.backspace)","    handler.handle(.press, on: .character(\"a\"))","    handler.handle(.release, on: .dismissKeyboard)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard actions can also be triggered by a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","isActive":true},{"type":"text","text":"."},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","isActive":true},{"type":"text","text":" or by applying a "},{"type":"codeVoice","code":".keyboardButton(...)"},{"type":"text","text":" modifier to any view:"}]},{"syntax":"swift","type":"codeListing","code":["Text(\"Button\")","    .keyboardButton(...)"]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true},{"type":"text","text":" applies this modifier to all its buttons, to automatically make them support press, release, long press, repeat, etc."}]},{"text":"…handle keyboard actions","anchor":"handle-keyboard-actions","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Actions are by default handled with the main "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler"},{"type":"text","text":", which you can replace to customize how actions are handled. This is required for some actions that don’t have a standard or default behavior."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can either implement the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"type":"text","text":" protocol from scratch, or inherit the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true,"type":"reference"},{"type":"text","text":" class and override any of the many functions that it provides to add your own customizations to the standard behavior."}]},{"text":"…handle autocomplete suggestions","anchor":"handle-autocomplete-suggestions","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":" can also handle "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete"},{"type":"text","text":"."},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion"},{"type":"text","text":" values, which are for instance what happens when a user taps a suggestion in an  "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete"},{"type":"text","text":"."},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Toolbar"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["func handle(_ suggestion: Autocomplete.Suggestion, with handler: KeyboardActionHandler) {","    handler.handle(.suggestion(suggestion))","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will by default insert the suggestion into the text document proxy. You can customize this behavior with a custom action handler."}]},{"text":"…create a custom action handler","anchor":"create-a-custom-action-handler","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"You can create a custom ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"text":" to customize how certain actions are handled, and to handle actions that don’t have a standard or default behavior, like ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/image","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/command","isActive":true},{"text":", etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can implement the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"type":"text","text":" protocol from scratch, or inherit and customize "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["class CustomActionHandler: KeyboardAction.StandardActionHandler {","","    open override func handle(","        _ gesture: Keyboard.Gesture, ","        on action: KeyboardAction","    ) {","        if gesture == .press && action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"To use your custom handler instead of the standard one, just inject it into ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":" by replacing its ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler"},{"text":" p