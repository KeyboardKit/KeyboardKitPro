ve":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/emoji(_:)-swift.enum.case","type":"reference"},{"text":" - inserts an emoji.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/keyboardType(_:)","isActive":true},{"type":"text","text":" - changes the keyboard type."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextKeyboard","isActive":true,"type":"reference"},{"type":"text","text":" - triggers the system keyboard switcher."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextLocale","isActive":true,"type":"reference"},{"type":"text","text":" - triggers the locale switcher."}]}]}]},{"inlineContent":[{"type":"text","text":"Many actions have a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardAction","isActive":true},{"type":"text","text":", and a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","isActive":true},{"type":"text","text":" while others require manual handling by creating a custom "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Action Handlers","anchor":"Action-Handlers"},{"inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":" can handle actions, apply ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion"},{"text":" values, trigger audio & haptic feedback, etc. It’s in the center of how actions are handled, and can be customized to fit your needs.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For instance, to customize what happens when a user double-taps space, you can override "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","isActive":true,"type":"reference"},{"type":"text","text":" and check if the action is "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/space","isActive":true,"type":"reference"},{"type":"text","text":" and the gesture is "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture\/doubleTap","isActive":true,"type":"reference"},{"type":"text","text":". If so, do your custom thing, else call super."}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit automatically creates an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true},{"text":" and injects it into ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"text":". You can replace it at any time, as described further down.","type":"text"}],"type":"paragraph"},{"type":"heading","level":2,"text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro"},{"i