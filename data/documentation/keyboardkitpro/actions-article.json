eListing","syntax":"swift","code":["func doStuff(with handler: KeyboardActionHandler) {","    handler.handle(.backspace)","    handler.handle(.press, on: .character(\"a\"))","    handler.handle(.release, on: .dismissKeyboard)","}"]},{"inlineContent":[{"type":"text","text":"Keyboard actions can also be triggered by a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard"},{"type":"text","text":"."},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button"},{"type":"text","text":" or by applying a "},{"code":".keyboardButton(...)","type":"codeVoice"},{"type":"text","text":" modifier to any view:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Text(\"Button\")","    .keyboardButton(...)"]},{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"type":"text","text":" applies this modifier to all its buttons, to automatically make them support press, release, long press, repeat, etc."}],"type":"paragraph"},{"type":"heading","level":3,"text":"…handle keyboard actions","anchor":"handle-keyboard-actions"},{"inlineContent":[{"text":"Actions are by default handled with the main ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler","type":"reference"},{"text":", which you can replace to customize how actions are handled. This is required for some actions that don’t have a standard or default behavior.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can either implement the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":" protocol from scratch, or 