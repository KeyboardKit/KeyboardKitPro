true},{"type":"text","text":" can handle actions, apply "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion","isActive":true},{"type":"text","text":" values, trigger audio & haptic feedback, etc. It’s in the center of how actions are handled, and can be customized to fit your needs."}]},{"type":"paragraph","inlineContent":[{"text":"For instance, to customize what happens when a user double-taps space, you can override ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","isActive":true,"type":"reference"},{"text":" and check if the action is ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/space","isActive":true,"type":"reference"},{"text":" and the gesture is ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture\/doubleTap","isActive":true,"type":"reference"},{"text":". If so, do your custom thing, else call super.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit automatically creates an instance of ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true,"type":"reference"},{"text":" and injects it into ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":". You can replace it at any time, as described further down.","type":"text"}]},{"level":2,"type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro"},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"isActive":true,"type":"reference","overridingTitle":"KeyboardKit Pro"},{"text":" injects more capabilities into the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true,"type":"reference"},{"text":", to make it handle locale-specific input methods like Vietnamese TELEX, VIQR, and VNI, and handle other locale and pro-specific replacements.","type":"text"}]},{"type":"thematicBreak"},{"level":2,"type":"heading","anchor":"How-to","text":"How to…"},{"level":3,"type":"heading","anchor":"trigger-keyboard-actions","text":"…trigger keyboard actions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically triggers "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true},{"type":"text","text":"s when users interact with the keyboard or when certain events happen. Actions are by default handled with the main "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler","isActive":true},{"type":"text","text":", which you can replace to customize how actions are handled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can trigger actions programmatically with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(action:)"},{"type":"text","text":", or trigger "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)"},{"type":"text","text":" to simulate a certain action gesture:"}]},{"syntax":"swift","type":"codeListing","code":["func doStuff(with handler: KeyboardActionHandler) {","    handler.handle(.backspace)","    handler.handle(.press, on: .character(\"a\"))","    h