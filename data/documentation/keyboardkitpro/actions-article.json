ctionHandler"},{"text":" class and override any of the many functions that it provides to add your own customizations to the standard behavior.","type":"text"}]},{"anchor":"handle-autocomplete-suggestions","text":"…handle autocomplete suggestions","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"type":"text","text":" can also handle "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete","type":"reference","isActive":true},{"type":"text","text":"."},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion","type":"reference","isActive":true},{"type":"text","text":" values, which are for instance what happens when a user taps a suggestion in an  "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete","type":"reference","isActive":true},{"type":"text","text":"."},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Toolbar","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["func handle(_ suggestion: Autocomplete.Suggestion, with handler: KeyboardActionHandler) {","    handler.handle(.suggestion(suggestion))","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will by default insert the suggestion into the text document proxy. You can customize this behavior with a custom action handler."}]},{"anchor":"create-a-custom-action-handler","text":"…create a custom action handler","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"You can create a custom ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler