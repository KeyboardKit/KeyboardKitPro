{"sections":[],"abstract":[{"type":"text","text":"This article describes the KeyboardKit action engine."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AI-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Device-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emojis-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/External-Keyboards-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Gestures-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Input-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Layout-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Localization-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Navigation-Article"],"generated":true,"title":"Articles","anchor":"Articles"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/actions-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/actions-article"]}],"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction"},{"type":"text","text":" type is a central concept in KeyboardKit, where an action can be triggered by the keyboard or by code, then handled with a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"text":" can either handle a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","type":"reference","isActive":true},{"text":" in a standard way, or handle it based on a certain ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture","type":"reference","isActive":true},{"text":" for more granular control when triggering actions programatically.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"👑 ","type":"text"},{"isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"text":" injects more capabilities into the action handler, to make it handle locale-specific input methods like Vietnamese.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Namespace","type":"heading","anchor":"Namespace"},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true},{"type":"text","text":" enum that defines a bunch of keyboard-related actions. It’s also a namespace for action-related types and views, like a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true},{"type":"text","text":" that provides you with a standard way to handle actions."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here are just some of the many actions that the enum defines. See the full "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","type":"reference","isActive":true},{"type":"text","text":" documentation for a full list of actions:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/backspace","type":"reference"},{"type":"text","text":" - triggers a backspace deletion."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/character(_:)","isActive":true},{"type":"text","text":" - inserts a character."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/dismissKeyboard","type":"reference","isActive":true},{"text":" - dismisses the keyboard.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/diacritic(_:)","isActive":true},{"text":" - inserts a diacritic.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/emoji(_:)-swift.enum.case","type":"reference","isActive":true},{"type":"text","text":" - inserts an emoji."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/keyboardType(_:)","isActive":true,"type":"reference"},{"text":" - changes the keyboard type.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextKeyboard"},{"text":" - triggers the system keyboard switcher.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/nextLocale","isActive":true},{"type":"text","text":" - triggers the locale switcher."}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Many actions have a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardAction","isActive":true,"type":"reference"},{"type":"text","text":", and a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","isActive":true,"type":"reference"},{"type":"text","text":" while others require manual handling by creating a custom "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Action Handlers","type":"heading","anchor":"Action-Handlers"},{"inlineContent":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":" can handle actions, apply "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion"},{"type":"text","text":" values, trigger audio & haptic feedback, etc. It’s in the center of how actions are handled, and can be customized to fit your needs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For instance, to customize what happens when a user double-taps space, you can override "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","type":"reference","isActive":true},{"type":"text","text":" and check if the action is "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/space","type":"reference","isActive":true},{"type":"text","text":" and the gesture is "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Gesture\/doubleTap","type":"reference","isActive":true},{"type":"text","text":". If so, do your custom thing, else call super."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true},{"type":"text","text":" and injects it into "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"type":"text","text":". You can replace it at any time, as described further down."}],"type":"paragraph"},{"level":2,"text":"👑 KeyboardKit Pro","type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro"},{"inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","overridingTitle":"KeyboardKit Pro"},{"type":"text","text":" injects more capabilities into the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","type":"reference"},{"text":", to make it handle locale-specific input methods like Vietnamese TELEX, VIQR, and VNI, and handle other locale and pro-specific replacements.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"level":2,"text":"How to…","type":"heading","anchor":"How-to"},{"level":3,"text":"…trigger keyboard actions","type":"heading","anchor":"trigger-keyboard-actions"},{"inlineContent":[{"text":"KeyboardKit automatically triggers ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"text":"s when users interact with the keyboard or when certain events happen. Actions are by default handled with the main ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler","isActive":true,"type":"reference"},{"text":", which you can replace to customize how actions are handled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can trigger actions programmatically with "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(action:)","isActive":true},{"type":"text","text":", or trigger "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler\/handle(_:on:)","isActive":true},{"type":"text","text":" to simulate a certain action gesture:"}],"type":"paragraph"},{"syntax":"swift","code":["func doStuff(with handler: KeyboardActionHandler) {","    handler.handle(.backspace)","    handler.handle(.press, on: .character(\"a\"))","    handler.handle(.release, on: .dismissKeyboard)","}"],"type":"codeListing"},{"inlineContent":[{"text":"Keyboard actions can also be triggered by a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","type":"reference","isActive":true},{"text":".","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","type":"reference","isActive":true},{"text":" or by applying a ","type":"text"},{"type":"codeVoice","code":".keyboardButton(...)"},{"text":" modifier to any view:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Text(\"Button\")","    .keyboardButton(...)"],"type":"codeListing"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"text":" applies this modifier to all its buttons, to automatically make them support press, release, long press, repeat, etc.","type":"text"}],"type":"paragraph"},{"level":3,"text":"…handle keyboard actions","type":"heading","anchor":"handle-keyboard-actions"},{"inlineContent":[{"type":"text","text":"Actions are by default handled with the main "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler"},{"type":"text","text":", which you can replace to customize how actions are handled. This is required for some actions that don’t have a standard or default behavior."}],"type":"paragraph"},{"inlineContent":[{"text":"You can either implement the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":" protocol from scratch, or inherit the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler"},{"text":" class and override any of the many functions that it provides to add your own customizations to the standard behavior.","type":"text"}],"type":"paragraph"},{"level":3,"text":"…handle autocomplete suggestions","type":"heading","anchor":"handle-autocomplete-suggestions"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","type":"reference","isActive":true},{"type":"text","text":" can also handle "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete","type":"reference"},{"type":"text","text":"."},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Suggestion","type":"reference"},{"type":"text","text":" values, which are for instance what happens when a user taps a suggestion in an  "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete","type":"reference"},{"type":"text","text":"."},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete\/Toolbar","type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["func handle(_ suggestion: Autocomplete.Suggestion, with handler: KeyboardActionHandler) {","    handler.handle(.suggestion(suggestion))","}"],"type":"codeListing"},{"inlineContent":[{"text":"This will by default insert the suggestion into the text document proxy. You can customize this behavior with a custom action handler.","type":"text"}],"type":"paragraph"},{"anchor":"create-a-custom-action-handler","text":"…create a custom action handler","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"You can create a custom "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"type":"text","text":" to customize how certain actions are handled, and to handle actions that don’t have a standard or default behavior, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/image"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/command"},{"type":"text","text":", etc."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can implement the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","isActive":true},{"type":"text","text":" protocol from scratch, or inherit and customize "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/StandardActionHandler","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["class CustomActionHandler: KeyboardAction.StandardActionHandler {","","    open override func handle(","        _ gesture: Keyboard.Gesture, ","        on action: KeyboardAction","    ) {","        if gesture == .press && action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"To use your custom handler instead of the standard one, just inject it into ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":" by replacing its ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/actionHandler","isActive":true,"type":"reference"},{"text":" property:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        services.actionHandler = CustomActionHandler(controller: self)","        setup(for: .myApp)  \/\/ See the getting-started guide","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This will make KeyboardKit use your custom action handler instead of the standard one."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Article","role":"article","title":"Actions","modules":[{"name":"KeyboardKitPro"}],"images":[{"identifier":"Page.png","type":"card"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"kind":"article","identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","interfaceLanguage":"swift"},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Input-Article":{"title":"Input","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Input-Article","url":"\/documentation\/keyboardkitpro\/input-article","kind":"article","images":[{"identifier":"Page.png","type":"card"}],"type":"topic","abstract":[{"type":"text","text":"This article describes the KeyboardKit input engine."}],"role":"article"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Keyboard/Button":{"abstract":[{"text":"This view can be used to create keyboard buttons for","type":"text"},{"text":" ","type":"text"},{"text":"various keyboard actions.","type":"text"}],"role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Button"}],"title":"Keyboard.Button","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","navigatorTitle":[{"kind":"identifier","text":"Button"}],"kind":"symbol","url":"\/documentation\/keyboardkitpro\/keyboard\/button"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardAction/backspace":{"abstract":[{"text":"Deletes backwards when pressed, and repeats until released.","type":"text"}],"identifier":"doc:\/