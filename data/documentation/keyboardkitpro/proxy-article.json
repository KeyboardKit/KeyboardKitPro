rfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"images":[{"identifier":"Page.png","type":"card"}],"role":"article","roleHeading":"Article","modules":[{"name":"KeyboardKitPro"}],"title":"Proxy Utilities"},"sections":[],"abstract":[{"text":"This article describes the KeyboardKit proxy engine and its utilities.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"iOS keyboards use a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true,"type":"reference"},{"text":" to integrate with the currently selected text field. The proxy lets you insert and delete text, get the currently selected text, move the input cursor, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The native APIs are however quite limited, and make it hard to get detailed text information and to perform many standard operations. For instance, you have to write code to get the current word or sentence, understand where the cursor is, etc.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit therefore extends ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","type":"reference"},{"type":"text","text":" to make things easier. "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference","isActive":true},{"text":" also has a custom ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy"},{"text":" that lets you do even more.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"👑 [KeyboardKit Pro][Pro] also unlocks ways for a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true,"type":"reference"},{"text":" to read the full content of the current document. Information about Pro features can be found further down.","type":"text"}]},{"type":"heading","level":2,"anchor":"Namespace","text":"Namespace"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"},{"type":"text","text":" namespace with proxy-related types. It currently only contains utils when it’s part of a KeyboardKit Pro build."}]},{"level":2,"anchor":"Extensions","type":"heading","text":"Extensions"},{"inlineContent":[{"text":"KeyboardKit extends the native ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true},{"type":"text","text":" with additional capabilities, such as the ability to get more content from the document, analyze words, sentences & quotations, end the current sentence, etc."}],"type":"paragraph"},{"inlineContent":[{"text":"Here are some examples of extensions that are added to the proxy by KeyboardKit, to make it much more capable than it is by default, with more variants of certain operations listed in the full ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy"},{"text":" documentation:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy\/currentWord","i