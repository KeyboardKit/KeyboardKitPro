 provide AI-based features that require more context."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro therefore unlocks ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy\/fullDocumentContext(config:)"},{"text":" proxy extensions that let you read ","type":"text"},{"inlineContent":[{"text":"all","type":"text"}],"type":"strong"},{"text":" text from the proxy:","type":"text"}]},{"code":["let proxy = keyboardContext.textDocumentProxy","let result = try await proxy.fullDocumentContext()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This will provide you with all the text before and after the input cursor, as well as an aggregate of all the available text in the document.","type":"text"}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"The full document read operation is a best effort operation, that makes the most of the very limited capabilities that are provided by the operating system. It’s not guaranteed to return a valid result. You can configure the operation to yield better results, for instance by waiting longer when moving the input cursor, try to move more times around the edges, etc.","type":"text"}]}],"style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/proxy-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/proxy-article"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article"},"abstract":[{"type":"text","text":"This article describes the KeyboardKit proxy engine and its utilities."}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro":{"title":"KeyboardKitPro","kind":"symbol","type":"topic","identifier":"doc:\/\/com.keyboardkit.Keyb