ract":[{"text":"This article describes the KeyboardKit proxy engine and its utilities.","type":"text"}],"metadata":{"images":[{"type":"card","identifier":"Page.png"}],"roleHeading":"Article","modules":[{"name":"KeyboardKitPro"}],"role":"article","title":"Proxy Utilities"},"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"iOS keyboards use a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true,"type":"reference"},{"text":" to integrate with the currently selected text field. The proxy lets you insert and delete text, get the currently selected text, move the input cursor, etc.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The native APIs are however quite limited, and make it hard to get detailed text information and to perform many standard operations. For instance, you have to write code to get the current word or sentence, understand where the cursor is, etc."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit therefore extends "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true},{"type":"text","text":" to make things easier. "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","type":"reference"},{"text":" also has a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy"},{"type":"text","text":" that lets you do even more."}]},{"inlineContent":[{"type":"text","text":"👑 [KeyboardKit Pro][Pro] also unlocks ways for a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy"},{"type":"text","text":" to read the full content of the current document. Information about Pro features can be found further down."}],"type":"paragraph"},{"anchor":"Namespace","level":2,"text":"Namespace","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy"},{"type":"text","text":" namespace with proxy-related types. It currently only contains utils when it’s part of a KeyboardKit Pro build."}]},{"text":"Extensions","type":"heading","level":2,"anchor":"Extensions"},{"inlineContent":[{"text":"KeyboardKit extends the native ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy"},{"type":"text","text":" with additional capabilities, such as the ability to get more content from the document, analyze words, sentences & quotations, end the current sentence, etc."}],"type":"paragraph"},{"inlineContent":[{"text":"Here are some examples of extensions that are added to the proxy by KeyboardKit, to make it much more capable than it is by default, with more variants of certain operations listed in the full ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","type":"reference"},{"type":"text","text":" documentation:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy\/currentWord","isActive":true,"type":"reference"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy\/deleteBackward(range:)","type":"reference"