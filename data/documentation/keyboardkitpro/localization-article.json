tPro\/documentation\/KeyboardKitPro\/KeyboardLocale"},{"type":"text","text":"s, like "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/english","type":"reference","isActive":true},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/swedish","type":"reference"},{"type":"text","text":", and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/persian","isActive":true,"type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"🇦🇱 🇦🇪 🇦🇲 🇧🇾 🇧🇬 🇦🇩 🏳️ 🇭🇷 🇨🇿 🇩🇰 🇳🇱 🇧🇪 🇺🇸 🇬🇧 🇺🇸 🇪🇪 🇫🇴 🇵🇭 🇫🇮 🇫🇷 🇨🇦 🇧🇪 🇨🇭 🇬🇪 🇩🇪 🇦🇹 🇨🇭 🇬🇷 🇺🇸 🇮🇱 🇭🇺 🇮🇸 🏳️ 🇮🇩 🇮🇪 🇮🇹 🇰🇿 🇹🇯 🇹🇯 🇹🇯 🇱🇻 🇱🇹 🇲🇰 🇲🇾 🇲🇹 🇲🇳 🏳️ 🇳🇴 🇳🇴 🇮🇷 🇵🇱 🇵🇹 🇧🇷 🇷🇴 🇷🇺 🇷🇸 🇷🇸 🇸🇰 🇸🇮 🇪🇸 🇦🇷 🇲🇽 🇰🇪 🇸🇪 🇹🇷 🇺🇦 🇺🇿 🏴󠁧󠁢󠁷󠁬󠁳󠁿 "}],"type":"paragraph"},{"level":2,"text":"Locale capabilities","anchor":"Locale-capabilities","type":"heading"},{"inlineContent":[{"text":"A keyboard locale refers to a native ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/locale"},{"text":" and has localized assets and strings that can be translated with ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KKL10n","isActive":true,"type":"reference"},{"text":". KeyboardKit also extends the native ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/Locale","isActive":true},{"type":"text","text":" type with a bunch of additional capabilities."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale","type":"reference"},{"type":"text","text":" has provides collection modifiers, behaviors, flags, search & sorting capabilities, and much more. For instance, you can get the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/flag","type":"reference","isActive":true},{"text":" of a locale, translate the name of a locale with other locales, etc.","type":"text"}]},{"inlineContent":[{"text":"Many extensions are applied to ","type":"text"},{"type":"codeVoice","code":"Locale"},{"text":" instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale"},{"type":"text","text":", whenever the base locale has enough information. "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale","isActive":true},{"text":" will for the most cases not mirror these extensions, so use the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/locale","type":"reference","isActive":true},{"type":"text","text":" property to access them."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"How-to-get-and-set-the-current-keyboard-locale","text":"How to get and set the current keyboard locale"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true},{"text":" can be used to get and set the current ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/locale"},{"type":"text","text":" and available "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/locales","isActive":true},{"type":"text","text":". These properties are raw "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Foundation\/Locale","type":"reference","isActive":true},{"text":" values, since a keyboard isn’t limited to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale"},{"type":"text","text":".  The context also has "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale","isActive":true,"type":"reference"},{"type":"text","text":"-specific variants."}],"type":"paragraph"},{"inlineContent":[{"text":"If the context ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/locales","type":"reference"},{"type":"text","text":" has multiple values, you can switch locale with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/selectNextLocale()"},{"text":" or a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardLocale\/ContextMenu"},{"type":"text","text":" that lets the user select a locale. You can apply a locale context menu with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUI\/View\/keyboardLocaleContextMenu(for:tapAction:)"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"How-to-change-the-primary-language","level":2,"text":"How to change the primary language","type":"heading"},{"inlineContent":[{"text":"Setting the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/locale"},{"text":" will update the controller’s ","type":"text"},{"type":"strong","inlineContent":[{"text":"primaryLanguage","type":"text"}]},{"text":", which controls things like spell checking and text direction. This also sets the keyboard locale name in the keyboard switcher.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"primaryLanguage"},{"text":" property always returns ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", even after being set in a way that actually works, which can be confusing.","type":"text"}]}],"type":"aside","name":"Note","style":"note"},{"anchor":"How-to-use-LTR-and-RTL-locales","level":2,"type":"heading","text":"How to use LTR and RTL locales"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit supports LTR (Left-To-Right) and RTL (Right-To-Left) locales."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You don’t need to configure your keyboard to support RTL. Just change the keyboard locale as explained above, and KeyboardKit will automatically adjust the text direction."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to use a single RTL locale, you can adjust the keyboard extension "},{"inlineContent":[{"type":"text","text":"Info.plist"}],"type":"strong"},{"text":":","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Set ","type":"text"},{"inlineContent":[{"type":"text","text":"PrefersRightToLeft"}],"type":"strong"},{"text":" to ","type":"text"},{"inlineContent":[{"type":"text","text":"1"}],"type":"strong"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Set "},{"inlineContent":[{"type":"text","text":"PrimaryLanguage"}],"type":"strong"},{"type":"text","text":" to the language code of your locale, e.g. "},{"type":"strong","inlineContent":[{"type":"text","text":"fa"}]},{"type":"text","text":" for Perian (Farsi)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Just be aware that setting the primary language may affect external keyboard key mappings.","type":"tex