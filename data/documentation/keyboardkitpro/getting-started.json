{"kind":"article","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"This article describes how to get started with KeyboardKit.","type":"text"}],"primaryContentSections":[{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This article describes how to get started with both KeyboardKit & KeyboardKit Pro. Each section will first show you how to do something for KeyboardKit, then for KeyboardKit Pro."}],"type":"paragraph"},{"anchor":"How-to-use-KeyboardKit","text":"How to use KeyboardKit","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard extensions can use KeyboardKit to create custom keyboards, while the main app can use it to check keyboard state, provide keyboard-specific settings, link to System Settings, etc."}]},{"text":"How to set up KeyboardKit for a keyboard extension","level":2,"type":"heading","anchor":"How-to-set-up-KeyboardKit-for-a-keyboard-extension"},{"inlineContent":[{"type":"text","text":"To set up KeyboardKit for a keyboard extension, import KeyboardKit and let "},{"code":"KeyboardViewController","type":"codeVoice"},{"type":"text","text":" inherit "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true,"type":"reference"},{"type":"text","text":" instead of "},{"type":"codeVoice","code":"UIInputViewController"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["import KeyboardKit \/\/ or KeyboardKitPro","","class KeyboardController: KeyboardInputViewController {}"]},{"inlineContent":[{"type":"text","text":"This gives you access to lifecycle functions like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboard()","isActive":true},{"text":", observable ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"text":", keyboard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","type":"reference","isActive":true},{"text":", and more.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you want to use the default ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard","isActive":true,"type":"reference"},{"text":", which mimics a native iOS keyboard, you don’t have to do anything else. To replace or customize the default view, just override ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboard()","isActive":true,"type":"reference"},{"type":"text","text":" and call any setup function:"}]},{"type":"codeListing","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboard() {","        super.viewWillSetupKeyboard()","        setup { [weak self] controller in \/\/ <-- Use [weak self] or [unowned self] if you need self here.","            SystemKeyboard(","                state: controller.state,","                services: controller.services,","                buttonContent: { $0.view },","                buttonView: { $0.view },","                emojiKeyboard: { $0.view },","                toolbar: { _ in MyCustomToolbar() }","            )","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can use the view builder ","type":"text"},{"type":"codeVoice","code":"controller"},{"type":"text","text":" parameter to access "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","type":"reference","isActive":true},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":" and any other properties and functions you need."}]},{"style":"warning","type":"aside","name":"Warning","content":[{"inlineContent":[{"type":"text","text":"A very important thing that you MUST consider when you use "},{"code":"setup","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"setupPro","type":"codeVoice"},{"text":" with a ","type":"text"},{"type":"codeVoice","code":"view"},{"text":" builder, is that the ","type":"text"},{"code":"view","type":"codeVoice"},{"text":" builder provides you with an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" controller reference, since referring to ","type":"text"},{"code":"self","type":"codeVoice"},{"type":"text","text":" from the view builder can cause memory leaks. However, since this reference is a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"type":"text","text":", you must still use "},{"code":"self","type":"codeVoice"},{"text":" when you have to refer to your specific controller class. If you do, it is VERY important to add ","type":"text"},{"type":"codeVoice","code":"[weak self]"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":" to the builder. If you don’t, the "},{"type":"codeVoice","code":"self"},{"type":"text","text":" reference will cause a memory leak."}],"type":"paragraph"}]},{"anchor":"👑-KeyboardKit-Pro","type":"heading","text":"👑 KeyboardKit Pro","level":3},{"type":"paragraph","inlineContent":[{"text":"Unlike KeyboardKit, KeyboardKit Pro has a setup function that lets you register a license key, after which KeyboardKit Pro automatically sets up your license and unlocks all included features.","type":"text"}]},{"inlineContent":[{"text":"To use KeyboardKit Pro with the default ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard"},{"text":" view, just call ","type":"text"},{"type":"strong","inlineContent":[{"text":"setupPro","type":"text"}]},{"text":" without a view in ","type":"text"},{"inlineContent":[{"text":"viewDidLoad","type":"text"}],"type":"strong"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["import KeyboardKitPro","","class KeyboardViewController: KeyboardInputViewController {","","    func viewDidLoad() {","        super.viewDidLoad()","        setupPro(","            withLicenseKey: \"your-license-key\",","            locales: [...], \/\/ Define which locales to use (Basic & Silver licenses)  ","            licenseError: { error in","                \/\/ This is called if the license registration fails.","            }","            licenseConfiguration: { license in","                \/\/ This is called if the license registration succeeds.","                \/\/ You can use this license to configure your keyboard.","                \/\/ You can now also access all KeyboardKit Pro features.","            }","        )","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use KeyboardKit Pro with a custom view, just call "},{"type":"strong","inlineContent":[{"type":"text","text":"setupPro"}]},{"type":"text","text":" and provide it with any custom view in "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboard()","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import KeyboardKitPro","","class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboard() {","        super.viewWillSetupKeyboard()","        setupPro(","            withLicenseKey: \"your-license-key\",","            locales: [...],","            licenseError: { error in ... }","            licenseConfiguration: { license in ... }","            view: { controller in","                SystemKeyboard(","                    state: controller.state,","                    services: controller.services,","                    buttonContent: { $0.view },","                    buttonView: { $0.view },","                    emojiKeyboard: { $0.view },","                    toolbar: { _ in MyCustomToolbar() }","                )","            }","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since Basic, Silver, and monthly Gold licenses validate licenses over the Internet, your keyboard extension must enable Full Access to be able to make network requests. This is not needed for yearly Gold and custom licenses, which are validated on-device."}]},{"type":"aside","name":"Important","style":"important","content":[{"inlineContent":[{"type":"text","text":"A Basic license unlocks 1 locale, Silver unlocks 5 and Gold unlocks all supported locales. You can change which locales to use for each new version of your app, after which the locales will be persisted for that app version."}],"type":"paragraph"}]},{"level":2,"type":"heading","anchor":"How-to-set-up-KeyboardKit-for-an-app","text":"How to set up KeyboardKit for an app"},{"inlineContent":[{"text":"You can use KeyboardKit in your main app, to check the enabled and Full Access status of a keyboard, provide keyboard settings, link to System Settings, etc. It’s a great place to provide app settings, since it has more available space than the keyboard extension.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You don’t have to set up KeyboardKit in your app. Just import KeyboardKit in any file where you want to use it, and you’re good to go.","type":"text"}]},{"type":"heading","level":3,"anchor":"👑-KeyboardKit-Pro","text":"👑 KeyboardKit Pro"},{"inlineContent":[{"type":"text","text":"To set up KeyboardKit Pro in your main app, just register your license key as soon as the the application launches:"}],"type":"paragraph"},{"syntax":"swift","code":["import KeyboardKitPro","","@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            ContentView()","                .task { setupKeyboardKitPro() }","        }","    }","}","","extension MyApp {","","    func setupKeyboardKitPro() async throws {","        do {","            let license = try await License.register(...)","            \/\/ KeyboardKit Pro is now activated.","        } catch {","            print(error)","            \/\/ Handle the license error in any way you want.","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you need to use Pro features on the root screen, just set some observed state when the license is registered to force a view update.","type":"text"}]},{"type":"heading","level":2,"anchor":"How-to-set-up-KeyboardKit-as-a-package-dependency","text":"How to set up KeyboardKit as a package dependency"},{"inlineContent":[{"type":"text","text":"To set up KeyboardKit as a transient package dependency, just add it to package dependencies and link it to any target that needs it."}],"type":"paragraph"},{"text":"👑 KeyboardKit Pro","type":"heading","level":3,"anchor":"👑-KeyboardKit-Pro"},{"inlineContent":[{"text":"Since KeyboardKit Pro is a binary target, it requires some special handling to be used as a transient package dependency:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You don’t have to link to KeyboardKit Pro from any target.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"You ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"must"}]},{"type":"text","text":" update "},{"inlineContent":[{"text":"runpath search paths","type":"text"}],"type":"strong"},{"text":" under ","type":"text"},{"inlineContent":[{"type":"text","text":"Build Settings"}],"type":"strong"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For the main app, set it to "},{"type":"strong","inlineContent":[{"text":"@executable_path\/Frameworks","type":"text"}]},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"For the keyboard, set it to "},{"type":"strong","inlineContent":[{"text":"@executable_path\/..\/..\/Frameworks","type":"text"}]},{"text":".","type":"text"}]}]}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Failing to set the search paths will cause a runtime crash when you try to use KeyboardKit Pro.","type":"text"}]},{"anchor":"How-to-use-KeyboardKit-state--services","text":"How to use KeyboardKit state & services","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The KeyboardKit "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"type":"text","text":" provides you with keyboard-specific observable "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":", that let you build powerful keyboards."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit injects all these observable state types into the view hierarchy as environment objects, to let you access them like this:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomKeyboard: View {","","    init(","        actionHandler: KeyboardActionHandler","    ) {","        self.actionHandler = actionHandler","    }","","    let actionHandler: KeyboardActionHandler","","    @EnvironmentObject","    private var context: KeyboardContext","","    var body: some View {","        ...","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Services are not injected into the view hierarchy, and must be passed around. KeyboardKit uses init injection for both state and services."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can easily modify any state and replace any service with custom implementations. For instance, here we disable autocomplete with the shared "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AutocompleteContext"},{"text":" and replace the standard ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler"},{"text":" with a custom one:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        services.actionHandler = CustomActionHandler(","            inputViewController: self","        )","        super.viewDidLoad()","        state.autocompleteContext.isAutocompleteEnabled = false","    }","}","","class CustomActionHandler: StandardActionHandler {","","    open override func handle(","        _ gesture: KeyboardGesture, ","        on action: KeyboardAction","    ) {","        if gesture == .press && action == .space {","            print(\"Pressed space!\")","        }","        super.handle(gesture, on: action) ","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Since services are lazy and resolved when they’re used for the first time, you should set up any custom services as early as possible, to ensure that the dependency graph is properly resolved.","type":"text"}]},{"anchor":"Going-further","text":"Going further","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You should now have a basic understanding of how to set up KeyboardKit and KeyboardKit Pro. For more information & examples, see the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials","isActive":true},{"text":" article, as well as the other articles. Also, take a look at the demo app.","type":"text"}]}],"kind":"content"}],"metadata":{"images":[{"type":"card","identifier":"Page.png"}],"role":"article","color":{"standardColorIdentifier":"blue"},"modules":[{"name":"KeyboardKitPro"}],"roleHeading":"Article","title":"Getting Started"},"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/getting-started"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/getting-started"]}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro","url":"\/documentation\/keyboardkitpro","type":"topic","title":"KeyboardKitPro","abstract":[{"type":"text","text":"KeyboardKit helps you create custom keyboard extensions with Swift and SwiftUI."}],"role":"collection","kind":"symbol"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardActionHandler":{"type":"topic","navigatorTitle":[{"text":"KeyboardActionHandler","kind":"identifier"}],"url":"\/documentation\/keyboardkitpro\/keyboardactionhandler","kind":"symbol","abstract":[{"type":"text","text":"This protocol can be implemented by any classes that can"},{"text":" ","type":"text"},{"text":"handle triggered ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction"},{"text":" events.","type":"text"}],"title":"KeyboardActionHandler","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"KeyboardActionHandler"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardActionHandler","role":"symbol"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Essentials":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials","kind":"article","type":"topic","abstract":[{"text":"This article describes the essential parts of KeyboardKit.","type":"text"}],"title":"Essentials","url":"\/documentation\/keyboardkitpro\/essentials","role":"article","images":[{"type":"card","identifier":"Page.png"}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/AutocompleteContext":{"navigatorTitle":[{"text":"AutocompleteContext","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AutocompleteContext","kind":"identifier"}],"abstract":[{"type":"text","text":"This class has observable, autocomplete-related state."}],"url":"\/documentation\/keyboardkitpro\/autocompletecontext","type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AutocompleteContext","kind":"symbol","title":"AutocompleteContext"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardAction":{"kind":"symbol","url":"\/documentation\/keyboardkitpro\/keyboardaction","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"KeyboardAction","kind":"identifier"}],"title":"KeyboardAction","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"KeyboardAction"}],"abstract":[{"text":"This enum defines keyboard-specific actions, and is also","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"serving as a namespace for keyboard action-related types."}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardInputViewController":{"url":"\/documentation\/keyboardkitpro\/keyboardinputviewcontroller","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"KeyboardInputViewController"}],"kind":"symbol","type":"topic","title":"KeyboardInputViewController","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","abstract":[{"type":"text","text":"This is the main input controller in a KeyboardKit-based"},{"text":" ","type":"text"},{"text":"keyboard extension.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"KeyboardInputViewController"}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardInputViewController/services":{"type":"topic","role":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","title":"services","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"services","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14KeyboardKitPro0A0V","text":"Keyboard"},{"kind":"text","text":"."},{"text":"Services","kind":"typeIdentifier","preciseIdentifier":"s:14KeyboardKitPro0A0V8ServicesC"}],"url":"\/documentation\/keyboardkitpro\/keyboardinputviewcontroller\/services","abstract":[{"type":"text","text":"The default set of keyboard-specific services."}],"kind":"symbol"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardInputViewController/state":{"title":"state","kind":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","abstract":[{"type":"text","text":"The default set of keyboard-specific state."}],"url":"\/documentation\/keyboardkitpro\/keyboardinputviewcontroller\/state","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"state"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Keyboard","preciseIdentifier":"s:14KeyboardKitPro0A0V"},{"text":".","kind":"text"},{"text":"State","preciseIdentifier":"s:14KeyboardKitPro0A0V5StateC","kind":"typeIdentifier"}],"role":"symbol","type":"topic"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/SystemKeyboard":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SystemKeyboard"}],"navigatorTitle":[{"text":"SystemKeyboard","kind":"identifier"}],"title":"SystemKeyboard","kind":"symbol","abstract":[{"text":"This keyboard can be used to mimic a native iOS keyboard.","type":"text"}],"role":"symbol","url":"\/documentation\/keyboardkitpro\/systemkeyboard","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard","type":"topic"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardInputViewController/viewWillSetupKeyboard()":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"viewWillSetupKeyboard"},{"text":"()","kind":"text"}],"role":"symbol","title":"viewWillSetupKeyboard()","type":"topic","kind":"symbol","abstract":[{"text":"This function is called when a keyboard view must be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"created. It will by default setup a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard"},{"type":"text","text":"."}],"url":"\/documentation\/keyboardkitpro\/keyboardinputviewcontroller\/viewwillsetupkeyboard()","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/viewWillSetupKeyboard()"},"Page.png":{"identifier":"Page.png","alt":"Page icon","type":"image","variants":[{"url":"\/images\/Page.png","traits":["1x","light"]}]}},"variantOverrides":[{"patch":[{"value":"occ","op":"replace","path":"\/identifier\/interfaceLanguage"},{"op":"add","path":"\/topicSections","value":null},{"op":"add","path":"\/seeAlsoSections","value":null},{"path":"\/references\/doc:~1~1com.keyboardkit.KeyboardKitPro~1documentation~1KeyboardKitPro~1KeyboardInputViewController\/title","op":"replace","value":"KeyboardInputViewController"},{"value":[{"text":"KeyboardInputViewController","kind":"identifier"}],"op":"replace","path":"\/references\/doc:~1~1com.keyboardkit.KeyboardKitPro~1documentation~1KeyboardKitPro~1KeyboardInputViewController\/fragments"}],"traits":[{"interfaceLanguage":"occ"}]}]}