so a namespace for theme-related types and views, like ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/Shelf","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/ShelfItem","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Context","text":"Context"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has an observable "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext","type":"reference","isActive":true},{"type":"text","text":" class that can be used to handle themes and auto-persisted "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property","isActive":true,"type":"reference"},{"type":"text","text":". It also has auto-persisted "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"type":"text","text":" that can be used to persist themes."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit automatically creates an instance of this class, injects it into ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"text":" and updates it whenever the theme changes.","type":"text"}]},{"type":"heading","text":"Services","level":2,"anchor":"Services"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In KeyboardKit, a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService\/themeBased(keyboardContext:themeContext:)","type":"reference"},{"text":" style service can be used to apply a keyboard theme:","type":"text"}]},{"code":["override func viewDidLoad() {","    super.viewDidLoad()","    setup(for: .myApp) { result in","        \/\/ Check result to see that setup was successful","        self.services.styleService = .themeBased(","            keyboardContext: state.keyboardContext,","            themeContext: state.themeContext","        )","    } ","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can inherit "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","isActive":true},{"type":"text","text":" to customize themes even further, which lets you mix the benefits of themes and styles."}],"type":"paragraph"},{"type":"heading","level":2,"text":"Settings","anchor":"Settings"},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeSettings","isActive":true,"type":"reference"},{"text":" type with theme-related state & settings. The context ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property","type":"reference","isActive":true},{"type":"text","text":" is used by default."}],"type":"paragraph"},{"anchor":"Themes","level":2,"type":"heading","text":"Themes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","type":"reference","isActive":true},{"text":" can provide keyboard-related styles in a way that can be easily used and modified. A theme can also define style variations that can be used to customize a constrained set of theme properties.","type":"text"}]},{"inlineContent":[{"text":"KeyboardKit Pro unlocks a bunch of themes and style variations, as well as a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","isActive":true,"type":"reference"},{"type":"text","text":" that lets you apply themes with the style service concept that is still used by the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro unlocks many standard themes, like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/standard"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/swifty","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/minimal"},{"type":"text","text":". These themes also have style variations, that lets you vary their appearance, like the standard theme’s "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/StandardStyle\/blue","type":"reference","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/StandardStyle\/green","isActive":true},{"type":"text","text":" variations:"}]},{"type":"tabNavigator","tabs":[{"title":".standard","content":[{"columns":[{"content":[{"inlineContent":[{"identifier":"standard","type":"image"}],"type":"paragraph"}],"size":1},{"content":[{"inlineContent":[{"identifier":"standard-blue","type":"image"}],"type":"paragraph"}],"size":1},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"standard-green","type":"image"}]}]}],"type":