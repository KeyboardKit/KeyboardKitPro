nt":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"tron"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"tron-fcon","type":"image"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"tron-virus"}]}]}]}],"title":".tron"}]},{"type":"paragraph","inlineContent":[{"text":"You can get a list of all predefined themes, as well as all pre-defined style variations, using the static ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/predefined","isActive":true,"type":"reference"},{"text":" properties. You can create your own themes, as well as custom style variations for all predefined themes.","type":"text"}]},{"type":"heading","level":2,"anchor":"Views","text":"Views"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro unlocks views in the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme"},{"type":"text","text":" namespace, that make it easy to preview and present keyboard themes:"}]},{"type":"tabNavigator","tabs":[{"content":[{"numberOfColumns":2,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"themeshelf","type":"image"}]}],"size":1},{"content":[{"inlineContent":[{"text":"A keyboard theme ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/Shelf","type":"reference","isActive":true},{"text":" can be used to list themes in a vertical list of horizontally scrolling shelves.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use the standard "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/ShelfItem","isActive":true},{"type":"text","text":" to show how a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","isActive":true},{"type":"text","text":" will look, or use completely custom views for the titles and items."}],"type":"paragraph"}],"size":1}],"type":"row"}],"title":"Shelf"}]},{"type":"thematicBreak"},{"type":"heading","level":2,"anchor":"How-to","text":"How to…"},{"type":"heading","level":3,"anchor":"apply-a-theme","text":"…apply a theme"},{"type":"paragraph","inlineContent":[{"text":"The easiest way to apply a theme is with the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardTheme(_:context:)","isActive":true},{"text":" view modifier. Note that this requires that you have a KeyboardKit Pro license that includes the themes feature.","type":"text"}]},{"type":"heading","level":3,"anchor":"create-a-custom-theme","text":"…create a custom theme"},{"type":"paragraph","inlineContent":[{"text":"Since a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","isActive":true,"type":"reference"},{"text":" is just a struct, you can easily create your own custom themes by just defining new static theme value types.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, this theme only changes the color of the primary button:"}]},{"type":"codeListing","syntax":"swift","code":["extension KeyboardTheme {","","    static var greenPrimary: Self {","        get throws {","            try? Self(primaryBackgroundColor: .green)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use other themes as a base when creating your own custom themes, if you only want to change a small part of a theme."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For instance, this theme starts with the minimal theme and changes the color of the primary button to pink:"}]},{"type":"codeListing","syntax":"swift","code":["extension KeyboardTheme {","","    static var pinkPrimary: Self {","        get throws {","            var theme = try? KeyboardTheme.minimal","            theme.buttonStyles[.primary]?.backgroundColor = .green","            return theme","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also create custom themes that just tweak a style variation of another theme."}]},{"type":"paragraph","inlineContent":[{"text":"For instance, this custom theme is a standard theme that applies a black tint color style variation:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension KeyboardTheme {","","    static var standardBlack: Self {","        .standard(.init(tint: .black))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All these combinations make the theme engine very flexible and powerful."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/themes-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/themes-article"]}],"references":{"themeshelf":{"alt":"ThemeShelf","variants":[{"traits":["1x","light"],"url":"\/images\/com.keyboardkit.KeyboardKitPro\/themeshelf.jpg"}],"type":"image","identifier":"themeshelf"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Host-Article":{"images":[{"type":"card","identifier":"Page.png"}],"kind":"article","type":"topic","role":"article","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","title":"Host Application","url":"\/documentation\/keyboardkitpro\/host-article","abstract":[{"type":"text","text":"This article describes how KeyboardKit Pro can identify and use the host application."}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Autocomplete-Article":{"images":[{"type":"card","identifier":"Page.png"}],"identifier":