text"}]},{"type":"codeListing","code":["extension KeyboardTheme {","","    static var pinkPrimary: Self {","        get throws {","            var theme = try? KeyboardTheme.minimal","            theme.buttonStyles[.primary]?.backgroundColor = .green","            return theme","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also create custom themes that just tweak a style variation of another theme."}]},{"type":"paragraph","inlineContent":[{"text":"For instance, this custom theme is a standard theme that applies a black tint color style variation:","type":"text"}]},{"type":"codeListing","code":["extension KeyboardTheme {","","    static var standardBlack: Self {","        .standard(.init(tint: .black))","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"All these combinations make the theme engine very flexible and powerful.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/keyboardkitpro\/themes-article"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/keyboardkitpro\/themes-article"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Host-Article":{"url":"\/documentation\/keyboardkitpro\/host-article","abstract":[{"text":"This article describes how KeyboardKit Pro can identify and use the host application.","type":"text"}],"kind":"article","title":"Host Application","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","type":"topic","images":[{"type":"card","identifier":"Page.png"}],"role":"article"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardTheme/swifty":{"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"Swifty"},{"type":"text","text":" theme."}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keybo