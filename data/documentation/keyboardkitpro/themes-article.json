nor":3},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a style engine that makes it easy to customize the style of your keyboard. However, the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"text":" is a bit tricky to use if you need to easily apply many different styles.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"👑 ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" therefore unlocks a theme engine that can be used to easily style your keyboard with different styles, and provides you with many predefined themes, templates, and theme-based views. You can easily create custom themes as well.","type":"text"}]},{"type":"heading","level":2,"anchor":"Namespace","text":"Namespace"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme"},{"text":" type that is also a namespace for theme-related types and views, like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/Shelf"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/ShelfItem"},{"text":".","type":"text"}]},{"type":"heading","level":2,"anchor":"Context","text":"Context"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has an observable "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext"},{"type":"text","text":" class that can be used to handle themes and auto-persisted "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"type":"text","text":". It also has auto-persisted "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"type":"text","text":" that can be used to persist themes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of this class, injects it into "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" and updates it whenever the theme changes."}]},{"type":"heading","level":2,"anchor":"Services","text":"Services"},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService\/themeBased(keyboardContext:themeContext:)"},{"text":" style service can be used to apply a keyboard theme:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["override func viewDidLoad() {","    super.viewDidLoad()","    setup(for: .myApp) { result in","        \/\/ Check result to see that setup was successful","        self.services.styleService = .themeBased(","            keyboardContext: state.keyboardContext,","            themeContext: state.themeContext","        )","    } ","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can inherit "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","isActive":true},{"type":"text","text":" to customize themes even further, which lets you mix the benefits of themes and styles."}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This service is being replaced with the new ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardTheme(_:context:)","type":"reference"},{"text":" view modifier, which will make it possible to apply a theme without having to register a custom service.","type":"text"}]}],"style":"note"},{"type":"heading","level":2,"anchor":"Settings","text":"Settings"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeSettings"},{"type":"text","text":" type with theme-related state & settings. The context "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"type":"text","text":" is used by default."}]},{"type":"heading","level":2,"anchor":"Themes","text":"Themes"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","isActive":true},{"type":"text","text":" can provide keyboard-related styles in a way that can be easily used and modified. A theme can also define style variations that can be used to customize a constrained set of theme properties."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro unlocks a bunch of themes and style variations, as well as a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","isActive":true},{"type":"text","text":" that lets you apply themes with the style service concept that is still used by the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro unlocks many standard themes, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/standard","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/swifty","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/minimal","isActive":true,"type":"reference"},{"text":". These themes also have style variations, that lets you vary their appearance, like the standard theme’s ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/StandardStyle\/blue","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/StandardStyle\/green","isActive":true,"type":"reference"},{"text":" variations:","type":"text"}]},{"type":"tabNavigator","tabs":[{"title":".standard","content":[{"numberOfColumns":3,"columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"standard","type":"image"}],"type":"paragraph"}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"standard-blue"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"standard-green"}]}]}],"type":"row"}]},{"title":".swifty","content":[{"numberOfColumns":3,"type":"row","columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"swifty"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":