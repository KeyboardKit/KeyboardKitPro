dKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/ShelfItem","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Context","level":2,"type":"heading","anchor":"Context"},{"inlineContent":[{"text":"KeyboardKit has an observable ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext","isActive":true},{"type":"text","text":" class that can be used to handle themes and auto-persisted "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"text":". It also has auto-persisted ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property","isActive":true},{"text":" that can be used to persist themes.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of this class, injects it into "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state","isActive":true},{"text":" and updates it whenever the theme changes.","type":"text"}]},{"text":"Services","level":2,"type":"heading","anchor":"Services"},{"inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService\/themeBased(keyboardContext:themeContext:)"},{"text":" style service can be used to apply a keyboard theme:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["override func viewDidLoad() {","    super.viewDidLoad()","    setupPro(for: .myApp) { license in","        self.services.styleService = .themeBased(","            keyboardContext: state.keyboardContext,","   