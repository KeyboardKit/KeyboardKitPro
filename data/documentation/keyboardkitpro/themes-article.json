t"},{"text":" class that can be used to handle themes and auto-persisted ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"text":". It also has auto-persisted ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property"},{"text":" that can be used to persist themes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit automatically creates an instance of this class, injects it into "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"type":"text","text":" and updates it whenever the theme changes."}]},{"type":"heading","level":2,"text":"Services","anchor":"Services"},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService\/themeBased(keyboardContext:themeContext:)","type":"reference"},{"text":" style service can be used to apply a keyboard theme:","type":"text"}]},{"type":"codeListing","code":["override func viewDidLoad() {","    super.viewDidLoad()","    setup(for: .myApp) { result in","        \/\/ Check result to see that setup was successful","        self.services.styleService = .themeBased(","            keyboardContext: state.keyboardContext,","            themeContext: state.themeContext","        )","    } ","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can inherit ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","isActive":true,"type":"reference"},{"text":" to customize themes even further, w