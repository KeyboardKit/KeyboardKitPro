style of your keyboard. However, the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true,"type":"reference"},{"text":" is a bit tricky to use if you need to easily apply many different styles.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"👑 "},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"type":"text","text":" therefore unlocks a theme engine that can be used to easily style your keyboard with different styles, and provides you with many predefined themes, templates, and theme-based views. You can easily create custom themes as well."}],"type":"paragraph"},{"anchor":"Namespace","type":"heading","text":"Namespace","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme"},{"type":"text","text":" type that is also a namespace for theme-related types and views, like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/Shelf"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/ShelfItem"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Context","type":"heading","text":"Context","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit has an observable "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext","isActive":true,"type":"reference"},{"type":"text","text":" class that can be used to handle themes and auto-persisted "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property","isActive":true,"type":"reference"},{"type":"text","text":". It also has auto-persisted "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardThemeContext\/settings-swift.property","isActive":true,"type":"reference"},{"type":"text","text":" that can be used to persist themes."}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit automatically creates an instance of this class, injects it into ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/state"},{"text":" and updates it whenever the theme changes.","type":"text"}],"type":"paragraph"},{"anchor":"Services","type":"heading","text":"Services","level":2},{"inlineContent":[{"type":"text","text":"In KeyboardKit, a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService\/themeBased(keyboardContext:themeContext:)","isActive":true},{"type":"text","text":" style service can be used to apply a keyboard theme:"}],"type":"paragraph"},{"type":"codeListing","code":["override func viewDidLoad() {","    super.viewDidLoad()","    setup(for: .myApp) { result in","        \/\/ Check result to see that setup was successful","        self.services.styleService = .themeBased(","            keyboardContext: state.keyboardContext,","            themeContext: state.themeContext","        )","    } ","}"],"syntax":"swift"},{"inlineContent":[{"text":"You can inherit ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedStyleService","type":"reference","isActive":true},{"text":" to customize themes even further, which lets you mix the benefits of themes and styles.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This service is being replaced with t