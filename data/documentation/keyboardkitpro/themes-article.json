Content":[{"type":"image","identifier":"tron-fcon"}]}]},{"size":1,"content":[{"inlineContent":[{"identifier":"tron-virus","type":"image"}],"type":"paragraph"}]}],"type":"row"}],"title":".tron"}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"You can get a list of all predefined themes, as well as all pre-defined style variations, using the static ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme\/allPredefined","isActive":true},{"text":" properties. You can create your own themes, as well as custom style variations for all predefined themes.","type":"text"}]},{"anchor":"How-to-apply-a-theme","type":"heading","text":"How to apply a theme","level":2},{"type":"paragraph","inlineContent":[{"text":"You can apply theme with the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedProvider","type":"reference"},{"text":" style provider, or the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleProvider\/themed(with:keyboardContext:)","isActive":true,"type":"reference"},{"type":"text","text":" shorthand:"}]},{"type":"codeListing","syntax":"swift","code":["override func viewWillSetupKeyboard() {","    super.viewWillSetupKeyboard()","","    \/\/ Setup KeyboardKit Pro with a license","    setupPro(withLicenseKey: \"...\") { license in","        services.styleProvider = .themed(","            with: .standard,","            keyboardContext: state.keyboardContext,","            fallback: services.styleProvider","        )","    } view: { controller in","        \/\/ Return your keyboard view here","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"You can inherit ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/ThemeBasedProvider"},{"type":"text","text":" to customize the theme even further, which lets you mix the benefits of themes and styles."}]},{"type":"heading","anchor":"How-to-create-a-custom-theme","level":2,"text":"How to create a custom theme"},{"inlineContent":[{"type":"text","text":"Since a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","type":"reference"},{"text":" is just a struct, you can easily create your own custom themes by just defining new static theme value types.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For instance, this theme only changes the color of the primary button:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["extension KeyboardTheme {","","    static var greenPrimary: Self {","        get throws {","            try? Self(primaryBackgroundColor: .green)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"You can also use other themes as a base when creating your own custom themes, if you only want to change a small part of a theme.","type":"text"}]},{"inlineContent":[{"text":"For instance, this theme starts with the minimal theme and changes the color of the primary button to pink:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["extension KeyboardTheme {","","    static var pinkPrimary: Self {","        get throws {","            var theme = try? KeyboardTheme.minimal","            theme.buttonStyles[.primary]?.backgroundColor = .green","            return theme","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"You can also create custom themes that just tweak a style variation of another theme."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For instance, this custom theme is a standard theme that applies a black tint color style variation:","type":"text"}]},{"syntax":"swift","code":["extension KeyboardTheme {",""