{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Custom iOS keyboards use a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy"},{"type":"text","text":" to modify text, move the input cursor, provide input-related information, etc."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This proxy points to the currently selected text field in the currently active app, and will "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" detect if you focus on a text field inside the keyboard extension. Text that you type will still be sent to the currently active app."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro unlocks text input views that let you type directly within a keyboard extension, as well as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Vietnamese"},{"type":"text","text":" input support."}],"type":"paragraph"},{"level":2,"anchor":"Text-routing","text":"Text routing","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"type":"text","text":" has a custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy"},{"type":"text","text":" that can be set to route text to any other text field or custom proxy. You can always access the original text document proxy with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/originalTextDocumentProxy"},{"type":"text","text":" property."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" has similar properties, but you should avoid referring to it and passing it within your code."}],"type":"paragraph"},{"level":2,"anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"text":" unlocks a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","type":"reference"},{"text":" that let you type directly within a keyboard extension by automatically registering themselves as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","type":"reference"},{"text":" when they get focus","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro also unlocks additional "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextInput","type":"reference","isActive":true},{"type":"text","text":" support, like "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Vietnamese","type":"reference","isActive":true},{"type":"text","text":", to let you to type in locale-specific ways."}],"type":"paragraph"},{"level":3,"anchor":"%F0%9F%87%BB%F0%9F%87%B3-Vietnamese-Input-BETA","text":"🇻🇳 Vietnamese Input (BETA)","type":"heading"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro unlocks a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Vietnamese","isActive":true},{"type":"text","text":" namespace, with Vietnamese-related types, as well as a  "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/VietnameseInputEngine","isActive":true},{"type":"text","text":" that supports typing with TELEX, VIQR, and VNI."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro will automatically use the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/VietnameseInputEngine","isActive":true,"type":"reference"},{"type":"text","text":" when applicable. You can also use these types as standalone features to implement Vietnamese input support elsewhere."}],"type":"paragraph"},{"name":"Important","content":[{"inlineContent":[{"text":"Vietnamese typing requires a ","type":"text"},{"type":"codeVoice","code":"Gold"},{"text":" license.","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside"},{"level":3,"anchor":"Input-Views","text":"Input Views","type":"heading"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField"},{"type":"text","text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension."}]}],"title":"KeyboardTextField"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true,"type":"reference"},{"text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension.","type":"text"}]}],"title":"KeyboardTextView"}],"type":"tabNavigator"},{"inlineContent":[{"text":"Both views support ","type":"te