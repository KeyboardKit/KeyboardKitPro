{"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Input-Article"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"Custom iOS keyboards use a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","type":"reference","isActive":true},{"text":" to modify text, move the input cursor, provide input-related information, etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This proxy points to the currently selected text field in the currently active app, and will ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" detect if you focus on a text field inside the keyboard extension. Text that you type will still be sent to the currently active app.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit Pro unlocks text input views that let you type directly within a keyboard extension, as well as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Vietnamese","type":"reference"},{"text":" input support.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Text routing","anchor":"Text-routing"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true,"type":"reference"},{"text":" has a custom ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true,"type":"reference"},{"text":" that can be set to route text to any other text field or custom proxy. You can always access the original text document proxy with the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/originalTextDocumentProxy","isActive":true,"type":"reference"},{"text":" property.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" has similar properties, but you should avoid referring to it and passing it within your code."}],"type":"paragraph"},{"level":2,"type":"heading","text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro"},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView"},{"type":"text","text":" that let you type directly within a keyboard extension by automatically registering themselves as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy"},{"type":"text","text":" when they get focus"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro also unlocks additional "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextInput"},{"type":"text","text":" support, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Vietnamese"},{"type":"text","text":", to let you to type in locale-specific ways."}],"type":"paragraph"},{"level":3,"type":"heading","text":"🇻🇳 Vietnamese Input (BETA)","anchor":"%