want"}]},{"text":" to use in your app and keyboard. It will be capped to the number of locales that your KeyboardKit Pro license includes.","type":"text"}],"type":"paragraph"}]},{"type":"heading","level":2,"text":"Keyboard App View","anchor":"Keyboard-App-View"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","isActive":true},{"type":"text","text":" view can be used as the root view of a keyboard app target, to set up everything needed to use KeyboardKit for a certain "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","code":["@main","struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will set up things that are defined by the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","type":"reference"},{"type":"text","text":", like making keyboard setting use an App Group to sync between the app and its keyboard, register a KeyboardKit Pro license key, set up dictation, etc. It will also inject all keyboard "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State","type":"reference"},{"text":" into the environment:","type":"text"}]},{"type":"codeListing","code":["struct ContentView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: View {","        ...","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"The injected state will also be used by the KeyboardKit Pro screens that are described below.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"type":"heading","text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}]},{"type":"text","text":" unlocks screens in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"text":" namespace, that let you quickly add keyboard-related features to the main app.","type":"text"}],"type":"paragraph"},{"type":"tabNavigator","tabs":[{"title":"HomeScreen","content":[{"numberOfColumns":2,"columns":[{"content":[{"inlineContent":[{"identifier":"keyboardapp-homescreen","type":"image"}],"type":"paragraph"}],"size":1},{"content":[{"inlineContent":[{"type":"text","text":"A "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","type":"reference"},{"type":"text","text":" can be used as the main screen of a keyboard app, to let you quickly get your main app up and running."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The screen shows the main app icon, a keyboard status section, links to settings screens, custom header & footer content, etc.","type":"text"}]}],"size":1}],"type":"row"}]},{"content":[{"columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"keyboardapp-settingsscreen"}],"type":"paragraph"}],"size":1},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","type":"reference","isActive":true},{"text":" can be used as the main settings screen of a keyboard app or in a keyboard extension.","type":"text"}]},{"type":"