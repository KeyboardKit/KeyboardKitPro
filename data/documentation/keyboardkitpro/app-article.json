Pro\/documentation\/KeyboardKitPro\/KeyboardApp\/locales","isActive":true},{"text":" collection is only meant to describe which locales you ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"want"}]},{"text":" to use in your app and keyboard. It will be capped to the number of locales that your KeyboardKit Pro license includes.","type":"text"}]}]},{"anchor":"Keyboard-App-View","type":"heading","level":2,"text":"Keyboard App View"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView","isActive":true,"type":"reference"},{"text":" view can be used as the root view of a keyboard app target, to set up everything needed to use KeyboardKit for a certain ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"This will set up things that are defined by the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"type":"text","text":", like making keyboard setting use an App Group to sync between the app and its keyboard, register a KeyboardKit Pro license key, set up dictation, etc. It will also inject all keyboard "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State","isActive":true,"type":"reference"},{"type":"text","text":" into the environment:"}],"type":"paragraph"},{"code":["struct ContentView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","   