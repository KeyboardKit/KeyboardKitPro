"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen"},{"type":"text","text":" that are unlocked by KeyboardKit Pro."}]},{"inlineContent":[{"type":"text","text":"You can create an app-specific "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" value to define and set up your app & keyboard, by defining your app’s  "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/name","type":"reference"},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId","isActive":true},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId"},{"text":", ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/deepLinks-swift.property","type":"reference"},{"text":", etc.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can create a static app value and add it to both the main app and its keyboard extension, to easily refer to it from both, for instance:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        KeyboardApp(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                    \/\/ You may also use a license file","            bundleId: \"com.keyboardkit.demo\",",