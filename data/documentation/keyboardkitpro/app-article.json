{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/app-article"]},{"paths":["\/documentation\/keyboardkitpro\/app-article"],"traits":[{"interfaceLanguage":"occ"}]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"KeyboardKit has app-specific utilities to help you build a great main app for your keyboard, like setting that automatically setting up your keyboard and app with a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"type":"text","text":", syncing settings between the app and its keyboard, and much more."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"👑 "},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"text":" unlocks app-specific screens, like a home screen template, and various settings screens, to help you get your main app up and running in minutes. Information about Pro features can be found further down.","type":"text"}]},{"anchor":"Keyboard-App","type":"heading","text":"Keyboard App","level":2},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","type":"reference","isActive":true},{"text":" struct that is also a namespace for app-related types and views, like the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen"},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/LocaleScreen","type":"reference","isActive":true},{"type":"text","text":" that are unlocked by KeyboardKit Pro."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create an app-specific "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" value to define and set up your app & keyboard, by defining your app’s  "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/name","isActive":true},{"type":"text","text":", "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/bundleId","isActive":true,"type":"reference"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/appGroupId"},{"type":"text","text":", "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/licenseKey","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/deepLinks-swift.property","isActive":true,"type":"reference"},{"type":"text","text":", etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create a static app value and add it to both the main app and its keyboard extension, to easily refer to it from both, for instance:"}]},{"type":"codeListing","code":["extension KeyboardApp {","","    static var keyboardKitDemo: KeyboardApp {","        .init(","            name: \"KeyboardKit\",","            licenseKey: \"your-key-here\",                \/\/ Sets up KeyboardKit Pro!","            appGroupId: \"group.com.keyboardkit.demo\",   \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up custom autocomplete  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"kkdemo:\/\/\", ...)     \/\/ Defines how to open the app","        )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":" can specify other properties you may need. See "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete-Article","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AI-Article","isActive":true,"type":"reference"},{"text":" for more information.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":"’s "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/locales","type":"reference"},{"type":"text","text":" collection is only meant to describe which locales you "},{"inlineContent":[{"type":"text","text":"want"}],"type":"emphasis"},{"type":"text","text":" to use in your app and keyboard. It will be capped to the number of locales that your KeyboardKit Pro license includes."}]}],"style":"important","name":"Important","type":"aside"},{"text":"Keyboard App View","anchor":"Keyboard-App-View","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAppView"},{"type":"text","text":" view can be used as the root view of a keyboard app target, to set up everything needed to use KeyboardKit for a certain "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"code":["@main","struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .keyboardKitDemo) {","                ContentView()","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This will set up things that are defined by the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","isActive":true},{"type":"text","text":", like making keyboard setting use an App Group to sync between the app and its keyboard, register a KeyboardKit Pro license key, set up dictation, etc. It will also inject all keyboard "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/State","type":"reference"},{"type":"text","text":" into the environment:"}]},{"code":["struct ContentView: View {","","    @EnvironmentObject","    var keyboardContext: KeyboardContext","","    var body: View {","        ...","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The injected state will also be used by the KeyboardKit Pro screens that are described below.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"anchor":"%F0%9F%91%91-KeyboardKit-Pro","type":"heading","text":"👑 KeyboardKit Pro","level":2},{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true,"type":"reference","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}]},{"type":"text","text":" unlocks screens in the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp","type":"reference"},{"type":"text","text":" namespace, that let you quickly add keyboard-related features to the main app."}]},{"tabs":[{"title":"HomeScreen","content":[{"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"keyboardapp-homescreen","type":"image"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/HomeScreen","isActive":true,"type":"reference"},{"text":" can be used as the main screen of a keyboard app, to let you quickly get your main app up and running.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The screen shows the main app icon, a keyboard status section, links to settings screens, custom header & footer content, etc.","type":"text"}]}],"size":1}],"type":"row","numberOfColumns":2}]},{"title":"SettingsScreen","content":[{"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"keyboardapp-settingsscreen","type":"image"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp\/SettingsScreen","isActive":true},{"type":"text","text":" can be used as the main settings screen of a keyboard app or in a keyboard extension."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The screen lists various keyboard settings, grouped by type. All changes are automatically synced to the various context types."}]}],"size":1}],"type":"row","numberOfColumns":2}]},{"content":[{"type":"row","numberOfColumns":2,"columns"