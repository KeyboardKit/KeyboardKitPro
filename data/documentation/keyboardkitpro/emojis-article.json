dkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/ColonSearch","type":"reference"},{"text":" search engine.  Information about Pro features can be found further down.","type":"text"}],"type":"paragraph"},{"name":"Important","style":"important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard","isActive":true},{"text":" uses high-resolution emojis on iPad, which consumes a lot of memory when scrolling through categories. Apply an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/KeyboardStyle\/optimized(for:)"},{"type":"text","text":" style with "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/emojiKeyboardStyle(_:)","isActive":true,"type":"reference"},{"type":"text","text":" if your keyboard uses memory-intense tools. Check out the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Developer-Memory-Management"},{"type":"text","text":" article for more information about memory management in keyboard extensions."}],"type":"paragraph"}]},{"text":"Emojis","type":"heading","level":2,"anchor":"Emojis"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji","isActive":true},{"text":" struct represents a structured emoji model that lets you work with emojis and their information in a more structured way:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let emoji = Emoji(\"😀\")"]},{"inlineContent":[{"text":"You can trigger emoji character insertion by triggering the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/emoji(_:)-swift.enum.case","isActive":true},{"text":" keyboard action, just like you trigger any other keyboard action.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Emoji Categories","anchor":"Emoji-Categories","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory","type":"reference","isActive":true},{"type":"text","text":" enum defines all available emoji categories and their emojis:"}],"type":"paragraph"},{"syntax":"swift","code":["EmojiCategory.smileysAndPeople.emojis  \/\/ 😀😃😄...","EmojiCategory.animalsAndNature.emojis  \/\/ 🐶🐱🐭..."],"type":"codeListing"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory","type":"reference"},{"type":"text","text":" uses "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiVersion","isActive":true,"type":"reference"},{"text":" to filter out emojis that are unavailable to the current runtime, to only include available emojis.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Emoji Versions","level":2,"anchor":"Emoji-Versions"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiVersion","type":"reference","isActive":true},{"text":" enum defines all available emoji versions and their emojis and supported platforms:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let version = EmojiVersion.v15","version.emojis          \/\/ 🫨🫸🫷🪿🫎🪼🫏🪽🪻🫛🫚🪇🪈🪮🪭🩷🩵🩶🪯🛜...","version.version         \/\/ 15.0","version.iOS             \/\/ 16.4","version.olderVersions   \/\/ [.v14, .v13_1, .v13, .v12_1, ...]"]},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory","type":"reference","isActive":true},{"text":" uses ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiVersion","type":"reference"},{"text":" to filter out emojis that are unavailable to the current runtime, to only include available emojis.","type":"text"}]},{"level":2,"anchor":"Unicode-Information","type":"heading","text":"Unicode Information"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji","isActive":true},{"text":" enum has unicode-specific properties that can be used for identity and basic, non-localized naming:","type":"text"}]},{"code":["Emoji(\"👍\").unicodeIdentifier   \/\/ \\\\N{THUMBS UP SIGN}","Emoji(\"👍🏿\").unicodeIdentifier   \/\/ \\\\N{THUMBS UP SIGN}\\\\N{EMOJI MODIFIER FITZPATRICK TYPE-6}","Emoji(\"👍\").unicodeName         \/\/ Thumbs Up Sign"],"syntax":"swift","type":"codeListing"},{"type":"heading","anchor":"Skintone-Information","level":2,"text":"Skintone Information"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji","isActive":true,"type":"reference"},{"type":"text","text":" enum has skin tone-specific properties that define skin tone variants for all supported emojis:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Emoji(\"👍\").hasSkinToneVariants      \/\/ true","Emoji(\"🚀\").hasSkinToneVariants      \/\/ false","Emoji(\"👍🏿\").neutralSkinToneVariant   \/\/ 👍","Emoji(\"👍\").skinToneVariants         \/\/ 👍👍🏻👍🏼👍🏽👍🏾👍🏿"]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard","type":"reference","isActive":true},{"type":"text","text":" will automatically add skin tones as secondary callout actions to all single-component emojis that have them."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Localization-Support","text":"Localization Support"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory"},{"text":" enums can be localized in any locale that has translations:","type":"text"}]},{"code":["let emoji = Emoji(\"😀\") ","emoji.localizedName                   \/\/ Grinning Face","emoji.localizedName(in: .swedish)     \/\/ Leende Ansikte","","let category = EmojiCategory.animalsAndNature ","category.localizedName                \/\/ Animals & Nature","category.localizedName(in: .swedish)  \/\/ Djur och natur"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Take a look at "},{"code":"Resources\/en.lproj\/Localizable.strings","type":"codeVoice"},{"type":"text","text":" to see how you can localize emojis for more keyboard locales."}],"type":"paragraph"},{"level":2,"anchor":"String--Character-Extensions","text":"String & Character Extensions","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are String & Character extensions that can be used to detect and handle emojis, for instance:"}]},{"syntax":"swift","type":"codeListing","code":["\"Hello!\".containsEmoji           \/\/ false","\"Hello! 👋\".containsEmoji        \/\/ true","\"Hello! 👋\".containsOnlyEmojis   \/\/ false","\"Hello! 👋😀\".emojis             \/\/ [\"👋\", \"😀\"]"]},{"type":"thematicBreak"},{"anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2,"type":"heading","text":"👑 KeyboardKit Pro"},{"type":"paragraph","inlineContent":[{"type":"reference","overridingTitle":"KeyboardKit Pro","isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard"},{"type":"text","text":" that is automatically added to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":" when a Gold license is registered."}]},{"text":"Colon Search","type":"heading","level":3,"anchor":"Colon-Search"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit unlocks an ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji","isActive":true},{"text":".","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/ColonSearch","isActive":true},{"text":" search engine that makes it possible to search for emojis by starting the current word with a colon. This engine can be used by the local autocomplete service, to add emoji suggestions to the search result.","type":"text"}]},{"level":3,"anchor":"Views","type":"heading","text":"Views"},{"type":"tabNavigator","tabs":[{"title":"EmojiKeyboard","content":[{"type":"row","numberOfColumns":2,"columns":[{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"emojis-emojikeyboard","type":"image"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard","type":"reference","isActive":true},{"type":"text","text":" mimics a native emoji keyboard. It has support for categories, skin tones, callouts, etc."}]},{"type":"paragraph","inlineContent":[{"text":"The view can be styled with an emoji-specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/KeyboardStyle","isActive":true,"type":"reference"},{"text":", which can be applied with the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/emojiKeyboardStyle(_:)","isActive":true,"type":"reference"},{"type":"text","text":" view modifier. Use the builder-based style modifier to generate styles at runtime, based on the keyboard context."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This view requires a KeyboardKit Pro Gold license."}]}],"name":"Note","type":"aside","style":"note"}]}]}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Since SwiftUI’s grid views don’t deallocate cells, the emoji keyboard will allocate memory for each new emoji, but never deallocate any allocated memory. This leads to ever increasing memory consumption as your users swipe through categories. Due to this, the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiKeyboard","isActive":true,"type":"reference"},{"type":"text","text":" uses an "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emoji\/KeyboardStyle\/optimized(for:)","isActive":true},{"text":" style on iPhone, to save memory. If your keyboard uses too much base memory, you may however have to use the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/emojiKeyboardStyle(_:)","isActive":true,"type":"reference"},{"type":"text","text":" modifier to enforce using an optimized style on all devices. Just apply it to the keyboard view."}]}],"style":"important","type":"aside","name":"Important"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"This article describes the KeyboardKit