{"kind":"article","identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit lets you get the bundle ID of the host application that is using the keyboard. This may be of interest for many reasons, e.g. to vary the style or functionality of the keyboard based on the currently active app."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"👑 "},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","isActive":true},{"type":"text","text":" unlocks an additional "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplication","isActive":true,"type":"reference"},{"text":" type that defines many common apps and makes it easier to identify and navigate to specific apps. This lets you open the main app to perform a task, then return to the keyboard.","type":"text"}]},{"text":"Host Application Bundle Identifier","type":"heading","level":2,"anchor":"Host-Application-Bundle-Identifier"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"text":" has a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/hostApplicationBundleId"},{"text":" property that resolves the bundle ID of the app that is currently using the keyboard.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The controller will automatically sync this property to "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","type":"reference","isActive":true},{"type":"text","text":"’s auto-persisted "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/hostApplicationBundleId","isActive":true},{"text":" property, which can be used by your main app target to see in which app your keyboard was last used.","type":"text"}]},{"inlineContent":[{"text":"You can use the context’s’ ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/hostApplicationBundleIdSyncDate"},{"type":"text","text":" to check when the ID was last synced, to see if it’s still relevant. You can manually reset the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/hostApplicationBundleId","isActive":true},{"type":"text","text":" value if you know that it’s not, e.g. if the app launched without a deep link."}],"type":"paragraph"},{"level":2,"anchor":"Host-Application","text":"Host Application","type":"heading"},{"inlineContent":[{"text":"KeyboardKit Pro unlocks ways to identify specific apps, using a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplication","isActive":true},{"text":" type that defines many popular apps.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro adds a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplicationProvider\/hostApplication"},{"type":"text","text":" property to the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","type":"reference"},{"type":"text","text":", which maps the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/hostApplicationBundleId"},{"type":"text","text":" to any of the following known applications:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Amazon Prime, App Store, Apple Calendar, Apple Clock, Apple FaceTime, Apple Files, Apple Health, Apple Maps, Apple Messages, Apple Music, Apple Notes, Apple Numbers, Apple Pages, Apple Photos, Apple Podcasts, Apple Reminders, Apple Settings, Apple Shortcuts, Apple Translate, Apple TV, Apple Weather, Blue Sky, Brave, Bolt, ChatGPT, Discord, Disney+, Facebook, Gmail, Goodnotes, Google Assistant, Google Calendar, Google Chat, Google Chrome, Google Docs, Google Drive, Google Home, Google Maps, Instagram, Ivory, KeyboardKit Demo, LinkedIn, Meetup, Messenger, Microsoft OneDrive, Netflix, Signal, Slack, Snapchat, Spotify, Telegram, Trello, Twitch, X (Twitter), WhatsApp, Uber, YouTube","type":"text"}]},{"inlineContent":[{"type":"text","text":"Once you have resolved a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplication","isActive":true},{"type":"text","text":", you can open it with "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplication\/openWithAction(_:)","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardHostApplication\/openWithActionHandler(_:)"},{"type":"text","text":" and access additional information about the app from the app value."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/host-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/host-article"]}],"abstract":[{"text":"This article describes how KeyboardKit Pro can ident