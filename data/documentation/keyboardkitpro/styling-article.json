is currently required for more complex views."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","isActive":true,"type":"reference"},{"text":" is a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"static","type":"text"}]},{"type":"text","text":" style provider that can define, reuse and share styles."}],"type":"paragraph"}]}]},{"text":"KeyboardStyle namespace","anchor":"KeyboardStyle-namespace","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle","type":"reference","isActive":true},{"text":" namespace that contains style-related types.","type":"text"}]},{"type":"heading","anchor":"Keyboard-style-providers","text":"Keyboard style providers","level":2},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleProvider","isActive":true,"type":"reference"},{"type":"text","text":" is used to return dynamic styles for different parts of the keyboard. Unlike static styles, a style provider can vary styles depending on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"type":"text","text":", "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"type":"text","text":", etc."}]},{"type":"paragraph","inlineContent":[{"text":"More complex components, like ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard"},{"text":", does not yet use view modifiers, but instead use a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleProvider","type":"reference","isActive":true},{"text":" to apply dynamic, contextual, styles based on internal and external state.","type":"text"}]},{"inlineContent":[{"text":"KeyboardKit automatically creates an instance of ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardProvider","isActive":true},{"text":" and injects it into ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","type":"reference","isActive":true},{"type":"text","text":". You can replace it at any time, as described further down."}],"type":"paragraph"},{"name":"Important","content":[{"inlineContent":[{"text":"Views like ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard","isActive":true},{"text":" will apply style modifiers to any view that it renders. This means that you can’t apply these view modifiers to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SystemKeyboard"},{"type":"text","text":". You can however apply style modifiers to views that you create in view builders."}],"type":"paragraph"}],"type":"aside","style":"important"},{"level":2,"anchor":"Resources--Assets","type":"heading","text":"Resources & Assets"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit comes with colors and assets that can be used to create native-looking keyboards.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUI\/Color","type":"reference"},{"type":"text","text":" has a bunch of keyboard-specific colors, like "