{"kind":"article","abstract":[{"type":"text","text":"This article describes the KeyboardKit styling engine."}],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Styling-Article","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"title":"Articles","identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AI-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Device-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emojis-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/External-Keyboards-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Gestures-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Layout-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Localization-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Navigation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Previews-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Settings-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Status-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"],"anchor":"Articles"}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"While native iOS keyboards provide no way to customize the look & feel of the keyboard, KeyboardKit keyboards can be to great extent."}]},{"inlineContent":[{"type":"text","text":"Most KeyboardKit views have a corresponding "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View","isActive":true},{"type":"text","text":" modifier that lets you apply a custom style. You can also use a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true},{"text":" to style more complex views, like the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"👑 ","type":"text"},{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"text":" unlocks a theme engine and many pre-defined themes. Information about Pro features can be found further down.","type":"text"}],"type":"paragraph"},{"anchor":"Namespace","type":"heading","text":"Namespace","level":2},{"inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle","type":"reference","isActive":true},{"text":" namespace that contains style-related types.","type":"text"}],"type":"paragraph"},{"text":"Services","anchor":"Services","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"In KeyboardKit, a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true},{"type":"text","text":" can provide dynamic styles for different parts of a keyboard. Unlike static styles, a style service can vary styles depending on "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true},{"type":"text","text":", etc."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit injects a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","isActive":true,"type":"reference"},{"type":"text","text":" into "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":" when the keyboard is launched. You can replace it at any time, as described further down.","type":"text"}],"type":"paragraph"},{"text":"Color & Image Extensions","level":2,"type":"heading","anchor":"Color--Image-Extensions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit defines additional, keyboard-specific "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image","isActive":true,"type":"reference"},{"text":" extensions, like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color\/keyboardBackground","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboard","isActive":true},{"type":"text","text":", etc. to make it easy to create keyboards that look like a native iOS keyboard."}]},{"type":"row","columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"styling-images"}],"type":"paragraph"}],"size":1},{"size":1,"content":[{"inlineContent":[{"identifier":"styling-colors","type":"image"}],"type":"paragraph"}]}],"numberOfColumns":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit defines contextual colors that take a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true,"type":"reference"},{"type":"text","text":", like "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color\/keyboardBackground(for:)","isActive":true,"type":"reference"},{"type":"text","text":". These colors vary the color result based on the context. Prefer these context-based colors whenever possible."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit defines variable-based icons like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboardNewline","isActive":true,"type":"reference"},{"text":", which make it easy to use them as toggles and indicators.","type":"text"}]},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":"Some keyboard colors are semi-transparent to work around a system bug in iOS, where iOS defines an invalid color scheme when a keyboard is used with a dark appearance text field in light mode. iOS will say that the color scheme is "},{"code":".dark","type":"codeVoice"},{"text":", even if the system color scheme is light. Since dark appearance keyboards in light mode look quite different from keyboards in dark mode, this makes it impossible to apply the correct style. This has been ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit\/issues\/305"},{"type":"text","text":", but until it’s fixes, thse colors will stay semi-transparent."}],"type":"paragraph"}],"type":"aside","style":"important"},{"anchor":"Type-Extensions","text":"Type Extensions","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Many types in the library define standard images, texts & colors. You can for instance get the standard image and text for a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"type":"text","text":" with the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","type":"reference","isActive":true},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)"},{"type":"text","text":":"}]},{"syntax":"swift","code":["let context = KeyboardContext()","let image = KeyboardAction.command.standardButtonImage(for: context) \/\/ Command icon","let text = KeyboardAction.space.standardButtonText(for: context)     \/\/ KKL10n.space"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"These values can be overridden at any time, e.g. with the various view styles, by defining a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"type":"text","text":", etc."}]},{"type":"heading","anchor":"Style-Modifiers","level":2,"text":"Style Modifiers"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit defines custom styles for its various view. For instance, the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","type":"reference","isActive":true},{"text":" view has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/ButtonStyle","isActive":true,"type":"reference"},{"type":"text","text":" that can be applied with the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardButtonStyle(_:)","type":"reference"},{"text":" view modifier.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most views have static, standard styles that can be replaced by custom styles to change the global default style for that particular view."}]},{"type":"thematicBreak"},{"level":2,"type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro"},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro"},{"type":"text","text":" unlocks additional image assets, and a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","isActive":true,"type":"reference"},{"type":"text","text":" engine that makes easier to style keyboards with themes."}]},{"anchor":"Emoji-Icons","level":3,"type":"heading","text":"Emoji Icons"},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"images-emojis"}],"type":"paragraph"}],"size":1},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro unlocks vectorized emoji assets for all "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory"},{"type":"text","text":"s, e.g. "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboardEmoji","isActive":true},{"text":" & ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/emojiCategory(_:)","type":"reference","isActive":true},{"type":"text","text":":"}]},{"inlineContent":[{"text":"Since these images are vectorized, they scale well when they are resized. They however do not support different font weights, so do not render them alongside SF Symbols that support such features.","type":"text"}],"type":"paragraph"}]}]},{"text":"Themes","type":"heading","anchor":"Themes","level":3},{"inlineContent":[{"text":"KeyboardKit Pro unlocks a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","type":"reference","isActive":true},{"type":"text","text":" engine that makes easier to style keyboards with themes, as well as a bunch of themes:"}],"type":"paragraph"},{"numberOfColumns":3,"columns":[{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"standard-green"}]}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"swifty-blue"}]}],"size":1},{"size":1,"content":[{"inlineContent":[{"identifier":"candyshop-cottoncandy","type":"image"}],"type":"paragraph"}]}],"type":"row"},{"inlineContent":[{"text":"You can apply themes with a style-specific ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"text":". Future versions of KeyboardKit will also let you apply themes with a view modifier. See the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"},{"text":" article for more information.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"anchor":"How-to","type":"heading","text":"How to…","level":2},{"type":"heading","level":3,"text":"…create a custom style service","anchor":"create-a-custom-style-service"},{"inlineContent":[{"type":"text","text":"You can create a custom style service to customize styles in any way you want. You can implement "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","type":"reference","isActive":true},{"text":" from scratch, or inherit and customize ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class CustomKeyboardStyleService: KeyboardStyle.StandardStyleService {","    ","    override func buttonStyle(","        for action: KeyboardAction,","        isPressed: Bool","    ) -> Keyboard.ButtonStyle {","        let style = super.buttonStyle(for: action, isPressed: isPressed)","        if !action.isInputAction { return style }","        style.backgroundColor = .red","        return style","    }","}"]},{"inlineContent":[{"text":"To use your custom service instead of the standard one, just inject it into ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"type":"text","text":" by replacing its "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/styleService","isActive":true},{"type":"text","text":" property:"}],"type":"paragraph"},{"syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        keyboardStyleService = CustomKeyboardStyleService()","        super.viewDidLoad()","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"This will make KeyboardKit use your custom implementation instead of the standard one.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/styling-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/styling-article"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"metadata":{"title":"Styling","images":[{"identifier":"Page.png","type":"card"}],"role":"article","roleHeading":"Article","modules":[{"name":"KeyboardKitPro"}]},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Device-Article":{"url":"\/documentation\/keyboardkitpro\/device-article","abstract":[{"text":"This article describes the KeyboardKit device utilities.","type":"text"}],"title":"Device Utilities","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Device-Article","kind":"article","images":[{"type":"card","identifier":"Page.png"}],"type":"topic","role":"article"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Dictation-Article":{"images":[{"type":"card","identifier":"Page.png"}],"type":"topic","title":"Dictation","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","url":"\/documentation\/keyboardkitpro\/dictation-article","kind":"article","abstract":[{"type":"text","text":"This article describes the KeyboardKit dictation engine."}],"role":"article"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Callouts-Article":{"images":[{"identifier":"Page.png","type":"card"}],"title":"Callouts","url":"\/documentation\/keyboardkitpro\/callouts-article","role":"article","a