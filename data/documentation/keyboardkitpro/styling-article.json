:"text","text":"In KeyboardKit, a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"type":"text","text":" can provide dynamic styles for different parts of a keyboard. Unlike static styles, a style service can vary styles depending on "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction"},{"type":"text","text":", etc."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"KeyboardKit injects a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","isActive":true},{"type":"text","text":" into "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true},{"type":"text","text":" when the keyboard is launched. You can replace it at any time, as described further down."}],"type":"paragraph"},{"anchor":"Color--Image-Extensions","type":"heading","level":2,"text":"Color & Image Extensions"},{"inlineContent":[{"text":"KeyboardKit defines additional, keyboard-specific ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image","isActive":true},{"text":" extensions, like ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color\/keyboardBackground","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboard","isActive":true},{"text":", etc. to make it easy to create keyboards that look like a native iOS keyboard.","type":"text"}],"type":"paragraph"},{"numberOfColumns":2,"type":"row","columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"styling-images"}],"type":"paragraph"}],"size":1},{"content":[{"inlineContent":[{"identifier":"styling-colors","type":"image"}],"type":"paragraph"}],"size":1}]},{"inlineContent":[{"text":"KeyboardKit defines contextual colors that take a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"text":", like ","type":"text"},{"code":"keyboardBackground(for:)","type":"codeVoice"},{"text":". These colors vary the color result based on the context. Prefer these context-based colors whenever possible.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"KeyboardKit defines variable-based icons like ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboardNewline","isActive":true,"type":"reference"},{"text":", which make it easy to use them as toggles and indicators.","type":"text"}],"type":"paragraph"},{"style":"important","name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Some keyboard colors are semi-transparent to work around a system bug in iOS, where iOS defines an invalid color scheme when a keyboard is used with a dark appearance text field in light mode. iOS will say that the color scheme is "},{"code":".dark","type":"codeVoice"},{"type":"text","text":", even if the system color scheme is light. Since dark appearance keyboards in light mode look quite different from keyboards in dark mode, this makes it impossible to apply the correct style. This has been "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit\/issues\/305"},{"type":"text","text":", but until it’s fixes, thse colors will stay semi-transparent."}],"type":"paragraph"}]},{"anchor":"Type-Extensions","type":"heading","level":2,"text":"Type Extensions"},{"inlineContent":[{"type":"text","text":"Many types in the library define standard images, texts & colors. You can for instance get the standard image and text for a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true},{"type":"text","text":" with the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let context = KeyboardContext()","let image = KeyboardAction.command.standardButtonImage(for: context) \/\/ Command icon","let text = KeyboardAction.space.standardButtonText(for: context)     \/\/ KKL10n.space"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"These values can be overridden at any time, e.g. with the various view styles, by defining a custom "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true},{"type":"text","text":", etc."}],"type":"paragraph"},{"anchor":"Style-Modifiers","type":"heading","level":2,"text":"Style Modifiers"},{"inlineContent":[{"text":"KeyboardKit defines custom styles for its various view. For instance, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","type":"reference"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","type":"reference"},{"text":" view has a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/ButtonStyle","type":"reference"},{"text":" that can be applied with the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardButtonStyle(_:)","type":"reference"},{"text":" view modifier.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Most views have static, standard styles that can be replaced by custom styles to change the global default style for that particular view."}],"type":"paragraph"},{"type":"thematicBreak"},{"anchor":"%F0%9F%91%91-KeyboardKit-Pro","type":"heading","level":2,"text":"👑 KeyboardKit Pro"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}]},{"text":" unlocks additional image assets, and a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme"},{"text":" engine that makes easier to style keyboards with themes.","type":"text"}],"type":"paragraph"},{"anchor":"Emoji-Icons","type":"heading","level":3,"text":"Emoji Icons"},{"numberOfColumns":2,"type":"row","columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"images-emojis"}],"type":"paragraph"}],"size":1},{"content":[{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro unlocks vectorized emoji assets for all ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory","type":"reference"},{"text":"s, e.g. ","type":"text"},{"isActiv