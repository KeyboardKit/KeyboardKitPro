umentation\/KeyboardKitPro\/Previews-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Settings-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Status-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"],"generated":true}],"kind":"article","primaryContentSections":[{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"While native iOS keyboards provide no way to customize the look & feel of the keyboard, KeyboardKit keyboards can be to great extent."}]},{"inlineContent":[{"text":"Most KeyboardKit views have a corresponding ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View","type":"reference"},{"type":"text","text":" modifier that lets you apply a custom style. You can also use a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"type":"text","text":" to style more complex views, like the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"👑 "},{"type":"reference","isActive":true,"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks a theme engine and many pre-defined themes. Information about Pro features can be found further down."}],"type":"paragraph"},{"text":"Namespace","type":"heading","anchor":"Namespace","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle","isActive":true},{"type":"text","text":" namespace that contains style-related types."}],"type":"paragraph"},{"anchor":"Services","level":2,"text":"Services","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In KeyboardKit, a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"type":"text","text":" can provide dynamic styles for different parts of a keyboard. Unlike static styles, a style service can vary styles depending on "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction"},{"text":", etc.","type":"text"}]},{"inlineContent":[{"type":"text","text":"KeyboardKit injects a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","isActive":true},{"type":"text","text":" into "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services"},{"text":" when the keyboard is launched. You can replace it at any time, as described further down.","type":"text"}],"type":"paragraph"},{"anchor":"Color--Image-Extensions","level":2,"text":"Color & Image Extensions","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit defines additional, keyboard-specific ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color","isActive":true},{"type":"text","text":" and "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image","type":"reference"},{"type":"text","text":" extensions, like "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color\/keyboardBackground","isActive":true,"type":"reference"},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboard","isActive":true},{"text":", etc. to make it easy to create keyboards that look like a native iOS keyboard.","type":"text"}]},{"type":"row","numberOfColumns":2,"columns":[{"content":[{"inlineContent":[{"type":"image","identifier":"styling-images"}],"type":"paragraph"}],"size":1},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"styling-colors","type":"image"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit defines contextual colors that take a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true,"type":"reference"},{"text":", like ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Color\/keyboardBackground(for:)","type":"reference"},{"type":"text","text":". These colors vary the color result based on the context. Prefer these context-based colors whenever possible."}]},{"inlineContent":[{"text":"KeyboardKit defines variable-based icons like ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboardNewline","isActive":true},{"text":", which make it easy to use them as toggles and indicators.","type":"text"}],"type":"paragraph"},{"name":"Important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Some keyboard colors are semi-transparent to work around a system bug in iOS, where iOS defines an invalid color scheme when a keyboard is used with a dark appearance text field in light mode. iOS will say that the color scheme is ","type":"text"},{"type":"codeVoice","code":".dark"},{"type":"text","text":", even if the system color scheme is light. Since dark appearance keyboards in light mode look quite different from keyboards in dark mode, this makes it impossible to apply the correct style. This has been "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKit\/issues\/305"},{"text":", but until it’s fixes, thse colors will stay semi-transparent.","type":"text"}]}],"style":"important"},{"anchor":"Type-Extensions","type":"heading","level":2,"text":"Type Extensions"},{"inlineContent":[{"type":"text","text":"Many types in the library define standard images, texts & colors. You can for instance get the standard image and text for a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction","isActive":true,"type":"reference"},{"type":"text","text":" with the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonImage(for:)","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardAction\/standardButtonText(for:)"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let context = KeyboardContext()","let image = KeyboardAction.command.standardButtonImage(for: context) \/\/ Command icon","let text = KeyboardAction.space.standardButtonText(for: context)     \/\/ KKL10n.space"]},{"type":"paragraph","inlineContent":[{"text":"These values can be overridden at any time, e.g. with the various view styles, by defining a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"type":"text","text":", etc."}]},{"type":"heading","level":2,"text":"Style Modifiers","anchor":"Style-Modifiers"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit defines custom styles for its various view. For instance, the "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard","type":"reference"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Button","isActive":true,"type":"reference"},{"text":" view has a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/ButtonStyle","type":"reference","isActive":true},{"type":"text","text":" that can be applied with the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/keyboardButtonStyle(_:)","isActive":true},{"type":"text","text":" view modifier."}]},{"inlineContent":[{"text":"Most views have static, standard styles that can be replaced by custom styles to change the global default style for that particular view.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"type":"heading","text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}],"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro"},{"text":" unlocks additional image assets, and a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme"},{"type":"text","text":" engine that makes easier to style keyboards with themes."}]},{"type":"heading","anchor":"Emoji-Icons","text":"Emoji Icons","level":3},{"columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"images-emojis","type":"image"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"KeyboardKit Pro unlocks vectorized emoji assets for all ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/EmojiCategory"},{"type":"text","text":"s, e.g. "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/keyboardEmoji","isActive":true,"type":"reference"},{"type":"text","text":" & "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/Image\/emojiCategory(_:)","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since these images are vectorized, they scale well when they are resized. They however do not support different font weights, so do not render them alongside SF Symbols that support such features."}],"type":"paragraph"}],"size":1}],"type":"row","numberOfColumns":2},{"text":"Themes","type":"heading","level":3,"anchor":"Themes"},{"inlineContent":[{"text":"KeyboardKit Pro unlocks a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTheme","type":"reference","isActive":true},{"text":" engine that makes easier to style keyboards with themes, as well as a bunch of themes:","type":"text"}],"type":"paragraph"},{"type":"row","numberOfColumns":3,"columns":[{"size":1,"content":[{"inlineContent":[{"identifier":"standard-green","type":"image"}],"type":"paragraph"}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"identifier":"swifty-blue","type":"image"}]}]},{"size":1,"content":[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"candyshop-cottoncandy"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"You can apply themes with a style-specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","isActive":true,"type":"reference"},{"type":"text","text":". Future versions of KeyboardKit will also let you apply themes with a view modifier. See the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article","isActive":true},{"text":" article for more information.","type":"text"}]},{"type":"thematicBreak"},{"anchor":"How-to","level":2,"type":"heading","text":"How to…"},{"text":"…create a custom style service","anchor":"create-a-custom-style-service","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create a custom style service to customize styles in any way you want. You can implement "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService","type":"reference"},{"type":"text","text":" from scratch, or inherit and customize "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","type":"reference","isActive":true},{"type":"text","text":":"}]},{"code":["class CustomKeyboardStyleService: KeyboardStyle.StandardStyleService {","    ","    override func buttonStyle(","        for action: KeyboardAction,","        isPressed: Bool","    ) -> Keyboard.ButtonStyle {","        let style = super.buttonStyle(for: action, isPressed: isPressed)","        if !action.isInputAction { return style }","        style.backgroundColor = .red","        return style","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"To use your custom service instead of the standard one, just inject it into ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"type":"text","text":" by replacing its "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/styleService","type":"reference","isActive":true},{"type":"text","text":" property:"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        keyboardStyleService = CustomKeyboardStyleService()","        super.viewDidLoad()","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This will make KeyboardKit use your custom implementation instead of the standard one.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"This article describes the KeyboardKit styling engine."}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardStyle/StandardStyleService":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StandardStyleService","kind":"identifier"}],"kind":"symbol","type":"topic","role":"symbol","title":"KeyboardStyle.StandardStyleService","abstract":[{"text":"This class provides a standard way to create dynamic","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"keyboard styles."}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyle\/StandardStyleService","navigatorTitle":[{"kind":"identifier","text":"StandardStyleService"}],"url":"\/documentation\/keyboardkitpro\/keyboardstyle\/standardstyleservice"},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/SwiftUICore/Color/keyboardBackground":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"keyboardBackground","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Color","kind":"typeIdentifier","preciseIdentifier":"s:7SwiftUI5ColorV"}],"kind":"s