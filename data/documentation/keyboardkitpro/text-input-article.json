m.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" has a custom "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textInputProxy","isActive":true,"type":"reference"},{"type":"text","text":" that can be set to automatically route text to any other text field or custom proxy."}]},{"type":"paragraph","inlineContent":[{"text":"Just set ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textInputProxy","isActive":true,"type":"reference"},{"type":"text","text":" to start routing text to that proxy, and set it to nil to resume routing text to the active application. You can always access the original proxy with "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"👑 "},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","isActive":true},{"type":"text","text":" unlocks a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"text":" and a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"type":"text","text":" that both automatically register and unregister as input proxy when they get and lose focus. Information about Pro features can be found at the end of this article."}]},{"type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2,"text":"👑 KeyboardKit Pro"},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"isActive":true,"overridingTitle":"KeyboardKit Pro","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference"},{"text":" unlocks text input components that automatically register and unregister themselves as the main text input proxy when they receive and lose focus.","type":"text"}]},{"type":"heading","level":2,"text":"Views","anchor":"Views"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","isActive":true},{"text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension.","type":"text"}]}],"title":"KeyboardTextField"},{"title":"KeyboardTextView","content":[{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView"},{"type":"text","text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension."}],"type":"paragraph"}]}],"type":"tabNavigator"},{"inlineContent":[{"text":"Both views support ","type":"text"},{"type":"codeVoice","code":"@FocusState"},{"text":", and have a custom ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)","type":"reference","isActive":true},{"type":"text","text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:"}],"type":"paragraph"},{"syntax":"swift","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"],"type":"codeListing"},{"name":"Tip","style":"tip","type":"aside","content":[{"inlineContent":[{"text":"The default ","type":"text"},{"code":".onSubmit { ... }","type":"codeVoice"},{"text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in ","type":"text"},{"type":"codeVoice","code":"onSubmit:"},{"type":"text","text":" in the initializer."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"These views require at least a "},{"type":"codeVoice","code":"Silver"},{"text":" license. They also require Full Access, due to an iOS bug that causes a crash when using them while Full Access is disabled. They will automatically disable themselves when Full Access is disabled.","type":"text"}]}],"type":"aside","style":"important","name":"Important"}]}],"variants":[{"paths":["\/documentation\/keyboardkitpro\/text-input-article"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/keyboardkitpro\/text-input-article"],"traits":[{"interfaceLanguage":"occ"}]}],"kind":"article","abstract":[{"type":"text","text":"This article describes the KeyboardKit text input engine, which lets you type within the keyboard extension."}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardTextView":{"kind":"symbol","abstract":[{"text":"This view can be used to type within keyb