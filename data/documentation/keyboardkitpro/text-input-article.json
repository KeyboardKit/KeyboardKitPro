text will still be sent to the currently active app.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"These limitations make it hard to implement features that require text input in the keyboard, like emoji search, and AI-based features."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit adds ways to make text routing easier. ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController"},{"text":" has a custom ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textInputProxy","isActive":true},{"text":" that can be set to automatically route text to any other text field or custom proxy.","type":"text"}]},{"inlineContent":[{"type":"text","text":"👑 "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" unlocks a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"type":"text","text":" that automatically registers and unregisters as the input proxy when it gets and loses focus. Information about Pro features can be found at the end of this article."}],"type":"paragraph"},{"level":2,"anchor":"How-to-route-text-with-KeyboardKit","type":"heading","text":"How to route text with KeyboardKit"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController","isActive":true},{"type":"text","text":" has a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textInputProxy"},{"text":" that can be set to override ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy","isActive":true,"type":"reference"},{"type":"text","text":" as the main text document proxy. Setting it will cause any text you type to be sent to that proxy instead of the original one."}]},{"inlineContent":[{"text":"Just set ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textInputProxy"},{"type":"text","text":" to nil to restore the original proxy and resume routing text to the main application. You can always access the original proxy with "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","anchor":"👑-KeyboardKit-Pro","text":"👑 KeyboardKit Pro","level":2},{"inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","overridingTitle":"KeyboardKit Pro","isActive":true,"type":"reference","overridingTitleInlineContent":[{"text":"KeyboardKit Pro","type":"text"}]},{"text":" unlocks text input components that automatically register and unregister themselves as the main text input proxy when they receive and lose focus.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Views","type":"heading","text":"Views"},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","isActive":true,"type":"reference"},{"text":" component wraps a native text field and can be used for single-line text inputs.","type":"text"}],"type":"paragraph"}],"title":"KeyboardTextField"},{"title":"KeyboardTextView","content":[{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView"},{"type":"text","text":" component wraps a native text view and can be used for multi-line text inputs."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that you can use "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"type":"text","text":" for both single- & multi-line text inputs in later versions of iOS. "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","type":"reference"},{"text":" will be deprecated in a future version of KeyboardKit.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both views support "},{"code":"@FocusState","type":"codeVoice"},{"text":", and have a custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUI\/View\/focused(_:doneButton:)"},{"type":"text","text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:"}]},{"syntax":"swift","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"],"type":"codeListing"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The default ","type":"text"},{"type":"codeVoice","code":".onSubmit { ... }"},{"type":"text","text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in "},{"code":"onSubmit:","type":"codeVoice"},{"text":" in the initializer.","type":"text"}]}],"style":"note"},{"content":[{"inlineContent":[{"type":"text","text":"This view requires Full Access and will automatically disable itself when it’s disabled, due to an iOS bug that causes a crash when using text field while Full Access is disabled."}],"type":"paragraph"}],"style":"important","name":"Important","type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Callouts-Article":{"kind":"article","images":[{"type":"card","identifier":"Page.png"}],"title":"Callouts","role":"article","type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","url":"\/documentation\/keyboardkitpro\/callouts-article","abstract":[{"type":"text","text":"This article describes the KeyboardKit callout engine."}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Localization-Article":{"kind":"article","images":[{"identifier":"Page.png","type":"card"}],"title":"Localization","role":"article","type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Localization-Article","abstract":[{"text":"This article describes the KeyboardKit localization engine.","type":"text"