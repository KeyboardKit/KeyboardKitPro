},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit adds ways to make text routing easier. For instance, "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true},{"type":"text","text":" has a custom "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true},{"type":"text","text":" that can be set to route text to any other text field or custom proxy."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Just set "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true},{"type":"text","text":" to start typing to that proxy, and set it to nil to resume typing into the active application. The controller’s "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy"},{"type":"text","text":" will point to this property if set. You can access the original proxy with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy"},{"text":".","type":"text"}]},{"text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2,"type":"heading"},{"inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","type":"reference","isActive":true},{"text":" unlocks a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference","isActive":true},{"text":" and a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true,"type":"reference"},{"text":" that both automatically register and unregister as input proxy when they get and lose focus.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Views","type":"heading","text":"Views"},{"type":"tabNavigator","tabs":[{"title":"KeyboardTextField","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"type":"text","text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension."}]}]},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true,"type":"reference"},{"type":"text","text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension."}],"type":"paragraph"}],"title":"KeyboardTextView"}]},{"type":"paragraph","inlineContent":[{"text":"Both views support ","type":"text"},{"type":"codeVoice","code":"@FocusState"},{"type":"text","text":", and have a custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)"},{"text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"]},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The default "},{"code":".onSubmit { ... }","type":"codeVoice"},{"type":"text","text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in "},{"code":"onSubmit:","type":"codeVoice"},{"text":" in the initializer.","type":"text"}]}]},{"style":"important","type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"These views require at least a "},{"code":"Silver","type":"codeVoice"},{"text":" license. They also require Full Access, due to an iOS bug that causes a crash when using them while Full Access is disabled. They will automatically disable themselves when Full Access is disabled.","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/UIKit/UITextDocumentProxy":{"type":"topic","title":"UITextDocumentProxy","url":"\/documentation\/keyboardkitpro\/uikit\/uitextdocumentproxy","abstract":[],"role":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","navigatorTitle":[{"text":"UITextDocumentProxy","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"extension","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"c:objc(pl)UITextDocumentProxy","kind":"identifier","text":"UITextDocumentProxy"}]},"https://github.com/KeyboardKit/KeyboardKitPro":{"identifier":"https:\/\/github.com\/KeyboardKit\/Ke