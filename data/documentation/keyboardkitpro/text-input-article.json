{"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"iOS keyboard extensions use a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","type":"reference","isActive":true},{"type":"text","text":" to insert and delete text, move the text input cursor, etc. This proxy will by default point to the currently selected text field in the currently active app."}]},{"type":"paragraph","inlineContent":[{"text":"Keyboard extensions will by default only send text to this proxy, and will ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"emphasis"},{"type":"text","text":" detect if you select a text field inside the keyboard. Even if you focus on a text field within the keyboard, text will still be sent to the text document proxy."}]},{"inlineContent":[{"type":"text","text":"These limitations make it hard to implement features that require text input in the keyboard, like emoji search, and AI-based features. KeyboardKit adds ways to make text routing easier."}],"type":"paragraph"},{"anchor":"Text-Input","type":"heading","level":2,"text":"Text Input"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit adds ways to make text routing easier. For instance, "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true},{"type":"text","text":" has a custom "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","type":"reference","isActive":true},{"type":"text","text":" that can be set to route text to any other text field or custom proxy."}]},{"type":"paragraph","inlineContent":[{"text":"Just set ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","type":"reference","isActive":true},{"text":" to start typing to that proxy, and set it to nil to resume typing into the active application. The controller’s ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy"},{"text":" will point to this property if set. You can access the original proxy with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy"},{"type":"text","text":"."}]},{"type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2,"text":"👑 KeyboardKit Pro"},{"inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"text":" unlocks a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference","isActive":true},{"type":"text","text":" and a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"type":"text","text":" that both automatically register and unregister as input proxy when they get and lose focus."}],"type":"paragraph"},{"type":"heading","level":3,"text":"Views","anchor":"Views"},{"tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField"},{"text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension.","type":"text"}]}],"title":"KeyboardTextField"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"type":"text","text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension."}]}],"title":"KeyboardTextView"}],"type":"tabNavigator"},{"inlineContent":[{"type":"text","text":"Both views support "},{"code":"@FocusState","type":"codeVoice"},{"type":"text","text":", and have a custom "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)"},{"type":"text","text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:"}],"type":"paragraph"},{"syntax":"swift","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"],"type":"codeListing"},{"type":"aside","style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"The default ","type":"text"},{"type":"codeVoice","code":".onSubmit { ... }"},{"type":"text","text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in "},{"type":"codeVoice","code":"onSubmit:"},{"text":" in the initializer.","type":"text"}]}]},{"style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"These views require at least a "},{"code":"Silver","type":"codeVoice"},{"type":"text","text":" license. They also require Full Access, due to an iOS bug that causes a crash when using them while Full Access is disabled. They will automatically disable themselves when Full Access is disabled."}]}],"name":"Important"}]}],"metadata":{"role":"article","title":"Text Input","images":[{"type":"card","identifier":"Page.png"}],"roleHeading":"Article","modules":[{"name":"KeyboardKitPro"}]},"sections":[],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This article describes the KeyboardKit text input engine, which lets you type within the keyboard extension."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AI-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Device-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emojis-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKi