eading","text":"Text Input"},{"inlineContent":[{"text":"KeyboardKit adds ways to make text routing easier. For instance, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext"},{"type":"text","text":" has a custom "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy"},{"text":" that can be set to route text to any other text field or custom proxy.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Just set ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true},{"type":"text","text":" to start typing to that proxy, and set it to nil to resume typing into the active application. The controller’s "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy","type":"reference"},{"text":" will point to this property if set. You can access the original proxy with ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks a "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"type":"text","text":" and a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"type":"text","text":" that both automatically register and unregister as input proxy when they get and lose focus."}]},{"type":"heading","text":"Views","level":3,"anchor":"Views"},{"type":"tabNavigator","tabs":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","isActive":true},{"type":"text","text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension."}]}],"title":"KeyboardTextField"},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension.","type":"text"}],"type":"paragraph"}],"title":"KeyboardTextView"}]},{"type":"paragraph","inlineContent":[{"text":"Both views support ","type":"text"},{"code":"@FocusState","type":"codeVoice"},{"type":"text","text":", and have a custom "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)","isActive":true,"type":"reference"},{"type":"text","text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"]},{"content":[{"inlineContent":[{"type":"text","text":"The default "},{"type":"codeVoice","code":".onSubmit { ... }"},{"text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in ","type":"text"},{"type":"codeVoice","code":"onSubmit:"},{"type":"text","text":" in the initializer."}],"type":"paragraph"}],"style":"tip","type":"aside","name":"Tip"},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"These views require at least a "},{"type":"codeVoice","code":"Silver"},{"text":" license. They also require Full Access, due to an iOS bug that causes a crash when using them while Full Access is disabled. They will automatically disable themselves when Full Access is disabled.","type":"text"}]}],"style":"important","type":"aside"}]}],"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/KeyboardTextField":{"url":"\/documentation\/keyboardkitpro\/keyboardtextfield","role":"symbol","title":"KeyboardTextField","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"KeyboardTextField"}],"abstract":[{"text":"This view can be used to type within keyboard extensions.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"KeyboardTextField"}],"kind":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"topic"},"doc://com.ke