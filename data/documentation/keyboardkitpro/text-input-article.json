{"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom iOS keyboards use a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true,"type":"reference"},{"type":"text","text":" to modify text, move the input cursor, provide input-related information, etc."}]},{"type":"paragraph","inlineContent":[{"text":"This proxy will by default point to the currently selected text field in the currently active app, and will ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"type":"text","text":" detect if you select a text field inside the keyboard. Even if you focus on a text field within the keyboard, text will still be sent to the text field in the currently active app."}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro unlocks text input views that let you type directly within a custom keyboard extension. This makes it easy to implement text-based features, like search, AI prompting, etc.","type":"text"}]},{"level":2,"text":"Text Input","anchor":"Text-Input","type":"heading"},{"inlineContent":[{"text":"KeyboardKit adds ways to make text routing easier. For instance, ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","type":"reference","isActive":true},{"type":"text","text":" has a custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy"},{"text":" that can be set to route text to any other text field or custom proxy.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true},{"type":"text","text":" to any custom proxy to start routing text to that proxy instead of the currently active app, and set it to nil to resume using the active app. You can always access the original text document proxy with "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy","isActive":true},{"type":"text","text":"."}]},{"type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro","level":2},{"inlineContent":[{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true,"type":"reference"},{"type":"text","text":" unlocks a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true},{"type":"text","text":" that automatically register themselves as "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","isActive":true,"type":"reference"},{"type":"text","text":" when they get focus. Use them to type directly within a keyboard extension without any additional code."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro also unlocks additional ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextInput","isActive":true},{"type":"text","text":" support, like "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextInput\/Vietnamese","isActive":true,"type":"reference"},{"text":", to let you to type in locale-specific ways.","type":"text"}]},{"level":3,"anchor":"%F0%9F%87%BB%F0%9F%87%B3-Vietnamese-BETA","text":"🇻🇳 Vietnamese (BETA)","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit Pro unlocks support for ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextInput\/Vietnamese","isActive":true},{"text":" TELEX, VIQR, and VNI. This support is based on Vietnamese-specific ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Diacritic"},{"text":" values and locale-specific types in the Vietnamese namespace.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro will automatically use Vietnamese input when applicable. You can use the Vietnamese-specific diacritics and types as standalone features to implement Vietnamese typing support elsewhere."}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Vietnamese typing support requires at least a "},{"type":"codeVoice","code":"Silver"},{"type":"text","text":" license."}]}]},{"type":"heading","anchor":"Views","text":"Views","level":3},{"type":"tabNavigator","tabs":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField"},{"type":"text","text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension."}],"type":"paragraph"}],"title":"KeyboardTextField"},{"title":"KeyboardTextView","content":[{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","isActive":true,"type":"reference"},{"text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Both views support ","type":"text"},{"code":"@FocusState","type":"codeVoice"},{"text":", and have a custom ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)"},{"type":"text","text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:"}]},{"code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed    ","                \/\/ Use onSubmit: to detect the return key.","                \/\/ The onSubmit(...) view modifier doesn't work.","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"],"syntax":"swift","type":"codeListing"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"These views require at least a "},{"type":"codeVoice","code":"Silver"},{"type":"text","text":" license."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"These views require Full Access, due to an iOS b