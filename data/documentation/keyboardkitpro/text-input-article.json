{"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Actions-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/AI-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/App-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Autocomplete-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Callouts-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Device-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Dictation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Emojis-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/External-Keyboards-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Gestures-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Host-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Layout-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Localization-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Navigation-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Previews-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Proxy-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Settings-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Status-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Styling-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"],"anchor":"Features","title":"Features"}],"metadata":{"role":"article","roleHeading":"Article","title":"Text Input","images":[{"identifier":"Page.png","type":"card"}],"modules":[{"name":"KeyboardKitPro"}]},"abstract":[{"text":"This article describes the KeyboardKit text input engine, which lets you type within the keyboard extension.","type":"text"}],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkitpro\/text-input-article"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/text-input-article"]}],"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"iOS keyboard extensions use a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/UIKit\/UITextDocumentProxy","isActive":true,"type":"reference"},{"type":"text","text":" to insert and delete text, move the text input cursor, etc. This proxy will by default point to the currently selected text field in the currently active app."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Keyboard extensions will by default only send text to this proxy, and will "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" detect if you select a text field inside the keyboard. Even if you focus on a text field within the keyboard, text will still be sent to the text document proxy."}]},{"inlineContent":[{"type":"text","text":"These limitations make it hard to implement features that require text input in the keyboard, like emoji search, and AI-based features. KeyboardKit adds ways to make text routing easier."}],"type":"paragraph"},{"text":"Text Input","anchor":"Text-Input","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"KeyboardKit adds ways to make text routing easier. For instance, "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true},{"text":" has a custom ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy","type":"reference"},{"text":" that can be set to route text to any other text field or custom proxy.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Just set "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/textInputProxy"},{"text":" to start typing to that proxy, and set it to nil to resume typing into the active application. The controller’s ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/textDocumentProxy","type":"reference"},{"type":"text","text":" will point to this property if set. You can access the original proxy with "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardInputViewController\/originalTextDocumentProxy","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","text":"👑 KeyboardKit Pro","anchor":"%F0%9F%91%91-KeyboardKit-Pro"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true},{"text":" unlocks a ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","isActive":true},{"type":"text","text":" and a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView","type":"reference","isActive":true},{"type":"text","text":" that both automatically register and unregister as input proxy when they get and lose focus."}]},{"type":"heading","text":"Views","anchor":"Views","level":3},{"tabs":[{"title":"KeyboardTextField","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextField","type":"reference"},{"type":"text","text":" component wraps a native text field and can be used for single-line text input inside a keyboard extension."}]}]},{"title":"KeyboardTextView","content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardTextView"},{"text":" component wraps a native text view and can be used for multi-line text input inside a keyboard extension.","type":"text"}],"type":"paragraph"}]}],"type":"tabNavigator"},{"type":"paragraph","inlineContent":[{"text":"Both views support ","type":"text"},{"type":"codeVoice","code":"@FocusState"},{"text":", and have a custom ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/SwiftUICore\/View\/focused(_:doneButton:)","type":"reference","isActive":true},{"text":" view modifier that lets you provide a custom done button that slides in when the view is focused, and can be tapped to end editing:","type":"text"}]},{"type":"codeListing","code":["struct CustomKeyboardToolbar: View {","","    unowned var controller: KeyboardInputViewController","","    @State ","    private var text = \"\"","","    @FocusState ","    private var isTextFieldFocused","","    var body: some View {","        if hasFullAccess {","            KeyboardTextField(","                \"Type here...\", ","                text: $text, ","                controller: controller,","                config: configureTextField,","                onSubmit: handleReturnKeyPressed","            )","            .focused($isTextFieldFocused) {","                Image(systemName: \"xmark.circle.fill\")","            }","        }","    }","    ","    func configureTextField(_ view: UITextField) {","        \/\/ Configure the underlying view in any way you want.","    }","    ","    func handleReturnKeyPressed() {","        print(\"Return key pressed!\")","    }","}"],"syntax":"swift"},{"style":"tip","content":[{"inlineContent":[{"text":"The default ","type":"text"},{"type":"codeVoice","code":".onSubmit { ... }"},{"text":" view modifier doesn’t work for these text views. If you want to detect when the return key is pressed, you can instead pass in ","type":"text"},{"type":"codeVoice","code":"onSubmit:"},{"type":"text","text":" in the initializer."}],"type":"paragraph"}],"type":"aside","name":"Tip"},{"content":[{"inlineContent":[{"text":"These views require at least a ","type":"text"},{"code":"Silver","type":"codeVoice"},{"type":"text","text":" license. They also require Full Access, due to an iOS bug that causes a crash when using them while Full Access is disabled. They will automatically disable themselves when Full Access is disabled."}],"type":"paragraph"}],"name":"Important","style":"important","type":"aside"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro"]]},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Feedback-Article":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Feedback-Article","abstract":[{"text":"This article describes the KeyboardKit feedback engine.","type":"text"}],"url":"\/documentation\/keyboardkitpro\/feedback-article","role":"article","type":"topic","title":"Feedback","kind":"article","images":[{"type":"card","identifier":"Page.png"}]},"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Sta