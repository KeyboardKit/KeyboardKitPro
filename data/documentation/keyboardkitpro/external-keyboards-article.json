/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Text-Input-Article","doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Themes-Article"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Keyboard extensions start to behave strangely when you type on an external keyboard. For instance, the keyboard extension will stop receiving information about when text changes, and will only update the context when the text cursor moves."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"👑 "},{"identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro","isActive":true,"type":"reference"},{"type":"text","text":" unlocks tools that help you easily detect if an external keyboard is connected to the device, for instance if a magic keyboard is connected to an iPad. Information about Pro features can be found further down."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Workarounds","text":"Workarounds"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One way to force the proxy to update is to move the text cursor with a fixed interval, to make the keyboard read the current text. This may however interfere with the typing, so it’s not encouraged."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Due to this limitation, it may be better to collapse the keyboard to a compact toolbar when an external keyboard is connected. You can always add a button that expands the keyboard again."}]},{"level":2,"text":"How to collapse the keyboard","anchor":"How-to-collapse-the-keyboard","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext","isActive":true,"type":"reference"},{"type":"text","text":"’s "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardContext\/isKeyboardCollapsed"},{"text":" property can be used to collapse the keyboard, e.g. when an external keyboard is connected. KeyboardKit Pro will automatically update this if the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Settings\/isKeyboardAutoCollapseEnabled","type":"reference","isActive":true},{"type":"text","text":" setting is true."}]},{"inlineContent":[{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardView","isActive":true,"type":"reference"},{"type":"text","text":" lets you define which view to show when it’s collapsed. It defaults to a "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/CollapsedView","type":"reference","isActive":true},{"type":"text","text":". This can be used to display custom content when the keyboard is collapsed. See the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Essentials-Article","isActive":true,"type":"reference"},{"type":"text","text":" article for more information."}],"type":"paragraph"},{"level":2,"text":"How to manage external keyboard state","type":"heading","anchor":"How-to-manage-external-keyboard-state"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has an ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/ExternalKeyboardContext","isActive":true},{"text":" that has state for if an external keyboard is connected, such as a Smart Keyboard Folio, a Magic Keyboard, any Bluetooth keyboards, etc.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro will automatically keep this context up to date when an external keyboard is connected and disconnected. Without it, you must listen for connection changes yourself and update this context accordingly."}]},{"type":"thematicBreak"},{"type":"heading","level":2,"anchor":"%F0%9F%91%91-KeyboardKit-Pro","text":"👑 KeyboardKit Pro"},{"inlineContent":[{"type":"text","text":"KeyboardKit Pro will automatically keep the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/ExternalKeyboardContext","isActive":true},{"type":"text","text":" up to date when an external keyboard is connected and disconnected. Without it, you must listen for connection changes yourself and update this context accordingly."}],"type":"paragraph"},{"name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit Pro will consider an Apple Smart Keyboard Folio to be connected even when it’s just snapped on to the device and not being actively used. This should be improved."}]}],"type":"aside","style":"warning"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"This article describes the KeyboardKit external keyboard engine."}],"variants":[{"paths":["\/documentation\/keyboardkitpro\/external-keyboards-article"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/keyboardkitpro\/external-keyboards-article"]}],"metadata":{"color":{"standardColorIdentifier":"blue"},"modules":[{"name":"KeyboardKitPro"}],"role":"article","title":"External Keyboards","roleHeading":"Article","images":[{"identifier":"Page.png","type":"card"}]},"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/External-Keyboards-Article","interfaceLanguage":"swift"},"sections":[],"references":{"doc://com.keyboardkit.KeyboardKitPro/documentation/KeyboardKitPro/Text-Input-Article":{"type":"topic","abstract":[{"type":"text","text":"This article describes the KeyboardKit text input engine, which lets you type within the keyboard extension."}],"url":"\/documentation\/keyboardkitpro\/text-input-article","images":[{"t