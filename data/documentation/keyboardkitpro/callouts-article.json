e":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardStyleService"},{"text":".","type":"text"}]},{"type":"thematicBreak"},{"text":"👑 KeyboardKit Pro","type":"heading","anchor":"%F0%9F%91%91-KeyboardKit-Pro","level":2},{"type":"paragraph","inlineContent":[{"overridingTitleInlineContent":[{"type":"text","text":"KeyboardKit Pro"}],"type":"reference","isActive":true,"overridingTitle":"KeyboardKit Pro","identifier":"https:\/\/github.com\/KeyboardKit\/KeyboardKitPro"},{"type":"text","text":" unlocks a localized "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardCallout\/ProCalloutService"},{"type":"text","text":" for every locale in your license, and injects them as localized services into the main "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Keyboard\/Services\/calloutService"},{"type":"text","text":". You can access any localized service in your license like this:"}]},{"type":"codeListing","syntax":"swift","code":["let service = try KeyboardCallout.ProCalloutService.Swedish()"]},{"type":"paragraph","inlineContent":[{"text":"These services will throw an error if you try to access them without a valid KeyboardKit Pro license. If you are on the Basic or Silver plan, you must specify which locales to use in your ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/KeyboardApp"},{"text":". See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKitPro\/documentation\/KeyboardKitPro\/Getting-Started-Article"},{"text":" for more info.","type":"text"}]},{"type":"thematicBreak"},{"text":"How to…","type":"heading","anchor":"How-to","level":2},{"text":"…show callouts","type":"heading","anchor":"show-callouts","level":3},{"type":"paragraph",